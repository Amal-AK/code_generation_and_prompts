def anti_shuffle(s)
    """
  Wrtie a function that takes a string and returns a oredred version of it.
    Ordered version of string, is a string where all words(separated by space)
 are replaced by a new word where all the charcaters arragned in
    asecnding order based on ascii value.
    Note: You should keep the order of words and blank spaces in the sentence.

    For example:
    anti_shuffle('Hi') returns 'Hi'
    anti_shuffle('hello') returns 'ehllo'
    anti_shuffle('Hello World!!!') returns 'Hello !!!Wdlor'
    """
Code  :
def anti_shuffle(s):
    """
    Returns an ordered version of the string where each word's characters are sorted in ascending order
    based on ASCII value, while preserving the original word order and spaces.

    Args:
        s (str): Input string to be processed.

    Returns:
        str: String with each word's characters sorted in ascending order.
    """
    words = s.split(' ')
    ordered_words = []
    for word in words:
        # Sort the characters in the word based on ASCII value
        sorted_word = ''.join(sorted(word))
        ordered_words.append(sorted_word)
    # Join the words back with spaces
    return''.join(ordered_words)
