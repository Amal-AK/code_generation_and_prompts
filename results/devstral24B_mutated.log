def compare_one(a, b):
    def parse_number(s):
        if isinstance(s, (int, float)):
            return s
        s = s.replace(',', '.')
        try:
            return float(s)
        except ValueError:
            return s

    a_parsed = parse_number(a)
    b_parsed = parse_number(b)

    if isinstance(a_parsed, str) or isinstance(b_parsed, str):
        if isinstance(a_parsed, str) and isinstance(b_parsed, str):
            return a if a > b else b
        return None

    if a_parsed > b_parsed:
        return a
    elif b_parsed > a_parsed:
        return b
    else:
        return None
