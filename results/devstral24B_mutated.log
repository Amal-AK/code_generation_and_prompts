def is_prime(n):
    """Check if a number is prime."""
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    for i in range(3, int(n**0.5) + 1, 2):
        if n % i == 0:
            return False
    return True

def is_multiply_prime(a):
    """Return True if the given number is the multiplication of 3 prime numbers, False otherwise."""
    if a < 2:
        return False

    primes = []
    # Factorize the number
    temp = a
    for i in range(2, int(temp**0.5) + 1):
        while temp % i == 0 and is_prime(i):
            primes.append(i)
            temp = temp // i
    if temp > 1 and is_prime(temp):
        primes.append(temp)

    # Check if we have exactly 3 primes (counting multiplicities)
    return len(primes) == 3
