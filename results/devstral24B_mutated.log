def prod_signs(arr):
    if not arr:
        return None

    sum_magnitudes = sum(abs(num) for num in arr)

    product_signs = 1
    for num in arr:
        if num == 0:
            product_signs = 0
            break
        product_signs *= 1 if num > 0 else -1

    return sum_magnitudes * product_signs
