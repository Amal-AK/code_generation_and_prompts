import math

def poly(xs: list, x: float) -> float:
    """
    Evaluates polynomial with coefficients xs at point x.
    Returns xs[0] + xs[1] * x + xs[2] * x^2 +... + xs[n] * x^n
    """
    return sum(coeff * math.pow(x, i) for i, coeff in enumerate(xs))

def find_zero(xs: list) -> float:
    """
    Finds a zero of the polynomial defined by coefficients xs.
    Assumes xs has an even number of coefficients and the largest non-zero coefficient
    is at the end, guaranteeing a real solution.
    """
    # Binary search to find a root between -1000 and 1000
    low = -1000.0
    high = 1000.0

    # Check if we already have a root at 0
    if poly(xs, 0) == 0:
        return 0.0

    # Find a sign change
    while low <= high:
        mid = (low + high) / 2
        val = poly(xs, mid)
        if val == 0:
            return mid
        if val * poly(xs, low) < 0:
            high = mid
        else:
            low = mid

    # If no sign change found in [-1000, 1000], try a different approach
    # Since the problem states there's a solution, we'll use Newton's method
    # starting from a reasonable guess
    guess = 0.0
    for _ in range(100):
        val = poly(xs, guess)
        if abs(val) < 1e-10:
            return guess
        # Compute derivative
        deriv = sum(i * coeff * math.pow(guess, i-1) for i, coeff in enumerate(xs[1:], 1))
        if deriv == 0:
            break
        guess = guess - val / deriv

    return guess
