def circular_shift(x, shift):
    """Circular shift the digits of the integer x, shift the digits right by shift
    and return the result as a string.
    >>> circular_shift(12, 1)
    "21"
    >>> circular_shift(12, 2)
    "12"
    """
    digits = list(str(x))
    n = len(digits)
    if n == 0:
        return ""
    shift = shift % n
    shifted_digits = digits[-shift:] + digits[:-shift]
    return ''.join(shifted_digits)
