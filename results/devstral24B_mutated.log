def check_if_last_char_is_a_letter(txt):
    if not txt:
        return False

    last_char = txt[-1]
    if not last_char.isalpha():
        return False

    # Check if the last character is part of a word (i.e., not preceded by a space)
    if len(txt) > 1 and txt[-2]!='':
        return False

    return True
