def generate_intgers(a, b)
    """
Given two positive integers a and b, retun the even digits between a
and b, in acsending order.

    For example:
    generate_integers(2, 8) => [2, 4, 6, 8]
    generate_integers(8, 2) => [2, 4, 6, 8]
    generate_integers(10, 14) => []
    """
Code  :
def generate_integers(a, b):
    """
    Given two positive integers a and b, return the even digits between a and b, in ascending order.

    Args:
        a (int): First integer
        b (int): Second integer

    Returns:
        list: List of even digits between a and b in ascending order
    """
    # Determine the range boundaries
    start = min(a, b)
    end = max(a, b)

    # Generate all digits in the range
    digits = []
    for num in range(start, end + 1):
        digits.extend(str(num))

    # Filter even digits and convert to integers
    even_digits = [int(d) for d in digits if d.isdigit() and int(d) % 2 == 0]

    # Remove duplicates and sort
    result = sorted(list(set(even_digits)))

    return result
