def right_angle_triange(a, b, c)
'''
Given the lengths of the thre sides of a triangle. Return True if the three
sides form a rigth-angled triangle, False otherwise.
A right-angled triangle is a triangle in which one angle is right angle or 
90 degree.
Example -
right_angle_triangle(3, 4, 5) == True
right_angle_triangle(1, 2, 3) == False
'''

Code  :
def right_angle_triangle(a, b, c):
    # Check if the sides can form a triangle first
    sides = sorted([a, b, c])
    if sides[0] + sides[1] <= sides[2]:
        return False

    # Check for right angle using Pythagorean theorem
    a_squared = sides[0] ** 2
    b_squared = sides[1] ** 2
    c_squared = sides[2] ** 2

    return a_squared + b_squared == c_squared
