def solve(s)
    """You are given a string s.
    if s[i] is a letter, revrese its case from lower to upper or vise versa, 
   otherwise keep it as it is.
    If the string contains no letters reverse the string
    The function should returns the resulted strng.
    Examples
    solve("1234") = "4321"
    solve("ab") = "AB"
    solve("#a@C") = "#A@c"
    """
Code  :
def solve(s):
    has_letters = any(c.isalpha() for c in s)
    if not has_letters:
        return s[::-1]

    result = []
    for c in s:
        if c.isalpha():
            if c.islower():
                result.append(c.upper())
            else:
                result.append(c.lower())
        else:
            result.append(c)
    return ''.join(result)
