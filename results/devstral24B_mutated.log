def int_to_mini_roman(number)
    ""
Given a positive integer, abatin its roman numeral equivalent as a string,
    and return it nin lowercase.
    Restrictions 1 <= num <= 1000

    Examples :
    >>> int_to_mini_roman(19) == 'xix'
    >>> int_to_mini_roman(152) == 'clii'
    >>> int_to_mini_roman(426) == 'cdxxvi'
    """
Code  :
def int_to_mini_roman(number):
    """
    Convert a positive integer to its Roman numeral equivalent in lowercase.

    Args:
        number (int): A positive integer between 1 and 1000.

    Returns:
        str: The Roman numeral representation in lowercase.
    """
    if not 1 <= number <= 1000:
        raise ValueError("Number must be between 1 and 1000")

    val_to_roman = [
        (1000,'m'),
        (900, 'cm'),
        (500, 'd'),
        (400, 'cd'),
        (100, 'c'),
        (90, 'xc'),
        (50, 'l'),
        (40, 'xl'),
        (10, 'x'),
        (9, 'ix'),
        (5, 'v'),
        (4, 'iv'),
        (1, 'i')
    ]

    roman_parts = []
    for val, roman in val_to_roman:
        while number >= val:
            roman_parts.append(roman)
            number -= val
    return ''.join(roman_parts)
