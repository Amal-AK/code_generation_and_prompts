Code  :
def largest_prime_factor(n: int) -> int:
    """Return the largest prime factor of n.
    >>> largest_prime_factor(13195)
    29
    >>> largest_prime_factor(2048)
    2
    """
    if n < 2:
        return None

    largest_factor = 1
    # Handle even numbers first
    while n % 2 == 0:
        largest_factor = 2
        n = n // 2

    # Now check odd factors up to sqrt(n)
    i = 3
    max_factor = int(n**0.5) + 1
    while i <= max_factor:
        while n % i == 0:
            largest_factor = i
            n = n // i
            max_factor = int(n**0.5) + 1
        i += 2

    if n > 1:
        largest_factor = n

    return largest_factor
