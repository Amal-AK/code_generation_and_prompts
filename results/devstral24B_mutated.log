def encode_shift(s: str) -> str:
    """
    Encodes a string by shifting every character by 5 positions in the alphabet.
    Handles both uppercase and lowercase letters, leaving other characters unchanged.
    """
    def shift_char(c: str, shift: int) -> str:
        if 'a' <= c <= 'z':
            return chr(((ord(c) - ord('a') + shift) % 26) + ord('a'))
        elif 'A' <= c <= 'Z':
            return chr(((ord(c) - ord('A') + shift) % 26) + ord('A'))
        return c

    return ''.join(shift_char(c, 5) for c in s)

def decode_shift(s: str) -> str:
    """
    Decodes a string encoded with encode_shift by shifting every character back by 5 positions.
    """
    def shift_char(c: str, shift: int) -> str:
        if 'a' <= c <= 'z':
            return chr(((ord(c) - ord('a') + shift) % 26) + ord('a'))
        elif 'A' <= c <= 'Z':
            return chr(((ord(c) - ord('A') + shift) % 26) + ord('A'))
        return c

    return ''.join(shift_char(c, -5) for c in s)
