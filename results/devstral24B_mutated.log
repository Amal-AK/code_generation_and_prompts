Code  :
import math

def sum_squares(lst):
    """Return the sum of squared numbers in the given list after rounding each element to the upper int (ceiling)."""
    squared_sum = 0
    for num in lst:
        ceiling = math.ceil(num)
        squared_sum += ceiling ** 2
    return squared_sum
