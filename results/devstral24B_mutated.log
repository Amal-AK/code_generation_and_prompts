Code  :
def check_dict_case(dict):
    """
    Given a dictionary, return True if all keys are strings in lower case or all keys are strings in upper case,
    else return False.
    """
    if not dict:
        return True  # assuming empty dict meets the condition

    # Check if all keys are strings
    if not all(isinstance(key, str) for key in dict.keys()):
        return False

    # Determine the case of the first key
    first_key = next(iter(dict.keys()))
    if first_key.islower():
        # Check if all keys are lowercase
        return all(key.islower() for key in dict.keys())
    elif first_key.isupper():
        # Check if all keys are uppercase
        return all(key.isupper() for key in dict.keys())
    else:
        # First key is neither all lowercase nor all uppercase
        return False
