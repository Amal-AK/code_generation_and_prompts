def count_ones(n):
    """Helper function to count the number of 1s in the binary representation of n."""
    return bin(n).count('1')

def sort_array(arr):
    """
    Sorts an array of non-negative integers according to the number of ones in their binary representation.
    For negative numbers, it sorts them in ascending order (since their binary representation is not straightforward).
    """
    def sort_key(x):
        if x < 0:
            return (0, x)  # Negative numbers are sorted by their value
        return (count_ones(x), x)  # Non-negative numbers are sorted by count of 1s, then by value

    return sorted(arr, key=sort_key)
