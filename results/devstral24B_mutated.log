def even_odd_count(num):
    """Return a tuple with the count of even and odd digits in the number."""
    num_str = str(abs(num))
    even = 0
    odd = 0
    for digit in num_str:
        if int(digit) % 2 == 0:
            even += 1
        else:
            odd += 1
    return (even, odd)
