Code  :
def is_sorted(lst):
    # Check for more than one duplicate of the same number
    seen = set()
    for num in lst:
        if num in seen:
            return False
        seen.add(num)

    # Check if the list is sorted in ascending order
    for i in range(len(lst) - 1):
        if lst[i] > lst[i + 1]:
            return False
    return True
