Code  :
def change_base(x: int, base: int) -> str:
    """Change numerical base of input number x to base.
    return string representation after the conversion.
    >>> change_base(8, 3)
    '22'
    >>> change_base(8, 2)
    '1000'
    >>> change_base(7, 2)
    '111'
    """
    if x == 0:
        return "0"
    digits = []
    is_negative = False
    if x < 0:
        is_negative = True
        x = -x
    while x > 0:
        digits.append(str(x % base))
        x = x // base
    if is_negative:
        digits.append('-')
    return ''.join(reversed(digits)) if digits else "0"
