def will_it_fly(q, w):
    """
    Determines if the object q will fly based on its weight and balance.

    Args:
        q (list): List of weights representing the object's components.
        w (int): Maximum possible weight the object can have to fly.

    Returns:
        bool: True if the object will fly (sum of weights <= w and balanced), False otherwise.
    """
    total_weight = sum(q)
    if total_weight > w:
        return False

    # Check if the object is balanced (all elements are equal)
    if len(q) == 1:
        return True  # Single element is always balanced
    return all(x == q[0] for x in q)
