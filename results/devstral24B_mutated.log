Code  :
def check_dict_case(dictionary):
    if not dictionary:
        return False

    # Check if all keys are strings
    if not all(isinstance(key, str) for key in dictionary.keys()):
        return False

    # Determine the case of the first key
    first_key = next(iter(dictionary))
    if first_key.islower():
        # Check if all keys are lowercase
        return all(key.islower() for key in dictionary.keys())
    elif first_key.isupper():
        # Check if all keys are uppercase
        return all(key.isupper() for key in dictionary.keys())
    else:
        # Mixed case or other characters
        return False
