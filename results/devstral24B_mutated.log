from typing import List

def parse_music(music_string: str) -> List[int]:
    """Parse a string of musical notes into a list of beat counts."""
    note_map = {
        'o|': 2,
        '.|': 1
    }
    result = []
    i = 0
    n = len(music_string)
    while i < n:
        if music_string[i] =='':
            i += 1
            continue
        if i + 1 < n and music_string[i:i+2] in note_map:
            result.append(note_map[music_string[i:i+2]])
            i += 2
        else:
            # Handle cases where notes might be malformed (though examples suggest they're well-formed)
            # Default to 0 or handle as needed; here assuming input is correct per problem statement
            i += 1
    return result
