    """
    Write a function that takes a string and returns an ordered version of it.

    Note: You should keep the order of words and blank spaces in the sentence.

    For example:
    anti_shuffle('Hi') returns 'Hi'
    anti_shuffle('hello') returns 'ehllo'
    anti_shuffle('Hello World!!!') returns 'Hello !!!Wdlor'
    """
Code  :
def anti_shuffle(s):
    """
    Returns an ordered version of the string by sorting characters in each word while preserving word order and spaces.

    Args:
        s (str): Input string to be processed.

    Returns:
        str: String with characters in each word sorted in ascending order.
    """
    words = s.split(' ')
    processed_words = []
    for word in words:
        # Separate non-alphabetic characters and letters
        letters = [c for c in word if c.isalpha()]
        non_letters = [c for c in word if not c.isalpha()]
        # Sort the letters
        sorted_letters = sorted(letters)
        # Reconstruct the word
        processed_word = []
        letter_ptr = 0
        non_letter_ptr = 0
        for c in word:
            if c.isalpha():
                processed_word.append(sorted_letters[letter_ptr])
                letter_ptr += 1
            else:
                processed_word.append(non_letters[non_letter_ptr])
                non_letter_ptr += 1
        processed_words.append(''.join(processed_word))
    return''.join(processed_words)
