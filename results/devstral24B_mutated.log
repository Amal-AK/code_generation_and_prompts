def sort_even(l: list) -> list:
    """Return a list where even indices are sorted while odd indices remain unchanged."""
    even_indices = [l[i] for i in range(0, len(l), 2)]
    sorted_evens = sorted(even_indices)
    result = l.copy()
    for i, val in zip(range(0, len(l), 2), sorted_evens):
        result[i] = val
    return result
