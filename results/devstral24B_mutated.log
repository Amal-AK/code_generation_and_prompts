def largest_divisor(n: int) -> int:
    """ For a given number n, find the largest number that divides n evenly,
    >>> largest_divisor(15)
    5
    """
    if n == 0:
        return 0
    for i in range(n, 0, -1):
        if n % i == 0:
            return i
    return 1
