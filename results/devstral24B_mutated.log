Code  :
from fractions import Fraction

def simplify(x, n):
    """
    Simplifies the expression x * n and returns True if the result is a whole number, False otherwise.

    Args:
        x (str): A fraction in the form "a/b".
        n (str): A fraction in the form "a/b".

    Returns:
        bool: True if x * n is a whole number, False otherwise.
    """
    x_frac = Fraction(x)
    n_frac = Fraction(n)
    product = x_frac * n_frac
    return product.denominator == 1
