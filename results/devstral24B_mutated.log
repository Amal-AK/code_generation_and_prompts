    """
Code  :
def is_prime(n):
    """Helper function to check if a number is prime."""
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    for i in range(3, int(n**0.5) + 1, 2):
        if n % i == 0:
            return False
    return True

def prime_lengh(string):
    """Returns True if the length of the string is a prime number, False otherwise."""
    return is_prime(len(string))
