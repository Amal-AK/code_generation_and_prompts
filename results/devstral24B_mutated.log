Code  :
def is_odd_digit(digit):
    """Check if a digit is odd."""
    return digit in {1, 3, 5, 7, 9}

def specialFiltr(nums):
    """Return the count of numbers greater than 10 where first and last digits are odd."""
    count = 0
    for num in nums:
        if num > 10:
            # Handle negative numbers by taking absolute value
            abs_num = abs(num)
            # Convert to string to get first and last digits
            num_str = str(abs_num)
            first_digit = int(num_str[0])
            last_digit = int(num_str[-1])
            if is_odd_digit(first_digit) and is_odd_digit(last_digit):
                count += 1
    return count
