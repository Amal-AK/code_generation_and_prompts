Code  :
def plukc(arr):
    """
    Given an array representing a branch of a tree that has non-negative integer nodes,
    pluck one of the nodes and return it. The plucked node should be the node with the
    smallest even value. If multiple nodes with the same smallest even value are found,
    return the node that has the smallest index. If there are no even values or the given
    array is empty, return [].

    Args:
        arr: List of non-negative integers.

    Returns:
        List containing [smallest_even_value, its_index] or [] if no even values exist.
    """
    smallest_even = None
    smallest_index = -1

    for index, value in enumerate(arr):
        if value % 2 == 0:  # Check if the value is even
            if smallest_even is None or value < smallest_even:
                smallest_even = value
                smallest_index = index
            elif value == smallest_even and index < smallest_index:
                smallest_index = index

    if smallest_even is not None:
        return [smallest_even, smallest_index]
    else:
        return []
