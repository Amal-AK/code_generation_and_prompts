def is_prime(n):
    """Check if a number is prime."""
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    for i in range(3, int(n**0.5) + 1, 2):
        if n % i == 0:
            return False
    return True

def sum_of_digits(n):
    """Calculate the sum of digits of a number."""
    return sum(int(d) for d in str(abs(n)))

def skjkasdkd(lst):
    """Find the first prime number in the list and return the sum of its digits."""
    for num in lst:
        if is_prime(num):
            return sum_of_digits(num)
    return 0  # in case no prime is found, though examples suggest there's always one
