Code  :
def encode_cyclic(s: str) -> str:
    """
    Encodes a string by cycling groups of three characters.
    For each group of 3 characters, the first character is moved to the end.
    Groups with fewer than 3 characters remain unchanged.
    """
    groups = [s[i:i+3] for i in range(0, len(s), 3)]
    encoded_groups = []
    for group in groups:
        if len(group) == 3:
            encoded_groups.append(group[1:] + group[0])
        else:
            encoded_groups.append(group)
    return ''.join(encoded_groups)

def decode_cyclic(s: str) -> str:
    """
    Decodes a string encoded with encode_cyclic function.
    For each group of 3 characters, the last character is moved to the front.
    Groups with fewer than 3 characters remain unchanged.
    """
    groups = [s[i:i+3] for i in range(0, len(s), 3)]
    decoded_groups = []
    for group in groups:
        if len(group) == 3:
            decoded_groups.append(group[-1] + group[:-1])
        else:
            decoded_groups.append(group)
    return ''.join(decoded_groups)
