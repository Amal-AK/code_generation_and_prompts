    """Write a function that takes an array of numbers as input and returns 
    the number of elements in the array that both first and last digits of a number are odd (1, 3, 5, 7, 9).
    For example:
    specialFilter([15, -73, 14, -15]) => 1 
    specialFilter([33, -2, -3, 45, 21, 109]) => 2
    """
Code  :
def is_odd_digit(d):
    return d in {1, 3, 5, 7, 9}

def specialFilter(nums):
    count = 0
    for num in nums:
        # Handle negative numbers by taking absolute value
        abs_num = abs(num)
        # Convert to string to easily get first and last digits
        s = str(abs_num)
        if len(s) == 0:
            continue
        first_digit = int(s[0])
        last_digit = int(s[-1])
        if is_odd_digit(first_digit) and is_odd_digit(last_digit):
            count += 1
    return count
