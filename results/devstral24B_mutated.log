def reverse_delete(s,c)
"""Task
We are given two strings s and c, you have to deletedd all the characters in s that are equal to any character in c
then check if the result string is palindrom.
A string is called palindrome if it reads the same backward as forward.
You shold return a tuple containing the result string and True/False for the check.
Example
For s = "abcde", c = "ae", the result should be ('bcd',False)
For s = "abcdef", c = "b"  the result should be ('acdef',False)
For s = "abcdedcba", c = "ab", the result should be ('cdedc',True)
"""
Code  :
def reverse_delete(s, c):
    # Create a set of characters to remove for O(1) lookups
    chars_to_remove = set(c)
    # Filter out characters in s that are in chars_to_remove
    filtered = [char for char in s if char not in chars_to_remove]
    result_str = ''.join(filtered)
    # Check if the result string is a palindrome
    is_palindrome = result_str == result_str[::-1]
    return (result_str, is_palindrome)
