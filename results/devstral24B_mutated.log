    filtered = [num for num in arr if 1 <= num <= 9]
    # Sort the filtered numbers
    sorted_nums = sorted(filtered)
    # Reverse the sorted numbers
    reversed_nums = sorted_nums[::-1]
    # Map numbers to their corresponding names
    num_to_name = {
        1: "One",
        2: "Two",
        3: "Three",
        4: "Four",
        5: "Five",
        6: "Six",
        7: "Seven",
        8: "Eight",
        9: "Nine"
    }
    # Convert numbers to names
    result = [num_to_name[num] for num in reversed_nums]
    return result
