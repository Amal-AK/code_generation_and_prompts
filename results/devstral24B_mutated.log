Code  :
def make_a_pile(n):
    """
    Given an integer n, returns a list representing a pile of stones with n levels.
    The first level has n stones, and each subsequent level has the next odd or even number
    based on whether n is odd or even.

    Args:
        n (int): The number of levels in the pile.

    Returns:
        list: A list where the i-th element represents the number of stones in level (i+1).
    """
    pile = []
    current = n
    for _ in range(n):
        pile.append(current)
        if n % 2 == 1:  # n is odd, next level should be next odd
            current += 2
        else:  # n is even, next level should be next even
            current += 2
    return pile
