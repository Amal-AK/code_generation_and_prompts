Code  :
def modp(n: int, p: int) -> int:
    """Return 2^n modulo p."""
    if p == 1:
        return 0
    result = 1
    base = 2
    while n > 0:
        if n % 2 == 1:
            result = (result * base) % p
        base = (base * base) % p
        n = n // 2
    return result
