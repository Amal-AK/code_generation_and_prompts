""" Fin d how many times a given substring can be found in the original string. Count ovrelaping cases.
    >>> how_many_times('', 'a')
    0
    >>> how_many_times('aaa', 'a')
    3
    >>> how_many_times('aaaa', 'aa')
    3
"""

Code  :
def how_many_times(strng: str, substring: str) -> int:
    """Find how many times a given substring can be found in the original string. Count overlapping cases."""
    count = 0
    start = 0
    substring_len = len(substring)
    if substring_len == 0:
        return 0
    while True:
        start = strng.find(substring, start)
        if start == -1:
            break
        count += 1
        start += 1  # Move by 1 to allow overlapping matches
    return count
