def fix_spaces(text)
    """
  Given a string text, replcae all spaces in it with underscores, 
  and if a string has more than 2 consecutive spaces, 
then replace all consecutive spaces with - 
    
    fix_spaces("Example") == "Example"
    fix_spaces("Example 1") == "Example_1"
    fix_spaces(" Example 2") == "_Example_2"
    fix_spaces(" Example   3") == "_Example-3"
  ""

Code  :
def fix_spaces(text):
    """
    Replace spaces in the text according to the following rules:
    - Single spaces become underscores
    - Two consecutive spaces become underscores
    - Three or more consecutive spaces become a single hyphen
    """
    result = []
    i = 0
    n = len(text)

    while i < n:
        if text[i] =='':
            # Count consecutive spaces
            j = i
            while j < n and text[j] =='':
                j += 1
            space_count = j - i

            if space_count == 1:
                result.append('_')
            elif space_count == 2:
                result.append('_')
                result.append('_')
            else:
                result.append('-')

            i = j
        else:
            result.append(text[i])
            i += 1

    return ''.join(result)
