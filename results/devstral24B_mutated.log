Code  :
def can_arrange(arr):
    """
    Returns the largest index of an element which is not greater than or equal to the element immediately preceding it.
    If no such element exists, returns -1.
    """
    max_index = -1
    for i in range(1, len(arr)):
        if arr[i] < arr[i - 1]:
            max_index = i
    return max_index
