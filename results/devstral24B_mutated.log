Code  :
def factorial(n):
    """Helper function to compute the factorial of a number."""
    if n == 0 or n == 1:
        return 1
    return n * factorial(n - 1)

def special_factorial(n):
    """Computes the Brazilian factorial of n."""
    result = 1
    for i in range(1, n + 1):
        result *= factorial(i)
    return result
