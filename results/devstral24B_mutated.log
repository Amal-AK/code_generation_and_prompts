Code  :
def int_to_mini_roman(number):
    """
    Convert a positive integer to its lowercase Roman numeral representation.

    Args:
        number (int): A positive integer to convert.

    Returns:
        str: The Roman numeral in lowercase.

    Examples:
        >>> int_to_mini_roman(19)
        'xix'
        >>> int_to_mini_roman(152)
        'clii'
        >>> int_to_mini_roman(426)
        'cdxxvi'
    """
    if not isinstance(number, int) or number <= 0:
        raise ValueError("Input must be a positive integer")

    val_to_roman = [
        (1000,'m'), (900, 'cm'), (500, 'd'), (400, 'cd'),
        (100, 'c'), (90, 'xc'), (50, 'l'), (40, 'xl'),
        (10, 'x'), (9, 'ix'), (5, 'v'), (4, 'iv'), (1, 'i')
    ]

    roman_parts = []
    for val, roman in val_to_roman:
        while number >= val:
            roman_parts.append(roman)
            number -= val
    return ''.join(roman_parts)
