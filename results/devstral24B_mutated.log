    """You are given a word. Your task is to find the closest vowel that stands between 
    two consonants from the right side of the word.
    
    Vowels in the beginning and ending doesn't count. Return empty string if you didn't
    find any vowel met the above condition. 

    You may assume that the given string contains English letter only.

    Example:
    get_closest_vowel("yogurt") ==> "u"
    get_closest_vowel("FULL") ==> "U"
    get_closest_vowel("quick") ==> ""
    get_closest_vowel("ab") ==> ""
    """
Code  :
def get_closest_vowel(word):
    vowels = {'a', 'e', 'i', 'o', 'u', 'A', 'E', 'I', 'O', 'U'}
    consonants = set('bcdfghjklmnpqrstvwxyzBCDFGHJKLMNPQRSTVWXYZ')

    # Iterate from the second last character to the second character (right to left)
    for i in range(len(word) - 2, 0, -1):
        current_char = word[i]
        if current_char in vowels:
            # Check if the previous and next characters are consonants
            prev_char = word[i - 1]
            next_char = word[i + 1]
            if prev_char in consonants and next_char in consonants:
                return current_char
    return ""
