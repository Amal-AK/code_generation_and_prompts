'''
You are given a non emtpy list of positive integers. Return the greatest integer that is greater than 
zero, and has a frequecny greater than or equal to the value of the integer itself. 
The frequency of an integer is the number of times it appears in the list.
 If no such a value exsit, return -1.
Examples:
    search([4, 1, 2, 2, 3, 1]) == 2
    search([1, 2, 2, 3, 3, 3, 4, 4, 4]) == 3
    search([5, 5, 4, 4, 4]) == -1
'''
Code  :
from collections import Counter

def search(lst):
    if not lst:
        return -1

    frequency = Counter(lst)
    candidates = []

    for num in frequency:
        if num > 0 and frequency[num] >= num:
            candidates.append(num)

    if not candidates:
        return -1

    return max(candidates)
