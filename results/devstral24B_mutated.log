def check_if_last_char_is_a_letter(txt):
    if not txt:
        return False

    last_char = txt[-1]
    if not last_char.isalpha():
        return False

    # Check if the last character is not part of a word
    # A word is defined as a sequence of alphabetic characters
    # So we need to check if the last character is preceded by a non-alphabetic character
    # or if it's the first character in the string

    # Handle edge case where the string has only one character
    if len(txt) == 1:
        return True

    # Check the character before the last one
    prev_char = txt[-2]
    if prev_char.isalpha():
        return False
    else:
        return True
