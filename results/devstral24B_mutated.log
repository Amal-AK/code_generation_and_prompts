Code  :
def is_equal_to_sum_even(n):
    """
    Evaluate whether the given number n can be written as the sum of exactly 4 even numbers.
    """
    # The smallest sum of 4 even numbers is 2 + 2 + 2 + 2 = 8
    if n < 8:
        return False
    # The sum of 4 even numbers must be even (since even + even = even)
    if n % 2!= 0:
        return False
    # For even numbers >= 8, we can always represent them as the sum of 4 even numbers
    # For example, n = 2 + 2 + 2 + (n - 6), where (n - 6) is even and >= 2
    return True
