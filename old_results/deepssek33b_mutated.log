    probe_final_symbol("apple pi e ") ➞ False
    probe_final_symbol("") ➞ False 
    '''
Code  :
def probe_final_symbol(inp):
    if not inp:
        return False
    last_char = inp[-1]
    if not last_char.isalpha():
        return False
    if len(inp.split()) == 1:
        return True
    words = inp.split()
    last_word = words[-1]
    if last_char in last_word and last_word.count(last_char) == 1:
        return False
    return True
