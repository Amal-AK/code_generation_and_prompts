def tally(collection):
    """Given a non-empty collection of numbers collection. total the entries that meet a parity and positional condition.

    Examples:
        tally([4, 2, 6, 7]) ==> 2 
    """
    total = 0
    for i, num in enumerate(collection):
        if i % 2 == 0 and num % 2 == 0:
            total += num
    return total
