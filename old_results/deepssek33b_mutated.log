    characters move by an amount related to two being used twice.
    For example:
    alter('hi') returns 'lm'
    alter('asdfghjkl') returns 'ewhjklnop'
    alter('gf') returns 'kj'
    alter('et') returns 'ix'
    """
Code  :
def alter(inp):
    result = ""
    for char in inp:
        if char.isalpha():
            ascii_offset = ord('a') if char.islower() else ord('A')
            result += chr((ord(char) - ascii_offset + 2*2) % 26 + ascii_offset)
        else:
            result += char
    return result
