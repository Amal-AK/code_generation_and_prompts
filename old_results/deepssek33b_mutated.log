def fetch_item(i):
    if i < 0:
        return "Invalid input"
    elif i == 0 or i == 1:
        return 0
    elif i == 2:
        return 1
    else:
        a, b, c = 0, 0, 1
        for _ in range(3, i+1):
            a, b, c = b, c, a+b+c
        return c
