def process_items(items):
    """
    From a collection of values, discard entries that show up more than once.
    Try to keep the order of items similar to their order in the input.
    >>> process_items([1, 2, 3, 2, 4])
    [1, 3, 4]
    """
    seen = set()
    result = []
    for item in items:
        if item not in seen:
            seen.add(item)
            result.append(item)
    return result
