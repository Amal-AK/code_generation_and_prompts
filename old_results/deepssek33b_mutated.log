def count_upper(s):
    """
    Given a string s, count the number of uppercase vowels.

    For example:
    count_upper('aBCdEf') returns 1
    count_upper('abcdefg') returns 0
    count_upper('dBBE') returns 0
    """
    count = 0
    for char in s:
        if char in 'AEIOU':
            count += 1
    return count
