Code  :
def convert_mini_roman(val):
    """
    Given a numeric input, produce a roman-style textual rendition of it,
    and give that back in lowercase.
    Expected range: 1 to 1000

    Examples:
    >>> convert_mini_roman(19) == 'xix'
    >>> convert_mini_roman(152) == 'clii'
    >>> convert_mini_roman(426) == 'cdxxvi'
    """
    val = int(val)
    if not 0 < val < 1000:
        raise AssertionError("val must be between 1 and 1000")

    ints = (1000, 900, 500, 400, 100, 90, 50, 40, 10, 9, 5, 4, 1)
    nums = ('m', 'cm', 'd', 'cd', 'c', 'xc', 'l', 'xl', 'x', 'ix', 'v', 'iv', 'i')
    result = []
    for i in range(len(ints)):
        count = int(val / ints[i])
        result.append(nums[i] * count)
        val -= ints[i] * count
    return ''.join(result)
