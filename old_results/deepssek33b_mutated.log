        search([5, 5, 4, 4, 4]) == -1
    '''

Code  :
from collections import Counter

def search(lst):
    counter = Counter(lst)
    for num in sorted(counter.keys(), reverse=True):
        if num > 0 and counter[num] >= num:
            return num
    return -1
