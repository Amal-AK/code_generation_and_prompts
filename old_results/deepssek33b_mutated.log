import re

def count_items(seq):
    """Provide a routine count_items which accepts a sequence representing
    some text and yields the count of certain characters found.
    For this task, the relevant characters are 'a', 'e', 'i', 'o', 'u'.
    The letter 'y' is also considered relevant, but only when it appears
    at the end of the given term.

    Example:
    >>> count_items("abcde")
    2
    >>> count_items("ACEDY")
    3
    """
    seq = seq.lower()
    count = sum(1 for c in seq if c in 'aeiou')
    if seq.endswith('y'):
        count += 1
    return count
