Code  :
import string

def shift_vowel(letter):
    vowels = 'aeiou'
    if letter.lower() in vowels:
        return string.ascii_lowercase[(string.ascii_lowercase.index(letter.lower()) + 2) % 26]
    else:
        return letter

def process(content):
    return ''.join(shift_vowel(letter).upper() if index % 2 == 0 else shift_vowel(letter).lower() for index, letter in enumerate(content))
