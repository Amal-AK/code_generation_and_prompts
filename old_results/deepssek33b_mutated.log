def combine_values(items):
    """ For a given sequence of elements, return a pair containing an overall total and a product of the elements.
    For an empty input the total should be 0 and the product should be 1.
    >>> combine_values([])
    (0, 1)
    >>> combine_values([1, 2, 3, 4])
