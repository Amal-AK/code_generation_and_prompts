def seq(m):
    """Many people are familiar with the Fibonacci sequence; it has been examined a great deal over time. There is, however, a less familiar, Tribonacci-like variant.
    This variant is governed by a set of rules:
    seq(1) = 3
    seq(m) = 1 + m / 2, if m is even.
    seq(m) = seq(m - 1) + seq(m - 2) + seq(m + 1), if m is odd.
    For example:
    seq(2) = 1 + (2 / 2) = 2
    seq(4) = 3
    seq(3) = seq(2) + seq(1) + seq(4)
           = 2 + 3 + 3 = 8 
    You are given a non-negative whole number m, you should return a list of the
    first m + 1 entries of this sequence.
    Examples:
    seq(3) = [1, 3, 2, 8]
    """
Code  :
def seq(m):
    def helper(n):
        if n == 1:
            return 3
        elif n % 2 == 0:
            return 1 + n / 2
        else:
            return helper(n - 1) + helper(n - 2) + helper(n + 1)

    return [helper(i) for i in range(1, m + 2)]
