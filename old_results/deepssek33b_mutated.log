def apply_ops(symbols, values):
    result = values[0]
    for i in range(len(symbols)):
        if symbols[i] == '+':
            result += values[i + 1]
        elif symbols[i] == '-':
            result -= values[i + 1]
        elif symbols[i] == '*':
            result *= values[i + 1]
        elif symbols[i] == '//':
            result //= values[i + 1]
        elif symbols[i] == '**':
            result **= values[i + 1]
    return result
