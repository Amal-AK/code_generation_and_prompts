Code  :
def seems_mirror(value):
    """ Check whether the given input roughly mirrors itself """
    return value == value[::-1]

def form_symmetry(value):
    """ Produce a minimal symmetric form that starts with the given input.
    Rough idea:
    - Find the longest trailing part of the input that reads the same backwards.
    - Add on the reverse of an earlier portion so the whole thing looks symmetric.
    >>> form_symmetry('')
    ''
    >>> form_symmetry('cat')
    'catac'
    >>> form_symmetry('cata')
    'catac'
    """
    if seems_mirror(value):
        return value
    else:
        for i in range(len(value), -1, -1):
            if seems_mirror(value[:i]):
                return value + value[:i-1:-1]
