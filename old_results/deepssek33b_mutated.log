Code  :
def pick_one(items):
    def count_unique_chars(s):
        return len(set(s))

    max_unique_chars = max(count_unique_chars(item) for item in items)
    max_unique_chars_items = [item for item in items if count_unique_chars(item) == max_unique_chars]
    return min(max_unique_chars_items)
