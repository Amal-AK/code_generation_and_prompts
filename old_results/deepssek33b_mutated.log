Code  :
def seq4(pos):
    if pos < 0:
        raise ValueError("Position must be a non-negative integer.")
    elif pos < 4:
        return [0, 0, 2, 0][pos]
    else:
        seq = [0, 0, 2, 0]
        for i in range(4, pos + 1):
            seq.append(sum(seq[-4:]))
        return seq[-1]
