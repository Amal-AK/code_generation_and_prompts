def pick_items(data):
    """Given a bunch of numeric items in data. return an ordered subset of the
    entries that don't contain any even digit.

    Note: The output should be presented in ascending order.
    
    For example:
    >>> pick_items([15, 33, 1422, 1])
    [1, 15, 33]
    >>> pick_items([152, 323, 1422, 10])
    []
    """
Code  :
def pick_items(data):
    def has_even_digit(n):
        return any(int(digit) % 2 == 0 for digit in str(n))

    return sorted(n for n in data if not has_even_digit(n))
