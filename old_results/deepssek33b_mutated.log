def examine_fragments(parts):
    '''
    You are given a pair of strings, each made up only of opening '(' or closing ')' symbols.
    Your task is to check whether it's possible to join the two pieces in some order so the resulting text will be considered good.
    A string is considered good when its parentheses are properly paired. For example: '(())()' is good, while '())' is not.
    Return 'Yes' if there's a way to arrange them into a good string, and return 'No' otherwise.

    Examples:
    examine_fragments(['()(', ')']) == 'Yes'
    examine_fragments([')', ')']) == 'No'
    '''
Code  :
def examine_fragments(parts):
    def is_good(s):
        stack = []
        for c in s:
            if c == '(':
                stack.append(c)
            elif c == ')':
                if not stack or stack[-1]!= '(':
                    return False
                stack.pop()
        return not stack

    def dfs(parts, index, current):
        if index == len(parts):
            return is_good(current)
        return dfs(parts, index + 1, current + parts[index]) or dfs(parts, index + 1, parts[index] + current)

    return 'Yes' if dfs(parts, 0, "") else 'No'
