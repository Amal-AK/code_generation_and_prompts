def area_estimate(p, q, r):
    '''
    Given three measures that roughly represent the edges of a triangle. Produce
    the area of that shape rounded to 2 decimal points if the three measures
    form a plausible triangle. Otherwise yield -1
    Three edges are acceptable when the total of any two exceeds the third.
    Example:
    area_estimate(3, 4, 5) == 6.00
    area_estimate(1, 2, 10) == -1
    '''
Code  :
import math

def is_valid_triangle(a, b, c):
    return a + b > c and a + c > b and b + c > a

def area_estimate(p, q, r):
    if is_valid_triangle(p, q, r):
        s = (p + q + r) / 2
        area = math.sqrt(s * (s - p) * (s - q) * (s - r))
        return round(area, 2)
    else:
        return -1
