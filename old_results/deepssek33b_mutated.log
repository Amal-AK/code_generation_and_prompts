def overlap(range_a, range_b):
    """You are given two ranges,
    where each range is a pair of numbers. For example, range = (begin, finish) = (1, 2).
    The given ranges are inclusive which means that the span (begin, finish)
    includes both begin and finish.
    For each given range, it is assumed that its first value does not exceed its second.
    Your task is to decide whether the extent of the overlap of these two
    ranges is a prime number.
    Example, the overlap of the ranges (1, 3), (2, 4) is (2, 3)
    whose extent is 1, which is not a prime.
    If the extent of the overlap is a prime number, return "YES",
    otherwise, return "NO".
    If the two ranges don't overlap, return "NO".


    [input/output] samples:
    overlap((1, 2), (2, 3)) ==> "NO"
    overlap((-1, 1), (0, 4)) ==> "NO"
    overlap((-3, -1), (-5, 5)) ==> "YES"
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def overlap(range_a, range_b):
    begin = max(range_a[0], range_b[0])
    end = min(range_a[1], range_b[1])
    extent = end - begin + 1
    if extent <= 0:
        return "NO"
    return "YES" if is_prime(extent) else "NO"
