def has_nearby_items(values, margin):
    """ See whether, in a provided collection of values, any two entries end up nearer to one another than a certain margin.
    >>> has_nearby_items([1.0, 2.0, 3.0], 0.5)
    False
    >>> has_nearby_items([1.0, 2.8, 3.0, 4.0, 5.0, 2.0], 0.3)
    True
    """
    values.sort()
    for i in range(len(values) - 1):
        if values[i + 1] - values[i] < margin:
            return True
    return False
