Code  :
def change_base(x: int, base: int) -> str:
    """Change numerical base of input number x to base.
    return string representation after the conversion.
    >>> change_base(8, 3)
    '22'
    >>> change_base(8, 2)
    '1000'
    >>> change_base(7, 2)
    '111'
    """
    if x == 0:
        return '0'
    nums = []
    while x:
        x, rem = divmod(x, base)
        nums.append(str(rem))
    return ''.join(reversed(nums))
