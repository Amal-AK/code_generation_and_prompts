def looseFilter(vals):
    """Create a routine that accepts a collection of values and yields how many
    entries are above 10 and whose leading and trailing digits are odd (1, 3, 5, 7, 9).
    For example:
    looseFilter([15, -73, 14, -15]) => 1 
    looseFilter([33, -2, -3, 45, 21, 109]) => 2
    """
Code  :
def looseFilter(vals):
    def is_odd_digit(n):
        return n in [1, 3, 5, 7, 9]

    def is_valid(n):
        if n < 10:
            return False
        str_n = str(n)
        return is_odd_digit(int(str_n[0])) and is_odd_digit(int(str_n[-1]))

    return sum(1 for val in vals if is_valid(val))
