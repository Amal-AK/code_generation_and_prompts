def combine_signs(items):
    """
    You're given a collection items of numbers and should produce
    a total derived from the magnitudes adjusted by the combined sign
    of each element, where individual signs are represented by 1, -1 or 0.
    If the input is empty, return None.

    Example:
    >>> combine_signs([1, 2, 2, -4]) == -9
    >>> combine_signs([0, 1]) == 0
    >>> combine_signs([]) == None
    """
Code  :
def combine_signs(items):
    if not items:
        return None

    total = 0
    sign = 1

    for item in items:
        if item < 0:
            sign *= -1
        elif item == 0:
            return 0

    for item in items:
        total += item * sign

    return total
