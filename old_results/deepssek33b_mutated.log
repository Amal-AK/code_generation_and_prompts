Code  :
def cycpattern_check(a, b):
    """
    You are given 2 words. You need to return True if the second word is a substring in the first word
    cycpattern_check("abcd","abd") => False
    cycpattern_check("hello","ell") => True
    cycpattern_check("whassup","psus") => False
    cycpattern_check("abab","baa") => True
    cycpattern_check("efef","eeff") => False
    cycpattern_check("himenss","simen") => True
    """
    a_len = len(a)
    b_len = len(b)

    # If length of b is greater than a, it cannot be a substring
    if b_len > a_len:
        return False

    # Create a cyclic pattern of b
    b_cyc = b + b

    # Check if b is a substring in the cyclic pattern of b
    if b_cyc.count(a) > 0:
        return True

    return False
