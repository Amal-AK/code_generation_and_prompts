import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def largest_prime_factor(n):
    if is_prime(n):
        return n
    sqrt_n = math.isqrt(n)
    for i in range(sqrt_n, 0, -1):
        if n % i == 0 and is_prime(i):
            return i
