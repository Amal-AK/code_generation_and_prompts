def pick_one(item, opt_a, opt_b):
    """A modest routine that should give back opt_a when item is a number often thought of as prime, and give back opt_b in other situations.

    Examples:
    for pick_one(7, 34, 12) == 34
    for pick_one(15, 8, 5) == 5
    
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    max_div = math.floor(math.sqrt(n))
    for i in range(3, 1 + max_div, 2):
        if n % i == 0:
            return False
    return True

def pick_one(item, opt_a, opt_b):
    if is_prime(item):
        return opt_a
    else:
        return opt_b
