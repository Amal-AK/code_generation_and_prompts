def assess_marks(marks):
    """ marks is a sequence composed of "<" and ">".
    Indicate True when each start mark is paired with a corresponding end mark.

    >>> assess_marks("<")
    False
    >>> assess_marks("<>")
    True
    >>> assess_marks("<<><>>")
    True
    >>> assess_marks("><<>")
    False
    """
    count = 0
    for mark in marks:
        if mark == "<":
            count += 1
        elif mark == ">":
            count -= 1
        if count < 0:
            return False
    return count == 0
