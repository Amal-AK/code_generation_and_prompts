Code  :
def fibonacci(n):
    if n <= 0:
        return "Input should be positive integer."
    elif n == 1:
        return [1]
    elif n == 2:
        return [1, 1]
    else:
        fib_list = [1, 1]
        while len(fib_list) < n:
            fib_list.append(fib_list[-1] + fib_list[-2])
        return fib_list

def value_at(idx):
    if idx <= 0:
        return "Index should be positive integer."
    else:
        fib_series = fibonacci(idx)
        return fib_series[-1]
