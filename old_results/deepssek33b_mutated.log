    For items = [1,0,1,8,2,4597,2,1,3,40,1,2,1,2,4,2,5,1] the output should be 25
    For items = [1,3,1,32,5107,34,83278,109,163,23,2323,32,30,1,9,3] the output should be 13
    For items = [0,724,32,71,99,32,6,0,5,91,83,0,5,6] the output should be 11
    For items = [0,81,12,3,1,21] the output should be 3
    For items = [0,8,1,2,1,7] the output should be 7
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def process_numbers(items):
    max_prime = -1
    for item in items:
        if is_prime(item) and item > max_prime:
            max_prime = item
    return sum(int(digit) for digit in str(max_prime))
