Code  :
import re

def extract_groups(paren_text):
    """
    Input to this function is a string containing multiple clusters of nested parentheses. 
    Your aim is to pull those clusters out into individual strings and return a list of them.
    Groups are well-formed (each opener is properly closed) and not embedded within one another.
    Treat whitespace as insignificant in the input.
    >>> extract_groups('( ) (( )) (( )( ))')
    ['()', '(())', '(()())']
    """
    paren_text = paren_text.replace(" ", "")
    return re.findall(r'\(+\)+', paren_text)
