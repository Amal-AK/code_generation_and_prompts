Code  :
from typing import List

def factorize(n: int) -> List[int]:
    def get_factor(n):
        x = 2
        factors = []
        while x * x <= n:
            if n % x:
                x += 1
            else:
                n //= x
                factors.append(x)
        if n > 1:
            factors.append(n)
        return factors

    return get_factor(n)
