    Note: If a number is provided as text, the decimal marker could be . or ,

    pick_one(1, 2.5) ➞ 2.5
    pick_one(1, "2,3") ➞ "2,3"
    pick_one("5,1", "6") ➞ "6"
    pick_one("1", 1) ➞ None
    """
Code  :
import re

def convert_to_float(value):
    if isinstance(value, str):
        value = re.sub(r'[^\d.,-]', '', value)
        if '.' in value:
            value = float(value.replace(',', '.'))
        elif ',' in value:
            value = float(value.replace('.', '').replace(',', '.'))
        else:
            value = float(value)
    return value

def pick_one(p, q):
    p = convert_to_float(p)
    q = convert_to_float(q)

    if p > q:
        return p
    elif q > p:
        return q
    else:
        return None
