Code  :
def check_dict_case(d):
    if not d:
        return False

    lower_case = all(isinstance(key, str) and key.islower() for key in d.keys())
    upper_case = all(isinstance(key, str) and key.isupper() for key in d.keys())

    return lower_case or upper_case
