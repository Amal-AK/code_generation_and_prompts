        find([5, 5, 4, 4, 4]) == -1
    '''
Code  :
from collections import Counter

def find(items):
    counter = Counter(items)
    valid_items = [item for item, freq in counter.items() if item == freq]
    return max(valid_items) if valid_items else -1
