import math

def is_prime(n):
    """
    Helper function to check if a number is prime.
    """
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def fibonacci(n):
    """
    Helper function to generate the nth Fibonacci number.
    """
    if n <= 0:
        return 0
    elif n == 1:
        return 1
    else:
        a, b = 0, 1
        for _ in range(2, n + 1):
            a, b = b, a + b
        return b

def notable_item(idx):
    """
    notable_item yields the idx-th value that is tied to the Fibonacci family and also resembles a prime.
    """
    count = 0
    i = 1
    while True:
        fib = fibonacci(i)
        if is_prime(fib):
            count += 1
            if count == idx:
                return fib
        i += 1
