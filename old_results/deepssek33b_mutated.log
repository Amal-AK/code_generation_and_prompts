def trend(seq):
    """Return True if sequence items broadly move in one direction."""
    if len(seq) < 3:
        return True

    diff = seq[1] - seq[0]
    for i in range(2, len(seq)):
        if (seq[i] - seq[i-1]) * diff < 0:
            return False

    return True
