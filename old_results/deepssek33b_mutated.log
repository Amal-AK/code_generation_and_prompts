Code  :
def items(val):
    """Given a positive number val, return an overall multiplicative result of the odd parts.
    Produce 0 if none of the figures are odd.
    For example:
    items(1)  == 1
    items(4)  == 0
    items(235) == 15
    """
    odd_digits = [int(d) for d in str(val) if int(d) % 2!= 0]
    if not odd_digits:
        return 0
    result = 1
    for digit in odd_digits:
        result *= digit
    return result
