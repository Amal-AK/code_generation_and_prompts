def review_mapping_case(mapping):
    if not mapping:
        return False

    is_lower = all(k.islower() for k in mapping.keys() if isinstance(k, str))
    is_upper = all(k.isupper() for k in mapping.keys() if isinstance(k, str))

    return is_lower or is_upper
