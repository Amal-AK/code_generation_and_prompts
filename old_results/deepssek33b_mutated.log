import re

def tally_unique_parts(item):
    """ Given a piece of text, get a sense of how many different parts (ignoring case differences) it is made up of
    >>> tally_unique_parts('xyzXYZ')
    3
    >>> tally_unique_parts('Jerry')
    4
    """
    item = item.lower()
    parts = re.findall(r'\b\w+\b', item)
    return len(set(parts))
