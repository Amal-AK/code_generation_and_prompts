    '''
    Our planetary system has a set of worlds listed roughly by how near they are to the central star: Mercury, Venus, Earth, Mars, Jupiter, Saturn, Uranus, Neptune.
    Compose a routine that accepts two planet names as plain text inputs thing1 and thing2.
    The routine should produce a tuple containing the worlds whose orbits lie between the orbit of thing1 and the orbit of thing2, ordered by proximity to the star.
    The routine should yield an empty tuple if thing1 or thing2 are not recognized names.
    Examples
    locate_between("Jupiter", "Neptune") ==> ("Saturn", "Uranus")
    locate_between("Earth", "Mercury") ==> ("Venus")
    locate_between("Mercury", "Uranus") ==> ("Venus", "Earth", "Mars", "Jupiter", "Saturn")
    '''
Code  :
def locate_between(thing1, thing2):
    planets = ["Mercury", "Venus", "Earth", "Mars", "Jupiter", "Saturn", "Uranus", "Neptune"]
    if thing1 in planets and thing2 in planets:
        index1 = planets.index(thing1)
        index2 = planets.index(thing2)
        if index1 < index2:
            return tuple(planets[index1+1:index2])
        else:
            return tuple(planets[index2+1:index1])
    else:
        return ()
