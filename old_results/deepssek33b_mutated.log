def check_product_primes(val):
    """Provide a routine that signals whether the supplied value can be represented as a product of three prime factors
    or not.
    You may assume the input value is under 100.
    Example:
    check_product_primes(30) == True
    30 = 2 * 3 * 5
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def check_product_primes(val):
    factors = []
    for i in range(2, val // 2 + 1):
        if val % i == 0 and is_prime(i):
            factors.append(i)
            if len(factors) > 3:
                return False
    return len(factors) == 3
