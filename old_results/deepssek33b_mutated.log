def assess_pairing(marks):
    """ marks is a sequence of some opening and closing characters.
    return True if opening marks seem to have matching closing marks.

    >>> assess_pairing("(")
    False
    >>> assess_pairing("()")
    True
    >>> assess_pairing("(()())")
    True
    >>> assess_pairing(")(()")
    False
    """
Code  :
def assess_pairing(marks):
    stack = []
    for mark in marks:
        if mark == "(":
            stack.append(mark)
        elif mark == ")":
            if not stack or stack[-1]!= "(":
                return False
            stack.pop()
    return not stack
