import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def largest_prime_factor(n: int):
    """Return the largest prime factor of n."""
    if n <= 1:
        return None
    while n % 2 == 0:
        max_prime = 2
        n //= 2
    for i in range(3, math.isqrt(n) + 1, 2):
        while n % i == 0:
            max_prime = i
            n //= i
    if n > 2:
        max_prime = n
    return max_prime
