import math

def is_prime(n):
    """
    Helper function to check if a number is prime.
    """
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def fib(n):
    """
    Helper function to generate the n-th Fibonacci number.
    """
    a, b = 0, 1
    for _ in range(n):
        a, b = b, a + b
    return a

def prime_fib(n: int):
    """
    prime_fib returns n-th number that is a Fibonacci number.
    """
    count = 0
    i = 0
    while count < n:
        i += 1
        if is_prime(fib(i)):
            count += 1
    return fib(i)
