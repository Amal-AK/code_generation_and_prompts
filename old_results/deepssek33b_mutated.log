    """

Code  :
def specialFiltr(nums):
    def is_odd(n):
        return n in ['1', '3', '5', '7', '9']

    def is_special(n):
        return n > 10 and is_odd(str(n)[0]) and is_odd(str(n)[-1])

    return len([n for n in nums if is_special(n)])
