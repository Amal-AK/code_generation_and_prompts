def tally(collection):
    """
    Given a non-empty collection of numbers, total the entries that meet a parity and positional condition.

    Examples:
        tally([4, 2, 6, 7]) ==> 2
    """
    return sum(x for i, x in enumerate(collection) if (i % 2 == 0 and x % 2!= 0) or (i % 2!= 0 and x % 2 == 0))
