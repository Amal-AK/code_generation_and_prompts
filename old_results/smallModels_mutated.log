import re

def pick_one(p, q):
    if isinstance(p, str) and isinstance(q, str):
        p = re.sub(r'[^\d.,]', '', p)
        q = re.sub(r'[^\d.,]', '', q)
        if p == q:
            return None
        elif float(p) > float(q):
            return p
        else:
            return q
    elif isinstance(p, (int, float)) and isinstance(q, (int, float)):
        if p == q:
            return None
        elif p > q:
            return p
        else:
            return q
    else:
        raise ValueError("Invalid input types")
