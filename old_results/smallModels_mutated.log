def get_amount(source, piece):
    """ Figure out roughly how often a certain piece can be found in a larger body of content. Include overlapping instances.
    >>> get_amount('', 'a')
    0
    >>> get_amount('aaa', 'a')
    3
    >>> get_amount('aaaa', 'aa')
    3
    """
Code  :
def get_amount(source, piece):
    count = 0
    start = 0
    while True:
        start = source.find(piece, start)
        if start == -1:
            break
        count += 1
        start += 1
    return count
