def pair_check(item_one , item_two):
    """You're presented with a pair of tokens. You should indicate True when the latter token, or any of its cyclic shifts, appears somewhere inside the former token.
    pair_check("abcd","abd") => False
    pair_check("hello","ell") => True
    pair_check("whassup","psus") => False
    pair_check("abab","baa") => True
    pair_check("efef","eeff") => False
    pair_check("himenss","simen") => True

    """
Code  :
def pair_check(item_one, item_two):
    # Check if item_two is a substring of item_one
    if item_two in item_one:
        return True
    # If item_two is not a substring of item_one, check if any cyclic shift of item_two is a substring of item_one
    for i in range(len(item_two)):
        if item_two[i:] + item_two[:i] in item_one:
            return True
    # If no cyclic shift of item_two is a substring of item_one, return False
    return False
