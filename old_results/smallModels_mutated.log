def sort_even(l: list) -> list:
    """This function takes a list l and returns a list l' such that
    l' is identical to l in the odd indices.
    >>> sort_even([1, 2, 3])
    [1, 2, 3]
    >>> sort_even([5, 6, 3, 4])
    [3, 6, 5, 4]
    """
    even_indices = [i for i in range(len(l)) if i % 2 == 0]
    sorted_evens = sorted(l[i] for i in even_indices)

    result = l[:]
    for original_index, new_value in zip(even_indices, sorted_evens):
        result[original_index] = new_value

    return result
