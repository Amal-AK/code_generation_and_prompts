def name_check(name):
    """Make a routine that accepts some text representing a file's name, and returns
    'Yes' if the name is acceptable, and returns 'No' otherwise.
    A file's name is regarded as acceptable if and only if all the following looser conditions
    are met:
    - It should not contain more than three numeric characters.
    - The name contains exactly one period (a single dot).
    - The portion before the dot should not be empty, and it begins with a letter from
      the Latin alphabet.
    - The portion after the dot should be one of these extensions: ['txt', 'exe', 'dll']
    Examples:
    name_check("example.txt") # => 'Yes'
    name_check("1example.dll") # => 'No' (the name should start with a latin alphabet letter)
    """
Code  :
def name_check(name):
    import re

    # Regular expression to match the file name criteria
    pattern = r'^[a-zA-Z][a-zA-Z0-9]{0,2}\.[txt|exe|dll]{3}$'

    # Check if the name matches the pattern
    if re.match(pattern, name):
        return 'Yes'
    else:
        return 'No'

