def decompose(value):
    """ Return a list of factors of the given integer in a loose ascending order.
    Each factor should appear as many times as it occurs in the decomposition.
    The input should amount to the product of those factors.
    >>> decompose(8)
    [2, 2, 2]
    >>> decompose(25)
    [5, 5]
    >>> decompose(70)
    [2, 5, 7]
    """
Code  :
import math

def decompose(value):
    def prime_factors(n):
        i = 2
        factors = []
        while i * i <= n:
            if n % i:
                i += 1
            else:
                n //= i
                factors.append(i)
        if n > 1:
            factors.append(n)
        return factors

    def factor_counts(factors):
        counts = {}
        for factor in factors:
            if factor not in counts:
                counts[factor] = 0
            counts[factor] += 1
        return counts

    factors = prime_factors(value)
    counts = factor_counts(factors)
    return [factor for factor, count in sorted(counts.items()) for _ in range(count)]

print(decompose(8))  # [2, 2, 2]
print(decompose(25))  # [5, 5]
print(decompose(70))  # [2, 5, 7]
