    >>> reposition_segment(12, 1)
    "21"
    >>> reposition_segment(12, 2)
    "12"
    """
Code  :
def reposition_segment(item, amount):
    item = str(item)
    if amount > len(item):
        return item[::-1]
    else:
        return item[-amount:] + item[:-amount]
