Code  :
import collections

def smallest_change(arr):
    """
    Given an array arr of integers, find the minimum number of elements that
    need to be changed to make the array palindromic. A palindromic array is an array that
    is read the same backwards and forwards.

    For example:
    smallest_change([1,2,3,5,4,7,9,6]) == 4
    smallest_change([1, 2, 3, 4, 3, 2, 2]) == 1
    smallest_change([1, 2, 3, 2, 1]) == 0
    """
    # Step 1: Build a dictionary to keep track of the frequency of each element in the array
    freq = collections.Counter(arr)

    # Step 2: Find the minimum number of elements that need to be changed to make the array palindromic
    min_changes = 0
    for elem, count in freq.items():
        if count % 2 == 1:
            min_changes += 1

    return min_changes
