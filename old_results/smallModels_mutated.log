    iscube(180) ==> False
    '''
Code  :
def iscube(a):
    """
    Check if the given integer 'a' is a perfect cube.

    Args:
    a (int): The integer to check.

    Returns:
    bool: True if 'a' is a perfect cube, False otherwise.
    """
    # Handle negative numbers by checking their positive counterparts
    if a < 0:
        return iscube(-a)

    # Special case for 0
    if a == 0:
        return True

    # Calculate the cube root of the absolute value of 'a'
    cube_root = round(a ** (1/3))

    # Check if the cube of the calculated cube root equals 'a'
    return cube_root ** 3 == a
