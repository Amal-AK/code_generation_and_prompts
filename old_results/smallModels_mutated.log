def arrange_items(vals):
    """
    In this task, you should arrange a collection of numbers according to
    how many ones appear in their base-2 form, in increasing order.
    If they have a similar count of ones, order them by their usual numeric value.

    It must be implemented like this:
    >>> arrange_items([1, 5, 2, 3, 4]) == [1, 2, 3, 4, 5]
    >>> arrange_items([-2, -3, -4, -5, -6]) == [-6, -5, -4, -3, -2]
    >>> arrange_items([1, 0, 2, 3, 4]) [0, 1, 2, 3, 4]
    """
Code  :
def arrange_items(vals):
    def count_ones(n):
        return bin(n).count('1')

    return sorted(vals, key=lambda x: (count_ones(x), x))

