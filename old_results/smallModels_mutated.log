def reposition_segment(item, amount):
    """Reposition the characters of the input item, nudging them to the right by amount
    and give back the outcome as text.
    If amount > number of characters, yield the characters reversed.
    >>> reposition_segment(12, 1)
    "21"
    >>> reposition_segment(12, 2)
    "12"
    """
Code  :
def reposition_segment(item, amount):
    # Convert the item to string if it's not already
    item_str = str(item)

    # Calculate the effective shift within the bounds of the string length
    shift = amount % len(item_str)

    # If the shift is zero or negative, return the original string
    if shift == 0:
        return item_str

    # Perform the repositioning
    return item_str[-shift:] + item_str[:-shift]
