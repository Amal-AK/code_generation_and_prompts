Code  :
def central(items):
    sorted_items = sorted(items)
    n = len(sorted_items)
    if n % 2 == 1:
        return sorted_items[n // 2]
    else:
        return (sorted_items[n // 2 - 1] + sorted_items[n // 2]) / 2.0
