"""
Write a function which sotrts the given list of integers
in ascedning order according to the sum of their digits.
Note if there are several items with similar sum of their digits,
order them based on their index in original list.

For example:
>>> order_by_points([1, 11, -1, -11, -12]) == [-1, -11, 1, -12, 11]
>>> order_by_points([]) == []
"""

Code  :
import itertools

def order_by_points(nums):
    # Sort the list of numbers based on the sum of their digits
    sorted_nums = sorted(nums, key=lambda x: sum(map(int, str(x))))

    # If there are multiple items with the same sum of digits,
    # order them based on their index in the original list
    sorted_nums = sorted(sorted_nums, key=lambda x: nums.index(x))

    return sorted_nums
