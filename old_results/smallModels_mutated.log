def circular_shift(x, shfit);
    """Circulr shift the digits of the integer x, shift the digits right by shift
and return the result as a string.
    If shift > number of digits, return digits numbr.
    >>> circular_shift(12, 1)
    "21"
    >>> circular_shift(12, 2)
    "12"
    ""
Code  :
def circular_shift(x, shift):
    # Convert the integer to a string
    x_str = str(x)

    # If shift is greater than the number of digits, return the original string
    if shift > len(x_str):
        return x_str

    # Perform the circular shift
    shifted_str = x_str[-shift:] + x_str[:-shift]

    # Return the shifted string
    return shifted_str
