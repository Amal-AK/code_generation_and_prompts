def find(items):
    '''
    You are given a non-empty collection of positive numbers. Return the largest value that is above zero and that shows up at least as many times as the value itself.
    The frequency of a value is how often it appears in the collection.
    If no such value can be found, return -1.
    Examples:
        find([4, 1, 2, 2, 3, 1]) == 2
        find([1, 2, 2, 3, 3, 3, 4, 4, 4]) == 3
        find([5, 5, 4, 4, 4]) == -1
    '''
Code  :
def find(items):
    from collections import Counter

    count = Counter(items)
    for value in sorted(count.keys(), reverse=True):
        if count[value] >= value:
            return value
    return -1
