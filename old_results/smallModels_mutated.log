def right_angle_triangle(a, b, c):
    # Sort the sides to ensure the longest side is last (hypotenuse)
    sides = sorted([a, b, c])
    # Check if the Pythagorean theorem holds
    return sides[0]**2 + sides[1]**2 == sides[2]**2
