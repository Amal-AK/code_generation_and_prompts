    Example:
    tally('a b c') == {'a': 1, 'b': 1, 'c': 1}
    tally('a b b a') == {'a': 2, 'b': 2}
    tally('a b c a b') == {'a': 2, 'b': 2}
    tally('b b b b a') == {'b': 4}
    tally('') == {}

    """

Code  :
import collections

def tally(inp):
    """
    Given some input text made of space-separated tokens, produce a mapping of the symbol(s)
    that appear most frequently along with their counts. If multiple items share the top
    frequency, include all of them.

    Example:
    tally('a b c') == {'a': 1, 'b': 1, 'c': 1}
    tally('a b b a') == {'a': 2, 'b': 2}
    tally('a b c a b') == {'a': 2, 'b': 2}
    tally('b b b b a') == {'b': 4}
    tally('') == {}
    """
    counts = collections.Counter(inp.split())
    return {k: v for k, v in counts.most_common()}
