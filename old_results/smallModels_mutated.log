    [3, 6, 5, 4]
    """

Code  :
import itertools

def sort_even(l: list) -> list:
    """
    Sort the even indices of a list in ascending order.

    Args:
        l (list): The list to sort.

    Returns:
        list: The sorted list.
    """
    # Create a list of tuples containing the even indices and their corresponding values
    even_indices = [(i, x) for i, x in enumerate(l) if i % 2 == 0]

    # Sort the even indices in ascending order
    sorted_indices = sorted(even_indices, key=lambda x: x[1])

    # Create a new list with the sorted even indices and their corresponding values
    sorted_list = [x[1] for x in sorted_indices]

    # Return the sorted list
    return sorted_list
