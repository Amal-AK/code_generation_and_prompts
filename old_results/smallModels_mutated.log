def parts_in_text(text_input):
    """
    You are given some text,
    the text has some segments split by a space,
    and you should produce a string that includes the segments from the original input,
    whose sizes correspond to prime numbers,
    the ordering of the segments in the returned string should follow the original one.

    Example 1:
        Input: sentence = "This is a test"
        Output: "is"

    Example 2:
        Input: sentence = "lets go for swimming"
        Output: "go for"

    Constraints:
        * 1 <= len(input) <= 100
        * input contains only letters
    """
Code  :
import math

def parts_in_text(text_input):
    # Split the input text into a list of words
    words = text_input.split()

    # Initialize an empty list to store the prime-sized words
    prime_words = []

    # Iterate over the words in the input text
    for word in words:
        # Check if the length of the word is a prime number
        if math.sqrt(word) % 1 == 0:
            # If it is, add it to the list of prime-sized words
            prime_words.append(word)

    # Join the prime-sized words back into a string
    prime_text = " ".join(prime_words)

    return prime_text
