    """
Code  :
def is_prime(n):
    """Helper function to check if a number is prime."""
    if n <= 1:
        return False
    if n <= 3:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def process_numbers(items):
    """Function to find the largest prime number in the list and return the sum of its digits."""
    max_prime = None
    for item in items:
        if is_prime(item):
            if max_prime is None or item > max_prime:
                max_prime = item

    if max_prime is not None:
        return sum(int(digit) for digit in str(max_prime))
    else:
        return 0

