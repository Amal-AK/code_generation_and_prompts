Code  :
def has_nearby_items(values, margin):
    """
    Check if any two items in the list are closer to each other than the given margin.

    :param values: List of numerical values.
    :param margin: The maximum allowed distance between any two items.
    :return: True if any two items are closer than the margin, False otherwise.
    """
    # Sort the list to make it easier to find nearby items
    sorted_values = sorted(values)

    # Iterate through the sorted list and check adjacent items
    for i in range(len(sorted_values) - 1):
        if abs(sorted_values[i] - sorted_values[i + 1]) < margin:
            return True

    return False
