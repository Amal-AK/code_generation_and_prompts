import itertools

def blend_chars(first, second):
    first_chars = list(first)
    second_chars = list(second)
    blended_chars = []
    for f, s in itertools.zip_longest(first_chars, second_chars, fillvalue=''):
        blended_chars.append(f + s)
    return ''.join(blended_chars)
