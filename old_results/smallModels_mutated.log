Code  :
def arrange_by_score(items):
    """
    Provide a routine that orders the supplied collection of numbers
    in a less rigid way based on the cumulative value of their digits.
    If multiple entries share a similar digit total,
    keep them in the order they appeared originally.

    For example:
    >>> arrange_by_score([1, 11, -1, -11, -12]) == [-1, -11, 1, -12, 11]
    >>> arrange_by_score([]) == []
    """

    # Helper function to calculate the sum of digits of a number
    def sum_of_digits(n):
        return sum(int(digit) for digit in str(abs(n)))

    # Sort items using the sum of digits as the primary key
    # and the original index as the secondary key to maintain order
    sorted_items = sorted(enumerate(items), key=lambda x: (sum_of_digits(x[1]), x[0]))

    # Extract the sorted items while preserving the original order
    result = [item for _, item in sorted_items]

    return result
