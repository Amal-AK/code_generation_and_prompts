PromptUsed:
def process_paren_groups(text):
    """ The input to this routine is a piece of data composed of several groups of parentheses separated by whitespace.
    For each group, return an indication of the deepest nesting level present.
    E.g. (()()) has two levels while ((())) has three.

    >>> process_paren_groups('(()()) ((())) () ((())()())')
    [2, 3, 1, 3]
    """
Code  :
def process_paren_groups(text):
    import re

    # Split the text into groups of parentheses
    groups = re.findall(r'\(\)', text)

    # Initialize a list to store the nesting levels of each group
    levels = []

    # Process each group
    for group in groups:
        # Count the number of nested parentheses
        level = 0
        max_level = 0
        for char in group:
            if char == '(':
                level += 1
                if level > max_level:
                    max_level = level
            elif char == ')':
                level -= 1
        # Append the maximum level to the list
        levels.append(max_level)

    return levels
