import re

def correct_bracketing(brackets: str) -> bool:
    """Return True if every opening bracket has a corresponding closing bracket."""
    opening_brackets = re.findall(r'\(|\[|\{', brackets)
    closing_brackets = re.findall(r'\)|\]|\}', brackets)
    if len(opening_brackets)!= len(closing_brackets):
        return False
    for opening, closing in zip(opening_brackets, closing_brackets):
        if opening == '(' and closing!= ')':
            return False
        elif opening == '[' and closing!= ']':
            return False
        elif opening == '{' and closing!= '}':
            return False
    return True
