def modify_check(first,second):
    """Overview
    You're given two pieces of text first and second; you should take out all characters in first that match any character in second
    then check whether the remaining sequence reads the same backward as forward.
    A palindrome is when a sequence reads the same backward and forward.
    You should return a tuple containing the resulting sequence and a True/False indicator for the check.
    Example
    For first = "abcde", second = "ae", the result should be ('bcd',False)
    For first = "abcdef", second = "b"  the result should be ('acdef',False)
    For first = "abcdedcba", second = "ab", the result should be ('cdedc',True)
    """
Code  :
def modify_check(first, second):
    # Remove characters in second from first
    first = ''.join([char for char in first if char not in second])

    # Check if the remaining sequence reads the same backward as forward
    is_palindrome = first == first[::-1]

    return (first, is_palindrome)
