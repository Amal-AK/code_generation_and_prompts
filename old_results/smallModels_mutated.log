def convert_mini_roman(val):
    """
    Given a numeric input, produce a roman-style textual rendition of it,
    and give that back in lowercase.
    Expected range: 1 to 1000

    Examples:
    >>> convert_mini_roman(19) == 'xix'
    >>> convert_mini_roman(152) == 'clii'
    >>> convert_mini_roman(426) == 'cdxxvi'
    """
Code  :
def convert_mini_roman(val):
    if not 1 <= val <= 1000:
        raise ValueError("Value must be between 1 and 1000")

    roman_numerals = {
        1000:'m',
        900: 'cm',
        500: 'd',
        400: 'cd',
        100: 'c',
        90: 'xc',
        50: 'l',
        40: 'xl',
        10: 'x',
        9: 'ix',
        5: 'v',
        4: 'iv',
        1: 'i'
    }

    result = ''
    for value, numeral in roman_numerals.items():
        while val >= value:
            result += numeral
            val -= value

    return result
