def tweak_gaps(content):
    """
    Given an input sequence content, turn spacing characters into underscores, 
    and if the input contains runs of more than 2 consecutive spacing, 
    then fold those runs into a single dash 
    
    tweak_gaps("Example") == "Example"
    tweak_gaps("Example 1") == "Example_1"
    tweak_gaps(" Example 2") == "_Example_2"
    tweak_gaps(" Example   3") == "_Example-3"
    """
Code  :
def tweak_gaps(content):
    """
    Given an input sequence content, turn spacing characters into underscores,
    and if the input contains runs of more than 2 consecutive spacing,
    then fold those runs into a single dash
    """
    result = []
    space_count = 0

    for char in content:
        if char =='':
            space_count += 1
        else:
            if space_count > 2:
                result.append('-')
            elif space_count > 0:
                result.extend(['_'] * space_count)
            result.append(char)
            space_count = 0

    # Handle trailing spaces
    if space_count > 2:
        result.append('-')
    elif space_count > 0:
        result.extend(['_'] * space_count)

    return ''.join(result)

# Test cases
