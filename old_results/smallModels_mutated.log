Code  :
def is_bored(S):
    """
    Count the number of sentences starting with the word "I" in a given string S.
    Sentences are delimited by '.', '?' or '!'.

    :param S: String containing multiple sentences.
    :return: Number of boredoms (sentences starting with "I").
    """
    import re

    # Split the string into sentences using regex to match '.', '?', or '!'
    sentences = re.split(r'[.?!]\s*', S)

    # Count sentences that start with "I"
    boredom_count = sum(sentence.startswith('I') for sentence in sentences if sentence)

    return boredom_count

# Example usage:
