def parse_nested_parens(paren_string: str) -> List[int
  """ Input to this function is a string represnted multiple groups for nested parentheses separated by spaces.
    For each of the group, output the deepest level of nesting of parentheses.
    E.g. (()()) has maximum two levels of nesting while ((())) has three.

    >>> parse_nested_parens('(()()) ((())) () ((())()())')
    [2, 3, 1, 3]
    """

Code  :
import re

def parse_nested_parens(paren_string: str) -> List[int]:
    """
    Input to this function is a string represented multiple groups for nested parentheses separated by spaces.
    For each of the group, output the deepest level of nesting of parentheses.
    E.g. (()()) has maximum two levels of nesting while ((())) has three.
    """
    # Split the input string into individual groups of parentheses
    groups = re.split(r'\s+', paren_string)

    # Initialize a list to store the results
    results = []

    # Iterate over each group and count the number of nested parentheses
    for group in groups:
        count = 0
        for char in group:
            if char == '(':
                count += 1
            elif char == ')':
                count -= 1
        results.append(count)

    # Return the list of results
    return results
