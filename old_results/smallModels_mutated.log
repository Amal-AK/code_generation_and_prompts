Code  :
def encode_cyclic(s: str) -> str:
    """
    Encodes the given string by cycling groups of three characters.
    """
    # Split string into groups of three characters
    groups = [s[(3 * i):min((3 * i + 3), len(s))] for i in range((len(s) + 2) // 3)]

    # Cycle elements in each group unless the group has fewer than three elements
    groups = [(group[1:] + group[0]) if len(group) == 3 else group for group in groups]

    # Join the groups back into a single string
    return "".join(groups)

# Helper function to decode the cyclically encoded string
def decode_cyclic(s: str) -> str:
    """
    Decodes the given string that was encoded with the encode_cyclic function.
    """
    # Since encoding twice returns the original string, we can simply call encode_cyclic again
    return encode_cyclic(encode_cyclic(s))
