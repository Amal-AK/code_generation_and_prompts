Code  :
def apply_ops(symbols, values):
    """
    Given two sequences symbols and values. The first sequence contains some operation symbols, 
    and the second holds a collection of numbers. Use these two collections to form an algebraic 
    expression and return its computed result.

    The common operations:
    Addition ( + ) 
    Subtraction ( - ) 
    Multiplication ( * ) 
    Integer division ( // ) 
    Exponentiation ( ** ) 

    Example:
    symbols = ['+', '*', '-']
    values = [2, 3, 4, 5]
    result = 2 + 3 * 4 - 5
    => result = 9

    Note:
        The length of the symbol sequence equals the length of the value sequence minus one.
        Values are non-negative numbers.
        The symbol collection has at least one item, and the value collection has at least two items.
    """

    # Initialize the result with the first value
    result = values[0]

    # Iterate through the symbols and values to compute the expression
    for i, symbol in enumerate(symbols):
        if symbol == '+':
            result += values[i + 1]
        elif symbol == '-':
            result -= values[i + 1]
        elif symbol == '*':
            result *= values[i + 1]
        elif symbol == '//':
            result //= values[i + 1]
        elif symbol == '**':
            result **= values[i + 1]
        else:
            raise ValueError(f"Unsupported operation: {symbol}")

    return result
