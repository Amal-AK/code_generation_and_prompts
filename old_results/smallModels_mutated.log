    next_smallest([1, 1]) == None
    """
Code  :
def next_smallest(lst):
    if len(lst) < 2:
        return None
    first_min = second_min = float('inf')
    for num in lst:
        if num < first_min:
            second_min = first_min
            first_min = num
        elif first_min < num < second_min:
            second_min = num
    return second_min if second_min!= float('inf') else None
