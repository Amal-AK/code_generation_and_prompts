import re

def process_text(content):
    # Remove all vowels from the content
    vowels = "aeiou"
    content = re.sub(f"[{vowels}]", "", content)
    # Remove all consecutive letters from the content
    content = re.sub(r"(.)\1+", r"\1", content)
    return content
