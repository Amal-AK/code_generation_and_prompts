    """
Code  :
import re

def handle(seq):
    # Check if the input contains any letters
    if re.search(r'[a-zA-Z]', seq):
        # If it does, change the case of the letters
        return re.sub(r'[a-zA-Z]', lambda m: m.group(0).swapcase(), seq)
    else:
        # If it doesn't, reverse the input
        return seq[::-1]
