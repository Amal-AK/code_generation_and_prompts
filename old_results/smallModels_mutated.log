import re

def is_nested(string):
    """
    Check if a string contains a nested sequence of brackets.

    Args:
        string (str): The input string.

    Returns:
        bool: True if the string contains a nested sequence of brackets, False otherwise.
    """
    # Check if the string contains any brackets
    if not re.search(r'[[\]]', string):
        return False

    # Check if the string contains a nested sequence of brackets
    stack = []
    for char in string:
        if char == '[':
            stack.append(char)
        elif char == ']':
            if not stack:
                return False
            stack.pop()

    return not stack
