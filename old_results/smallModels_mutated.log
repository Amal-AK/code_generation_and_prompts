    check_size('abcdcba') == True
    check_size('kittens') == True
    check_size('orange') == False
    """
Code  :
import math

def check_size(item):
    def is_prime(n):
        if n == 1:
            return False
        if n == 2:
            return True
        if n % 2 == 0:
            return False
        max_div = math.floor(math.sqrt(n))
        for i in range(3, 1 + max_div, 2):
            if n % i == 0:
                return False
        return True

    return is_prime(len(item))
