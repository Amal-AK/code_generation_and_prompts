def process_text(t):
    """
    Make a routine that accepts some text and yields a more ordered form.
    The ordered form of the text is a version where all words (separated by space)
    are swapped out for a new word where the characters are put in
    a simple ascending arrangement based on underlying character codes.
    Note: You should keep the order of words and blank spaces in the sentence.

    For example:
    process_text('Hi') returns 'Hi'
    process_text('hello') returns 'ehllo'
    process_text('Hello World!!!') returns 'Hello!!!Wdlor'
    """

    def sort_word(word):
        return ''.join(sorted(word))

    words = t.split()
    sorted_words = [sort_word(word) if word.isalpha() else word for word in words]
    return''.join(sorted_words)

# Example usage:
