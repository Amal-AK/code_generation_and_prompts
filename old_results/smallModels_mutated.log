def assess_pairing(marks):
    """ marks is a sequence of some opening and closing characters.
    return True if opening marks seem to have matching closing marks.

    >>> assess_pairing("(")
    False
    >>> assess_pairing("()")
    True
    >>> assess_pairing("(()())")
    True
    >>> assess_pairing(")(()")
    False
    """
Code  :
def assess_pairing(marks):
    stack = []
    mapping = {")": "(", "}": "{", "]": "["}

    for mark in marks:
        if mark in mapping.values():
            stack.append(mark)
        elif mark in mapping:
            if not stack or mapping[mark]!= stack.pop():
                return False

    return not stack
