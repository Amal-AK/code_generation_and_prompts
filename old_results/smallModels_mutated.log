Code  :
import re

def correct_bracketing(brackets: str) -> bool:
    """
    Check if the given string of "(" and ")" brackets is correctly balanced.

    Args:
        brackets (str): A string of "(" and ")" brackets.

    Returns:
        bool: True if the brackets are correctly balanced, False otherwise.
    """
    # Check if the string contains any invalid characters
    if not re.match(r"^[()]*$", brackets):
        return False

    # Count the number of opening and closing brackets
    opening_brackets = brackets.count("(")
    closing_brackets = brackets.count(")")

    # Check if the number of opening and closing brackets is equal
    if opening_brackets!= closing_brackets:
        return False

    # Check if the brackets are correctly nested
    stack = []
    for char in brackets:
        if char == "(":
            stack.append(char)
        elif char == ")":
            if not stack or stack.pop()!= "(":
                return False

    # If we reach this point, the brackets are correctly balanced
    return True
