Code  :
import re

def item_allocation(txt, total):
    """
    Given a piece of text that hints at quantities of two fruit kinds
    that are placed in a container holding assorted produce,
    return how many of the remaining fruit are present.
    """
    pattern = r"(\d+) (\w+) and (\d+) (\w+)"
    match = re.search(pattern, txt)
    if match:
        apples = int(match.group(1))
        oranges = int(match.group(3))
        return total - apples - oranges
    else:
        return None
