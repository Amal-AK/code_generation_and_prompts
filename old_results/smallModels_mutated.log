def interpret_tune(tune_text):
    """ The input to this routine is a piece of text that represents musical items in a loose ASCII-like layout.
    Your job is to interpret that text and produce a list of integers indicating roughly how many beats each element lasts.

    Here is a simple key:
    'o' - whole note, lasts four beats
    'o|' - half note, lasts two beats
    '.|' - quater note, lasts one beat

    >>> interpret_tune('o o| .| o| o| .| .| .| .| o o')
    [4, 2, 1, 2, 2, 1, 1, 1, 1, 4, 4]
    """

Code  :
import re

def interpret_tune(tune_text):
    pattern = re.compile(r'[o|.|]')
    beats = []
    for match in pattern.finditer(tune_text):
        if match.group() == 'o':
            beats.append(4)
        elif match.group() == 'o|':
            beats.append(2)
        else:
            beats.append(1)
    return beats
