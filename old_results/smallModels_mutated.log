def shift_base(val, base):
    """Adjust the base representation of an input value val to another base.
    return a string-like representation after the change.
    bases are generally single-digit.
    >>> shift_base(8, 3)
    '22'
    >>> shift_base(8, 2)
    '1000'
    >>> shift_base(7, 2)
    '111'
    """
Code  :
def shift_base(val, base):
    if base < 2 or base > 9:
        raise ValueError("Base must be between 2 and 9, inclusive.")

    if val == 0:
        return "0"

    result = ""
    while val > 0:
        result = str(val % base) + result
        val //= base

    return result
