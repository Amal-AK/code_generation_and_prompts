def item_allocation(txt, total):
    """
    In this task, you will be given a piece of text that hints at quantities of two fruit kinds
    that are placed in a container holding assorted produce. The container may include
    apples, oranges, and some other fruit. Given the text that indicates the counts of
    the apples and oranges and an integer that indicates the overall amount of items
    in the container, return how many of the remaining fruit are present.
    for examble:
    item_allocation("5 apples and 6 oranges", 19) ->19 - 5 - 6 = 8
    item_allocation("0 apples and 1 oranges",3) -> 3 - 0 - 1 = 2
    item_allocation("2 apples and 3 oranges", 100) -> 100 - 2 - 3 = 95
    item_allocation("100 apples and 1 oranges",120) -> 120 - 100 - 1 = 19
    """

Code  :
import re

def item_allocation(txt, total):
    # Extract the number of apples and oranges from the text
    apples = int(re.search(r'(\d+) apples', txt).group(1))
    oranges = int(re.search(r'(\d+) oranges', txt).group(1))

    # Calculate the remaining fruit
    remaining = total - apples - oranges

    return remaining
