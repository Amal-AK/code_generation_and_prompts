PromptUsed:
def arrange_items(items):
    """ Input is a space-separated string of item words that stand for digits.
    These correspond broadly to the words for the digits zero through nine.
    Typical choices include 'zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight' and 'nine'.
    Return the string with the pieces ordered from smaller to larger
    >>> arrange_items('three one five')
    'one three five'
    """
Code  :
def arrange_items(items):
    # Define the words for the digits
    digit_words = ['zero', 'one', 'two', 'three', 'four', 'five','six','seven', 'eight', 'nine']

    # Split the input string into a list of words
    words = items.split()

    # Create a dictionary to map each word to its corresponding digit
    word_to_digit = {word: str(digit_words.index(word)) for word in digit_words}

    # Sort the words by their corresponding digits
    sorted_words = sorted(words, key=lambda word: word_to_digit[word])

    # Join the sorted words back into a string
    sorted_items =''.join(sorted_words)

    return sorted_items
