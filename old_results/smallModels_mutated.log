import re

def get_closest_vowel(word):
    vowels = ["a", "e", "i", "o", "u"]
    consonants = ["b", "c", "d", "f", "g", "h", "j", "k", "l", "m", "n", "p", "q", "r", "s", "t", "v", "w", "x", "y", "z"]
    word_list = list(word)
    for i in range(len(word_list)):
        if word_list[i] in vowels:
            if i == 0 or i == len(word_list) - 1:
                continue
            else:
                if word_list[i-1] in consonants and word_list[i+1] in consonants:
                    return word_list[i]
    return ""
