    """Given a positive number val, return an overall multiplicative result of the odd parts.
    Produce 0 if none of the figures are odd.
    For example:
    items(1)  == 1
    items(4)  == 0
    items(235) == 15
    """

Code  :
import math

def items(val):
    if val < 1:
        return 0
    result = 1
    for i in range(1, math.floor(math.sqrt(val)) + 1):
        if val % i!= 0:
            continue
        result *= i
        if val // i!= i:
            result *= val // i
    return result
