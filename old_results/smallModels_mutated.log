    prime_length('kittens') == True
    prime_length('orange') == False
    """
Code  :
def is_prime(n):
    """Helper function to check if a number is prime."""
    if n <= 1:
        return False
    if n <= 3:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def prime_length(s):
    """Function that checks if the length of a string is a prime number."""
    return is_prime(len(s))
