    0
    >>> feel_uninterested("The sky is blue. The sun is shining. I love this weather")
    1
    """
Code  :
import re

def feel_uninterested(txt):
    # Split the text into sentences using regex
    sentences = re.split('[.!?]', txt)
    # Initialize a counter
    counter = 0
    # Iterate over the sentences
    for sentence in sentences:
        # If the sentence starts with "I", increment the counter
        if sentence.strip().startswith("I"):
            counter += 1
    # Return the counter
    return counter
