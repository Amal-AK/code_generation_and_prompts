Code  :
import re

def collect_pieces(content):
    # Check if the content contains any gaps (spaces)
    if re.search(r'\s', content):
        # If it does, split the content on gaps
        return content.split()
    # If there are no gaps, check if the content contains any commas
    elif re.search(r',', content):
        # If it does, split the content on commas
        return content.split(',')
    # If there are no gaps or commas, return the count of lower-case letters at odd positions in the alphabet ordering
    else:
        return sum(1 for c in content if ord(c) % 2 == 1)
