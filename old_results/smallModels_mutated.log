    '''
    You are given a list of two strings.
    Your job to check if it is possible to concatenate the two strings in
    some order, that the resulting string will be good.
    A string S is considered to be good if and only if all parentheses in S
    are balanced. For example: the string '(())()' is good, while the string
    '())' is not.
    Return 'Yes' if there's a way to make a good string, and return 'No' otherwise.

    Examples:
    match_parens(['()(', ')']) == 'Yes'
    match_parens([')', ')']) == 'No'
    '''
Code  :
def match_parens(lst):
    # Check if the total number of parentheses is even
    if (lst[0].count('(') + lst[1].count('(')) % 2!= 0:
        return 'No'

    # Check if the number of closing parentheses is less than the number of opening parentheses
    if lst[0].count(')') > lst[0].count('(') or lst[1].count(')') > lst[1].count('('):
        return 'No'

    # Check if the number of closing parentheses in the first string is more than the number of opening parentheses in the second string
    if lst[0].count(')') > lst[1].count('('):
        return 'No'

    return 'Yes'
