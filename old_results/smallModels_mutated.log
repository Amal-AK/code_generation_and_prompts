Code  :
from typing import List

def parse_nested_parens(paren_string: str) -> List[int]:
    """ Input to this function is a string represented multiple groups for nested parentheses.
    For each of the group, output the deepest level of nesting of parentheses.
    E.g. (()()) has maximum two levels of nesting while ((())) has three.

    >>> parse_nested_parens('(()()) ((())) () ((())()())')
    [2, 3, 1, 3]
    """
    # Initialize an empty list to store the depths of each group
    depths = []

    # Split the string into groups
    groups = paren_string.split()

    # For each group
    for group in groups:
        # Initialize a counter for the depth of the current group
        depth = 0
        # Initialize a counter for the maximum depth
        max_depth = 0

        # For each character in the group
        for char in group:
            # If the character is an opening parenthesis
            if char == '(':
                # Increment the depth counter
                depth += 1
                # If the depth is greater than the maximum depth, update the maximum depth
                if depth > max_depth:
                    max_depth = depth
            # If the character is a closing parenthesis
            elif char == ')':
                # Decrement the depth counter
                depth -= 1

        # Append the maximum depth to the depths list
        depths.append(max_depth)

    # Return the depths list
    return depths
