    """Your aim is to create a small routine that yields true when a given value is a basic
    power of base and false in other situations.
    val is regarded as a basic power of base if it equals base raised to some integer exponent
    For example:
    seems_powerish(1, 4) => true
    seems_powerish(2, 2) => true
    seems_powerish(8, 2) => true
    seems_powerish(3, 2) => false
    seems_powerish(3, 1) => false
    seems_powerish(5, 3) => false
    """
Code  :
def seems_powerish(val, base):
    """Check if val is a basic power of base."""
    if base == 1:
        return val == 1
    if base <= 0 or val <= 0:
        return False

    current = base
    while current < val:
        current *= base

    return current == val
