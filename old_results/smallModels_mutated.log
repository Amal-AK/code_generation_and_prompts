Code  :
import math

def circular_shift(x, shift):
    num_digits = math.floor(math.log10(x)) + 1
    if shift > num_digits:
        return str(x)
    else:
        digits = [int(digit) for digit in str(x)]
        for i in range(shift):
            digits.append(digits.pop(0))
        return "".join(map(str, digits))
