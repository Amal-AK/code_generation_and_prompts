def solve(s)
    """You are given a string s.
    if s[i] is a letter, revrese its case from lower to upper or vise versa, 
   otherwise keep it as it is.
    If the string contains no letters reverse the string
    The function should returns the resulted strng.
    Examples
    solve("1234") = "4321"
    solve("ab") = "AB"
    solve("#a@C") = "#A@c"
    """
Code  :
def solve(s):
    # Check if the string contains any letters
    contains_letter = any(char.isalpha() for char in s)

    if contains_letter:
        # Reverse the case of each letter
        result = ''.join(char.swapcase() if char.isalpha() else char for char in s)
    else:
        # Reverse the entire string
        result = s[::-1]

    return result
