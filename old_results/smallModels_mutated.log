    '''Check if the supplied value can be seen as a combination of exactly 4 positive even quantities
    Example
    looks_like_combination(4) == False
    looks_like_combination(6) == False
    looks_like_combination(8) == True
    '''

Code  :
def looks_like_combination(val):
    # Check if the value is less than the smallest possible sum of 4 positive even numbers (2+2+2+2=8)
    if val < 8:
        return False

    # Check if the value is even, since the sum of even numbers is always even
    if val % 2!= 0:
        return False

    # Subtract the smallest possible sum of 3 positive even numbers (2+2+2=6) from the value
    remaining = val - 6

    # Check if the remaining value is even, which would mean it can be expressed as another even number
    return remaining % 2 == 0
