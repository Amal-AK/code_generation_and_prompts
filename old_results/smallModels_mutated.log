Code  :
import math

def calc(items, x):
    """
    Computes a value from given items at a point.
    return items[0] + items[1] * x + items[1] * x^2 +.... items[n] * x^n
    """
    return sum([coeff * math.pow(x, i) for i, coeff in enumerate(items)])

def locate_root(items):
    """ items represent coefficients for an expression.
    locate_root attempts to find a point where calc(items, x) == 0.
    locate_root returns only a single point, even if there are several.
    Also, locate_root only accepts inputs with certain length properties
    and where the leading non-zero entry makes a solution likely.
    >>> round(locate_root([1, 2]), 2) # f(x) = 1 + 2x
    -0.5
    >>> round(locate_root([-6, 11, -6, 1]), 2) # (x - 1) * (x - 2) * (x - 3) = -6 + 11x - 6x^2 + x^3
    1.0
    """
    # Check if the input is valid
    if len(items) < 2 or items[0] == 0:
        return None

    # Find the leading non-zero coefficient
    leading_coeff = items[0]
    for i in range(1, len(items)):
        if items[i]!= 0:
            leading_coeff = items[i]
            break

    # Check if the leading coefficient is positive
    if leading_coeff > 0:
        # Find the first root
        root = -leading_coeff / items[1]
        return root
    else:
        # Find the second root
        root = -leading_coeff / items[2]
        return root
