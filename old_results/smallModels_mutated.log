import math

def shift_base(val, base):
    """Adjust the base representation of an input value val to another base.
    return a string-like representation after the change.
    bases are generally single-digit.
    >>> shift_base(8, 3)
    '22'
    >>> shift_base(8, 2)
    '1000'
    >>> shift_base(7, 2)
    '111'
    """
    if base == 10:
        return str(val)
    else:
        return str(int(val, base))
