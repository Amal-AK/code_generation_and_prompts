def has_no_even_digit(n):
    """Check if a number contains no even digit."""
    return all(int(digit) % 2!= 0 for digit in str(n))

def pick_items(data):
    """Return an ordered subset of entries that don't contain any even digit."""
    filtered_data = [item for item in data if has_no_even_digit(item)]
    return sorted(filtered_data)

