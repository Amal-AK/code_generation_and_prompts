    >>> process_text('zbcd')
    'zbcd'
    """
    # Define the set of characters to remove
    chars_to_remove = {'a', 'A'}

    # Use a list comprehension to filter out unwanted characters
    result = ''.join([char for char in content if char not in chars_to_remove])

    return result
