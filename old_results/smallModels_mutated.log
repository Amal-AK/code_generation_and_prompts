Code  :
from typing import List

def remove_duplicates(numbers: List[int]) -> List[int]:
    count_dict = {}
    for num in numbers:
        if num in count_dict:
            count_dict[num] += 1
        else:
            count_dict[num] = 1
    return [num for num in numbers if count_dict[num] == 1]
