Code  :
def combine_items(items, count):
    """
    Given a sequence or collection of values items and a count, produce
    the total of entries that are up to two digits among the first count entries of items.

    Example:

        Input: items = [111,21,3,4000,5,6,7,8,9], count = 4
        Output: 24 # sum of 21 + 3

    Constraints:
        1. 1 <= len(items) <= 100
        2. 1 <= count <= len(items)
    """
    return sum(item for item in items[:count] if -99 <= item <= 99)

