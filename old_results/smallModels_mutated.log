Code  :
def add_elements(arr, k):
    # Sort the array in descending order
    arr.sort(reverse=True)

    # Initialize variables to keep track of the sum and the number of elements
    sum = 0
    count = 0

    # Iterate over the first k elements of the array
    for i in range(k):
        # If the current element is less than or equal to 99, add it to the sum and increment the count
        if arr[i] <= 99:
            sum += arr[i]
            count += 1
        # If the current element is greater than 99, break the loop since we only want to consider elements with at most two digits
        else:
            break

    # Return the sum of the elements with at most two digits from the first k elements of the array
    return sum
