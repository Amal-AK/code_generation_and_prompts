def parts_in_text(text_input):
    """
    You are given some text,
    the text has some segments split by a space,
    and you should produce a string that includes the segments from the original input,
    whose sizes correspond to prime numbers,
    the ordering of the segments in the returned string should follow the original one.

    Example 1:
        Input: sentence = "This is a test"
        Output: "is"

    Example 2:
        Input: sentence = "lets go for swimming"
        Output: "go for"

    Constraints:
        * 1 <= len(input) <= 100
        * input contains only letters
    """
Code  :
def is_prime(n):
    """Helper function to check if a number is prime."""
    if n <= 1:
        return False
    if n <= 3:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def parts_in_text(text_input):
    """
    Function to extract segments from the original input whose sizes correspond to prime numbers.

    :param text_input: A string containing segments separated by spaces.
    :return: A string with segments of prime length, preserving the original order.
    """
    words = text_input.split()
    result = []
    for word in words:
        if is_prime(len(word)):
            result.append(word)
    return''.join(result)

