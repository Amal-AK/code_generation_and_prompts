import itertools

def tally_vals(items):
    # Calculate the sum of the absolute values of each digit
    # in each number in the collection
    digit_sums = [sum(map(abs, list(str(item)))) for item in items]

    # Count the number of digit sums that are greater than zero
    return sum(1 for digit_sum in digit_sums if digit_sum > 0)
