    pick_next([1, 2, 3, 4, 5]) == 2
    pick_next([5, 1, 4, 3, 2]) == 2
    pick_next([]) == None
    pick_next([1, 1]) == None
    """
Code  :
import heapq

def pick_next(items):
    if len(items) < 2:
        return None
    heap = []
    for item in items:
        heapq.heappush(heap, item)
    smallest = heapq.heappop(heap)
    second_smallest = heapq.heappop(heap)
    return second_smallest
