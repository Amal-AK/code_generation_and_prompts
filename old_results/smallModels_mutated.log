    prime_length('abcdcba') == True
    prime_length('kittens') == True
    prime_length('orange') == False
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def prime_length(string):
    length = len(string)
    return is_prime(length)
