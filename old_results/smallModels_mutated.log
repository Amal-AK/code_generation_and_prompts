def fetch_item(i):
    """A FibFib-like series is a progression somewhat like a well-known additive series and is presented roughly as:
    fetch_item(0) == 0
    fetch_item(1) == 0
    fetch_item(2) == 1
    fetch_item(i) == fetch_item(i-1) + fetch_item(i-2) + fetch_item(i-3).
    Please provide a routine to obtain the i-th entry of this progression in a reasonably effective way.
    >>> fetch_item(1)
    0
    >>> fetch_item(5)
    4
    >>> fetch_item(8)
    24
    """

Code  :
def fetch_item(i):
    if i == 0 or i == 1:
        return 0
    elif i == 2:
        return 1

    a, b, c = 0, 0, 1
    for _ in range(3, i + 1):
        a, b, c = b, c, a + b + c
    return c
