def alter(inp):
    """Provide a routine alter that accepts some text input and
    returns a changed text with the characters being rotated.
    The set of characters should be shifted in a loose way such that the
    characters move by an amount related to two being used twice.
    For example:
    alter('hi') returns 'lm'
    alter('asdfghjkl') returns 'ewhjklnop'
    alter('gf') returns 'kj'
    alter('et') returns 'ix'
    """
Code  :
def alter(inp):
    result = []
    for char in inp:
        if 'a' <= char <= 'z':
            result.append(chr((ord(char) - ord('a') + 2) % 26 + ord('a')))
        elif 'A' <= char <= 'Z':
            result.append(chr((ord(char) - ord('A') + 2) % 26 + ord('A')))
        else:
            result.append(char)
    return ''.join(result)

