PromptUsed:
def pick_items(seq, count):
    """
    Given a sequence seq of values and a count count, return a sorted list 
    of length count with the top count items from seq.

    Example 1:

        Input: seq = [-3, -4, 5], count = 3
        Output: [-4, -3, 5]

    Example 2:

        Input: seq = [4, -4, 4], count = 2
        Output: [4, 4]

    Example 3:

        Input: seq = [-3, 2, 1, 2, -1, -2, 1], count = 1
        Output: [2]

    Note:
        1. The size of the input will be in the range of [1, 1000].
        2. The values in the input will be in the range of [-1000, 1000].
        3. 0 <= count <= len(seq)
    """
Code  :
import heapq

def pick_items(seq, count):
    """
    Given a sequence seq of values and a count count, return a sorted list 
    of length count with the top count items from seq.
    """
    if count > len(seq):
        raise ValueError("count cannot be greater than the length of the sequence")

    # Use a min heap to keep track of the top count items
    heap = []
    for i in range(count):
        heapq.heappush(heap, (seq[i], i))

    # Add the remaining items to the heap
    for i in range(count, len(seq)):
        heapq.heappush(heap, (seq[i], i))

    # Return the top count items from the heap
    return [item[0] for item in heapq.nsmallest(count, heap)]
