    tally_caps('abcdefg') returns 0
    tally_caps('dBBE') returns 0
    """

Code  :
import re

def tally_caps(src):
    vowels = "aeiou"
    caps_vowels = 0
    for i, c in enumerate(src):
        if c.isupper() and c in vowels:
            if i % 2 == 0:
                caps_vowels += 1
    return caps_vowels
