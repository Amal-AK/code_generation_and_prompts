def assess_pairing(marks):
    """ marks is a sequence of some opening and closing characters.
    return True if opening marks seem to have matching closing marks.

    >>> assess_pairing("(")
    False
    >>> assess_pairing("()")
    True
    >>> assess_pairing("(()())")
    True
    >>> assess_pairing(")(()")
    False
    """
Code  :
def assess_pairing(marks):
    stack = []
    for mark in marks:
        if mark in ['(', '[', '{', '<']:
            stack.append(mark)
        else:
            if not stack:
                return False
            if mark == ')' and stack[-1] == '(':
                stack.pop()
            elif mark == ']' and stack[-1] == '[':
                stack.pop()
            elif mark == '}' and stack[-1] == '{':
                stack.pop()
            elif mark == '>' and stack[-1] == '<':
                stack.pop()
            else:
                return False
    return not stack
