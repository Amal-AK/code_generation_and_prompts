def digits(n):
    """Given n, return the product of the odd digits.
    Return 0 if all digits are even.
    For example:
    digits(1)  == 1
    digits(4)  == 0
    digits(235) == 15
    """

Code  :
def digits(n):
    # Initialize the product of odd digits to 1
    product = 1
    # Convert the number to a string to iterate over its digits
    for digit in str(n):
        # If the digit is odd, multiply it to the product
        if int(digit) % 2!= 0:
            product *= int(digit)
    # If the product is still 1, all digits are even, so return 0
    if product == 1:
        return 0
    # Otherwise, return the product of the odd digits
    else:
        return product
