Code  :
import math

def evaluate_sides(s1, s2, s3):
    # Sort the sides in ascending order
    sides = sorted([s1, s2, s3])

    # Use the Pythagorean theorem to check if the triangle is right-angled
    return math.isclose(sides[0]**2 + sides[1]**2, sides[2]**2)
