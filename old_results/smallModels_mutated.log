import itertools

def sort_third(l: list) -> list:
    """
    Sorts the elements of a list in place, but only for the indices that are not divisible by 3.
    """
    l_sorted = sorted(l)
    l_sorted_third = [l_sorted[i] for i in range(0, len(l), 3)]
    l_sorted_remainder = [l_sorted[i] for i in range(1, len(l), 3)]
    l_sorted_remainder.extend(l_sorted_third)
    return l_sorted_remainder
