    match_parens(['()(', ')']) == 'Yes'
    match_parens([')', ')']) == 'No'
    '''
Code  :
import re

def match_parens(lst):
    """
    Return 'Yes' if there's a way to make a good string, and return 'No' otherwise.
    """
    pattern = re.compile(r'\([^()]*\)(*SKIP)(*F)|[()]')
    return 'Yes' if pattern.sub('', ''.join(lst)) == '' else 'No'
