def pick_one(p, q):
    """
    Create a routine that accepts numeric-ish things or textual forms of numbers,
    and gives back the one that seems larger in the same format it was given.
    Return None if they appear equal.
    Note: If a number is provided as text, the decimal marker could be. or,
    """
    # Helper function to convert string to float with support for both '.' and ',' as decimal markers
    def str_to_float(s):
        return float(s.replace(',', '.'))

    # Convert inputs to floats if they are strings, otherwise keep them as is
    try:
        p_float = str_to_float(p)
    except ValueError:
        p_float = p

    try:
        q_float = str_to_float(q)
    except ValueError:
        q_float = q

    # Compare the values
    if p_float == q_float:
        return None
    elif p_float > q_float:
        return p
    else:
        return q
