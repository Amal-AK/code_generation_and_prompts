Code  :
import collections

def pick_one(items):
    """
    Return the item with the greatest amount of varied characters.
    If several items share the greatest amount of varied characters,
    return the one that would appear earlier under a common textual ordering.
    """
    counter = collections.Counter(items)
    return max(items, key=lambda x: (counter[x], x))
