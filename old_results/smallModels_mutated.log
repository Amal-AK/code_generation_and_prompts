def apply_ops(symbols, values):
    """
    Given two sequences symbols and values. The first sequence contains some operation symbols, 
    and the second holds a collection of numbers. Use these two collections to form an algebraic 
    expression and return its computed result.

    The common operations:
    Addition ( + ) 
    Subtraction ( - ) 
    Multiplication ( * ) 
    Integer division ( // ) 
    Exponentiation ( ** ) 

    Example:
    symbols = ['+', '*', '-']
    values = [2, 3, 4, 5]
    result = 2 + 3 * 4 - 5
    => result = 9

    Note:
        The length of the symbol sequence equals the length of the value sequence minus one.
        Values are non-negative numbers.
        The symbol collection has at least one item, and the value collection has at least two items.

    """

Code  :
import operator

def apply_ops(symbols, values):
    result = values[0]
    for i in range(1, len(symbols)):
        symbol = symbols[i]
        value = values[i]
        if symbol == '+':
            result = operator.add(result, value)
        elif symbol == '-':
            result = operator.sub(result, value)
        elif symbol == '*':
            result = operator.mul(result, value)
        elif symbol == '//':
            result = operator.floordiv(result, value)
        elif symbol == '**':
            result = operator.pow(result, value)
        else:
            raise ValueError(f'Invalid symbol: {symbol}')
    return result
