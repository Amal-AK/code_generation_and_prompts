Code  :
def closest_integer(value):
    """
    Takes a string representing a number and returns the closest integer to it.
    If the number is equidistant from two integers, rounds it away from zero.

    Args:
    value (str): A string representing a number.

    Returns:
    int: The closest integer to the given number.
    """
    num = float(value)
    if abs(num - round(num)) == 0.5:
        return int(num + (num / abs(num)))
    else:
        return round(num)

