def check_if_last_char_is_a_letter(txt):
    # Strip any trailing whitespace from the input string
    txt = txt.rstrip()

    # Check if the last character is an alphabet and if it's preceded by a space or is the only character
    return len(txt) > 0 and txt[-1].isalpha() and (len(txt) == 1 or txt[-2] =='')
