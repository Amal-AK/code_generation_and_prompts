    [1, 2, 3]
    >>> process_items([5, 6, 3, 4])
    [3, 6, 5, 4]
    """

Code  :
import itertools

def process_items(items):
    """
    This routine accepts a collection items and returns an output of similar shape such that
    the output keeps entries at the other positions unchanged, while the entries at a certain set
    of positions are reordered.
    """
    # Get the positions to be reordered
    reorder_positions = [0, 2, 3]

    # Create a new list with the items at the reordered positions
    new_items = [items[pos] for pos in reorder_positions]

    # Add the remaining items to the new list
    new_items.extend(items[i] for i in range(len(items)) if i not in reorder_positions)

    return new_items
