def fibfib(n: int) -> int:
    if n == 0 or n == 1:
        return 0
    elif n == 2:
        return 1

    a, b = 0, 0
    c = 1
    for _ in range(3, n + 1):
        a, b = b, c
        c = a + b
    return c
