    >>> change_base(7, 2)
    '111'
    """
Code  :
def change_base(x: int, base: int) -> str:
    if base < 2 or base > 36:
        raise ValueError("Base must be between 2 and 36")

    digits = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    if x == 0:
        return "0"

    result = ""
    is_negative = x < 0
    x = abs(x)

    while x > 0:
        result = digits[x % base] + result
        x //= base

    if is_negative:
        result = "-" + result

    return result
