def find(items):
    '''
    You are given a non-empty collection of positive numbers. Return the largest value that is above zero and that shows up at least as many times as the value itself.
    The frequency of a value is how often it appears in the collection.
    If no such value can be found, return -1.
    Examples:
        find([4, 1, 2, 2, 3, 1]) == 2
        find([1, 2, 2, 3, 3, 3, 4, 4, 4]) == 3
        find([5, 5, 4, 4, 4]) == -1
    '''
Code  :
from collections import Counter

def find(items):
    # Count the frequency of each item in the list
    freq = Counter(items)

    # Initialize the result to -1, assuming no valid value is found
    result = -1

    # Iterate through the items and their frequencies
    for item, count in freq.items():
        # Check if the item's frequency is at least as large as the item itself
        if item <= count:
            # Update the result with the maximum valid item found so far
            result = max(result, item)

    return result
