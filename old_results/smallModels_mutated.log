Code  :
import re

def modify_check(first, second):
    """
    Modify the first string by removing all characters that match any character in the second string.
    Then, check if the resulting string is a palindrome.
    Return a tuple containing the modified string and a boolean indicating if it's a palindrome.
    """
    modified_string = re.sub(f"[{second}]", "", first)
    return modified_string, modified_string == modified_string[::-1]
