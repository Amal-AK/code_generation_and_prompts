def solve(N)
    \"\"\"Givn a positive integer N, retun the total sum of its digits in binary.
    
    Example
        For N = 1000, the sum of digits will be 1 the output should be \"1\".
        For N = 150, the sum of digits will be 6 the output should be \"110\".
        For N = 147, the sum of digits will be 12 the output should be \"1100\".
    
Variables:
        @N integer
             Constraints: 0 ≤ N ≤ 10000.
    Output
         a string of binary number
    \"\"\"
Code  :
def solve(N):
    # Convert the integer to binary and remove the '0b' prefix
    binary = bin(N)[2:]
    # Calculate the sum of the digits
    total_sum = sum(int(digit) for digit in binary)
    # Convert the sum to binary and return it
    return bin(total_sum)[2:]
