Code  :
def get_row(lst, x):
    """
    Find all occurrences of integer x in a 2D list and return their coordinates as a list of tuples.

    Parameters:
    lst (list of list of int): The 2D list to search within.
    x (int): The integer to search for.

    Returns:
    list of tuple: A list of tuples where each tuple represents the coordinates (row, column) of x.
    """
    result = []
    for i, row in enumerate(lst):
        for j, value in enumerate(row):
            if value == x:
                result.append((i, j))
    return result
