import math

def prime_fib(n: int) -> int:
    if n == 1:
        return 2
    elif n == 2:
        return 3
    else:
        a, b = 0, 1
        for _ in range(n-2):
            a, b = b, a + b
            if math.sqrt(5*a*a + 4) % 1 == 0:
                return a
        return a
