def handle(inp):
    """Given a numeric input inp, give a combined total of its digits when expressed in base 2.
    
    Example
        For inp = 1000, the sum of digits will be 1 the output should be "1".
        For inp = 150, the sum of digits will be 6 the output should be "110".
        For inp = 147, the sum of digits will be 12 the output should be "1100".
    
    Variables:
        @inp
             Constraints: 0 6le; inp 6le; 10000.
    Output:
         a string representing the binary result
    """
Code  :
def handle(inp):
    # Convert the input to binary and remove the '0b' prefix
    binary = bin(inp)[2:]

    # Calculate the sum of the digits
    total = sum(int(digit) for digit in binary)

    # Convert the sum to binary and remove the '0b' prefix
    result = bin(total)[2:]

    return result
