    """Provide a routine alter that accepts some text input and
    returns a changed text with the characters being rotated.
    The set of characters should be shifted in a loose way such that the
    characters move by an amount related to two being used twice.
    For example:
    alter('hi') returns 'lm'
    alter('asdfghjkl') returns 'ewhjklnop'
    alter('gf') returns 'kj'
    alter('et') returns 'ix'
    """
Code  :
def alter(inp):
    result = ""
    for char in inp:
        if char.isalpha():
            shift = 2
            char_code = ord(char.lower())
            new_char_code = (char_code - 97 + shift) % 26 + 97
            result += chr(new_char_code).upper() if char.isupper() else chr(new_char_code)
        else:
            result += char
    return result
