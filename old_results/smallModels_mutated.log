Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def main_prime_piece(val):
    sqrt_val = math.isqrt(val)
    for i in range(2, sqrt_val + 1):
        if val % i == 0 and is_prime(i):
            return i
    return val
