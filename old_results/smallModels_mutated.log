def pick_one(items):
    """Create a routine that takes a collection of textual items.
    The collection contains distinct entries. Return the entry with the greatest
    amount of varied characters. If several entries share the greatest amount
    of varied characters, return the one that would appear earlier under a
    common textual ordering.

    pick_one(["name", "of", "string"]) == "string"
    pick_one(["name", "enam", "game"]) == "enam"
    pick_one(["aaaaaaa", "bb" ,"cc"]) == ""aaaaaaa"
    """
Code  :
def pick_one(items):
    # Helper function to count the number of unique characters in a string
    def count_unique_chars(s):
        return len(set(s))

    # Initialize the maximum number of unique characters and the item with that many characters
    max_unique_chars = 0
    item_with_max_unique_chars = None

    # Iterate over the items
    for item in items:
        # Count the number of unique characters in the current item
        num_unique_chars = count_unique_chars(item)
        # If the number of unique characters is greater than the current maximum,
        # update the maximum and the item with that maximum
        if num_unique_chars > max_unique_chars:
            max_unique_chars = num_unique_chars
            item_with_max_unique_chars = item

    # Return the item with the maximum number of unique characters
    return item_with_max_unique_chars
