    """
    You are given an array arr of integers and you need to retun
    sum of magntudes of integers multiplied by prodcut of all signs
    of each number in the array, represented by 1, -1 or 0.
  Note: return None for empty arr.

    Example:
    >>> prod_signs([1, 2, 2, -4]) == -9
    >>> prod_signs([0, 1]) == 0
    >>> prod_signs([]) == None
    """
Code  :
def prod_signs(arr):
    if not arr:
        return None

    product_of_signs = 1
    magnitude_sum = 0

    for num in arr:
        if num == 0:
            return 0
        elif num < 0:
            product_of_signs *= -1

