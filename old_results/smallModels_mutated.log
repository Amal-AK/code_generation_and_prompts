def numerical_letter_grade(grades):
    """Converts a list of GPAs to their corresponding letter grades."""
    # Define the mapping from GPA to letter grade
    gpa_to_grade = {
        4.0: 'A+', 3.7: 'A', 3.3: 'A-', 3.0: 'B+', 2.7: 'B',
        2.3: 'B-', 2.0: 'C+', 1.7: 'C', 1.3: 'C-', 1.0: 'D+',
        0.7: 'D', 0.0: 'D-', -1: 'E'  # Using -1 as a sentinel value for GPA <= 0
    }

    # Convert each GPA to its corresponding letter grade
    letter_grades = []
    for gpa in grades:
        if gpa >= 4.0:
            letter_grades.append(gpa_to_grade[4.0])
        elif gpa >= 3.7:
            letter_grades.append(gpa_to_grade[3.7])
        elif gpa >= 3.3:
            letter_grades.append(gpa_to_grade[3.3])
        elif gpa >= 3.0:
            letter_grades.append(gpa_to_grade[3.0])
        elif gpa >= 2.7:
            letter_grades.append(gpa_to_grade[2.7])
        elif gpa >= 2.3:
