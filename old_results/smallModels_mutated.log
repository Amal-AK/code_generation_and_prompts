def get_max_triples(n)
    """
 You are gvien a positive integer n. You have to create an integer array a of lenngth n.
        For each i (1 ≤ i ≤ n), the value of a[i] = i * i - i + 1.
    Retunr the number of triples (a[i], a[j], a[k]) of a where i < j < k, 
and a[i] + a[j] + a[k] is a multiple of 3.

    Example :
        Input: n = 5
        Output: 1
        Explanation: 
        a = [1, 3, 7, 13, 21]
        The only valid triple is (1, 7, 13).
    '''
Code  :
def get_max_triples(n):
    # Helper function to calculate the value of a[i]
    def calculate_a(i):
        return i * i - i + 1

    # Generate the array a
    a = [calculate_a(i) for i in range(1, n + 1)]

    # Count the number of triples (a[i], a[j], a[k]) where i < j < k and their sum is a multiple of 3
    count = 0
    for i in range(n):
        for j in range(i + 1, n):
            for k in range(j + 1, n):
                if (a[i] + a[j] + a[k]) % 3 == 0:
                    count += 1

    return count
