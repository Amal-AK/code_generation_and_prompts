def encode(message):
    """
    Write a function that takes a message, and encodes in such a 
    way that it swaps case of all letters, replaces all vowels in 
    the message with the letter that appears 2 places ahead of that 
    vowel in the english alphabet. 
    
    Examples:
    >>> encode('test')
    'TGST'
    >>> encode('This is a message')
    'tHKS KS C MGSSCGG'
    """
Code  :
def encode(message):
    # Define a helper function to replace vowels with the letter 2 places ahead
    def replace_vowel(vowel):
        if vowel.lower() == 'a':
            return 'C' if vowel.isupper() else 'c'
        elif vowel.lower() == 'e':
            return 'G' if vowel.isupper() else 'g'
        elif vowel.lower() == 'i':
            return 'K' if vowel.isupper() else 'k'
        elif vowel.lower() == 'o':
            return 'Q' if vowel.isupper() else 'q'
        elif vowel.lower() == 'u':
            return 'W' if vowel.isupper() else 'w'

    # Encode the message
    encoded_message = []
    for char in message:
        if char.isalpha():
            # Swap case
            swapped_char = char.swapcase()
            # Replace vowel if it's a vowel
            encoded_char = replace_vowel(swapped_char)
        else:
            encoded_char = char
        encoded_message.append(encoded_char)

    return ''.join(encoded_message)

