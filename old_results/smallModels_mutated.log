    each pair represents a position - (row, column), starting from 0.
    Order positions first by row in ascending order.
    Within each row, arrange the column positions in descending order.
    
    Examples:
    probe_group([
      [1,2,3,4,5,6],
      [1,2,3,4,1,6],
      [1,2,3,4,5,1]
    ], 1) == [(0, 0), (1, 4), (1, 0), (2, 5), (2, 0)]
    probe_group([], 1) == []
    probe_group([[], [1], [1, 2, 3]], 3) == [(2, 2)]
    """
Code  :
import itertools

def probe_group(container, key):
    rows = []
    for row in container:
        cols = []
        for i, col in enumerate(row):
            if col == key:
                cols.append(i)
        if cols:
            rows.append((row.index(key), cols))
    return [(row, col) for row, cols in rows for col in reversed(cols)]
