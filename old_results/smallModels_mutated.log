def seq4(pos):
    """The Seq4 number series is a sequence similar to a common series that's described roughly as:
    seq4(0) -> 0
    seq4(1) -> 0
    seq4(2) -> 2
    seq4(3) -> 0
    seq4(m) -> seq4(m-1) + seq4(m-2) + seq4(m-3) + seq4(m-4).
    Write a routine to obtain the term at a given position of the seq4 series. Try to avoid recursive methods.
    >>> seq4(5)
    4
    >>> seq4(6)
    8
    >>> seq4(7)
    14
    """
Code  :
def seq4(pos):
    if pos < 2:
        return 0
    elif pos == 2:
        return 2

    # Initialize the first four terms of the sequence
    a, b, c, d = 0, 0, 2, 0

    # Compute the sequence iteratively from the 5th term onwards
    for _ in range(4, pos + 1):
        a, b, c, d = b, c, d, a + b + c + d

    return d

