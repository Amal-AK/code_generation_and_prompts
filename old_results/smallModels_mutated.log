def review_mapping_case(mapping):
    """
    Given a mapping-like input, return True if all keys are text values in lower 
    case or all keys are text values in upper case, otherwise return False.
    The function should return False if the provided mapping is empty.
    Examples:
    review_mapping_case({"a":"apple", "b":"banana"}) should return True.
    review_mapping_case({"a":"apple", "A":"banana", "B":"banana"}) should return False.
    review_mapping_case({"a":"apple", 8:"banana", "a":"apple"}) should return False.
    review_mapping_case({"Name":"John", "Age":"36", "City":"Houston"}) should return False.
    review_mapping_case({"STATE":"NC", "ZIP":"12345" }) should return True.
    """
Code  :
def review_mapping_case(mapping):
    if not mapping:
        return False
    keys = list(mapping.keys())
    if all(isinstance(key, str) for key in keys):
        lower_keys = [key.lower() for key in keys]
        upper_keys = [key.upper() for key in keys]
        return all(key == lower_key or key == upper_key for key, lower_key, upper_key in zip(keys, lower_keys, upper_keys))
    return False
