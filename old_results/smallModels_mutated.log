Code  :
def pick_one(p, q):
    # Convert the inputs to string type
    p = str(p)
    q = str(q)

    # Replace ',' with '.' in the inputs
    p = p.replace(',', '.')
    q = q.replace(',', '.')

    # Convert the inputs to float type
    p = float(p)
    q = float(q)

    # Compare the inputs and return the larger one
    if p > q:
        return p
    elif q > p:
        return q
    else:
        return None
