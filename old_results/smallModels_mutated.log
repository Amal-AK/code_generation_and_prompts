def assess_pairing(marks):
    """ marks is a sequence of some opening and closing characters.
    return True if opening marks seem to have matching closing marks.

    >>> assess_pairing("(")
    False
    >>> assess_pairing("()")
    True
    >>> assess_pairing("(()())")
    True
    >>> assess_pairing(")(()")
    False
    """
Code  :
import re

def assess_pairing(marks):
    opening_marks = ["(", "{", "["]
    closing_marks = [")", "}", "]"]
    stack = []
    for mark in marks:
        if mark in opening_marks:
            stack.append(mark)
        elif mark in closing_marks:
            if not stack or stack.pop()!= closing_marks[opening_marks.index(mark)]:
                return False
    return not stack
