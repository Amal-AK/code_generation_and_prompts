from typing import List

def separate_paren_groupz(paren_string: str) -> List[str]:
    stack = []
    result = []

    for char in paren_string:
        if char == "(":
            stack.append(char)
        elif char == ")":
            if not stack:
                raise ValueError("Unbalanced parentheses")
            stack.pop()
            if not stack:
                result.append("".join(stack))
                stack = []

    if stack:
        raise ValueError("Unbalanced parentheses")

    return result
