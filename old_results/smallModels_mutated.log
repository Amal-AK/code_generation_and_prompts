    or not.
    You may assume the input value is under 100.
    Example:
    check_product_primes(30) == True
    30 = 2 * 3 * 5
    """
Code  :
import math

def check_product_primes(val):
    def is_prime(n):
        if n < 2:
            return False
        for i in range(2, int(math.sqrt(n)) + 1):
            if n % i == 0:
                return False
        return True

    factors = []
    for i in range(2, val):
        if val % i == 0 and is_prime(i):
            factors.append(i)
            val = val // i
            if len(factors) > 3:
                return False
    return len(factors) == 3 and is_prime(val)
