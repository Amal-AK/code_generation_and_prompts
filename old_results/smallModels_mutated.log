    'TGST'
    >>> encode('This is a message')
    'tHKS KS C MGSSCGG'
    """
Code  :
def encode(message):
    vowels = 'aeiou'
    encoded_message = ''
    for char in message:
        if char.isalpha():
            if char.lower() in vowels:
                encoded_message += chr((ord(char) + 2) % 26 + ord('A') if char.isupper() else ord(char) + 2)
            else:
                encoded_message += chr((ord(char) - 32 + 2) % 26 + ord('A')) if char.isupper() else char
        else:
            encoded_message += char
    return encoded_message
