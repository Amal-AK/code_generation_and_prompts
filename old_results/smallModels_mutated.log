    """
    Given a collection of items, return a variant of the input after arranging it,
    you will arrange the input in an increasing order if the combined value of the end elements is odd,
    or arrange it in a decreasing order if the combined value of the end elements is even.

    Note:
    * try not to alter the original input.

    Examples:
    * handle_items([]) => []
    * handle_items([5]) => [5]
    * handle_items([2, 4, 3, 0, 1, 5]) => [0, 1, 2, 3, 4, 5]
    * handle_items([2, 4, 3, 0, 1, 5, 6]) => [6, 5, 4, 3, 2, 1, 0]
    """
Code  :
def handle_items(seq):
    if not seq:
        return []
    elif len(seq) == 1:
        return [seq[0]]
    else:
        combined_value = seq[0] + seq[-1]
        if combined_value % 2 == 0:
            return sorted(seq, reverse=True)
        else:
            return sorted(seq)
