def assess_one(size):
    """
    Given a positive whole number size, return the count of the size-digit
    positive numbers that begin or finish with the digit 1.
    """
    if size == 1:
        return 1
    else:
        # Numbers starting with 1: 1xxxx... (size-1 digits)
        # Numbers ending with 1 but not starting with 1: x...x1 (size-2 digits)
        return 9 * (10 ** (size - 2)) + (10 ** (size - 1))
