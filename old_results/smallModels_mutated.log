def tally_vals(items):
    """
    Create a small routine tally_vals that accepts a collection of numbers and
    produces how many entries have a digits-sum that is greater than zero.
    If a value is negative, the sign is carried by the leading digit:
    e.g. -123 has signed digits -1, 2, and 3.
    >>> tally_vals([]) == 0
    >>> tally_vals([-1, 11, -11]) == 1
    >>> tally_vals([1, 1, 2]) == 3
    """
Code  :
def tally_vals(items):
    def sum_digits(n):
        if n < 0:
            return sum_digits(-n)
        else:
            return sum(int(digit) for digit in str(n))

    return sum(1 for item in items if sum_digits(item) > 0)
