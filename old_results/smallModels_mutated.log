Code  :
def anti_shuffle(s):
    """
    Write a function that takes a string and returns an ordered version of it.

    Note: You should keep the order of words and blank spaces in the sentence.

    For example:
    anti_shuffle('Hi') returns 'Hi'
    anti_shuffle('hello') returns 'ehllo'
    anti_shuffle('Hello World!!!') returns 'Hello!!!Wdlor'
    """

    # Helper function to shuffle characters in a word
    def shuffle_word(word):
        return ''.join(sorted(word))

    # Split the input string into words and non-word characters
    import re
    tokens = re.findall(r'\b\w+\b|[^\w\s]', s)

    # Shuffle each word while keeping non-word characters as is
    shuffled_tokens = [shuffle_word(token) if token.isalpha() else token for token in tokens]

    # Join the shuffled tokens back into a single string
    return ''.join(shuffled_tokens)
