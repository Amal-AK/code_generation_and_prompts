    Examples:
    For items = [0,3,2,1,3,5,7,4,5,5,5,2,181,32,4,32,3,2,32,324,4,3] the output should be 10
    For items = [1,0,1,8,2,4597,2,1,3,40,1,2,1,2,4,2,5,1] the output should be 25
    For items = [1,3,1,32,5107,34,83278,109,163,23,2323,32,30,1,9,3] the output should be 13
    For items = [0,724,32,71,99,32,6,0,5,91,83,0,5,6] the output should be 11
    For items = [0,81,12,3,1,21] the output should be 3
    For items = [0,8,1,2,1,7] the output should be 7
    """
Code  :
import sympy

def process_numbers(items):
    # Filter out non-prime numbers
    primes = [i for i in items if sympy.isprime(i)]
    # If no prime number is found, return 0
    if not primes:
        return 0
    # Find the biggest prime number
    biggest_prime = max(primes)
    # Return the sum of its digits
    return sum(int(digit) for digit in str(biggest_prime))
