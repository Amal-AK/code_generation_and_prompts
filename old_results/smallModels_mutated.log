def gcd(a, b):
    """Helper function to calculate the greatest common divisor using Euclid's algorithm."""
    while b!= 0:
        a, b = b, a % b
    return a

def common_measure(first, second):
    """Provide a greatest common divisor for the two inputs."""
    return gcd(first, second)

