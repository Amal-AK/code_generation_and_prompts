Code  :
import math

def prime_fib(n: int):
    if n <= 0:
        raise ValueError("n must be a positive integer")
    if n == 1:
        return 2
    if n == 2:
        return 3
    a, b = 1, 2
    for _ in range(n-2):
        a, b = b, a+b
        if math.gcd(a, b) == 1:
            return a
    return b
