Code  :
from typing import List

# Helper dictionary to map number words to their numeric values
number_map = {
    'zero': 0,
    'one': 1,
    'two': 2,
    'three': 3,
    'four': 4,
    'five': 5,
   'six': 6,
   'seven': 7,
    'eight': 8,
    'nine': 9
}

def sort_numbers(numbers: str) -> str:
    """ Sorts a space-delimited string of number words from 'zero' to 'nine'. """
    # Split the input string into a list of number words
    words = numbers.split()

    # Convert each word to its corresponding numeric value using the helper dictionary
    numeric_values = [number_map[word] for word in words]

    # Sort the numeric values
    sorted_numeric_values = sorted(numeric_values)

    # Convert the sorted numeric values back to words using the helper dictionary
    sorted_words = [word for word, value in number_map.items() if value in sorted_numeric_values]

    # Join the sorted words back into a single string
    return''.join(sorted_words)

# Example usage
print(sort_numbers('three one five'))  # Output: 'one three five'
