def compare_one(a, b):
    if isinstance(a, str) and isinstance(b, str):
        a = a.replace(',', '.')
        b = b.replace(',', '.')
        try:
            a = float(a)
            b = float(b)
        except ValueError:
            return None
    elif isinstance(a, str):
        a = a.replace(',', '.')
        try:
            a = float(a)
        except ValueError:
            return None
    elif isinstance(b, str):
        b = b.replace(',', '.')
        try:
            b = float(b)
        except ValueError:
            return None

    if isinstance(a, float) and isinstance(b, float):
        return max(a, b)
    elif isinstance(a, int) and isinstance(b, int):
        return max(a, b)
    else:
        return None
