def inspect_entry(entry):
    """You need to provide a routine that checks a provided date-like text and
    returns True if it seems acceptable otherwise False.
    The value is acceptable if several broad conditions hold:
    1. The input isn't blank.
    2. The day part should fall within typical bounds depending on the month: up to 31 for months 1,3,5,7,8,10,12; up to 30 for months 4,6,9,11; and up to 29 for month 2.
    3. Months should lie within the usual 1-12 span.
    4. The value should follow the shape: mm-dd-yyyy

    for example: 
    inspect_entry('03-11-2000') => True

    inspect_entry('15-01-2012') => False

    inspect_entry('04-0-2040') => False

    inspect_entry('06-04-2020') => True

    inspect_entry('06/04/2020') => False
    """
Code  :
import re
from datetime import datetime

def inspect_entry(entry):
    # Check if the entry is not blank
    if not entry.strip():
        return False

    # Check if the entry follows the correct format
    if not re.match(r'\d{2}-\d{2}-\d{4}', entry):
        return False

    # Extract the day, month and year from the entry
    day, month, year = map(int, entry.split('-'))

    # Check if the day, month and year are within the valid ranges
    if day < 1 or day > 31 or month < 1 or month > 12:
        return False

    if month in [4, 6, 9, 11] and day > 30:
        return False
    elif month == 2 and day > 29:
        return False
    elif month in [1, 3, 5, 7, 8, 10, 12] and day > 31:
        return False

    # Check if the year is a leap year if the month is February and the day is 29
    if month == 2 and day == 29 and not (year % 4 == 0 and (year % 100!= 0 or year % 400 == 0)):
        return False

    return True
