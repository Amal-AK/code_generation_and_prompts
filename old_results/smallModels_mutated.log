    2. The day part should fall within typical bounds depending on the month: up to 31 for months 1,3,5,7,8,10,12; up to 30 for months 4,6,9,11; and up to 29 for month 2.
    3. Months should lie within the usual 1-12 span.
    4. The value should follow the shape: mm-dd-yyyy

    for example: 
    inspect_entry('03-11-2000') => True

    inspect_entry('15-01-2012') => False

    inspect_entry('04-0-2040') => False

    inspect_entry('06-04-2020') => True

    inspect_entry('06/04/2020') => False
    """
Code  :
import re

def inspect_entry(entry):
    if not entry.strip():
        return False

    match = re.match(r'^(\d{2})-(\d{2})-(\d{4})$', entry)
    if not match:
        return False

    month, day, year = match.groups()
    if not (1 <= int(month) <= 12 and 1 <= int(day) <= get_max_day(int(month)) and 2000 <= int(year) <= 2099):
        return False

    return True

def get_max_day(month):
    if month in [1, 3, 5, 7, 8, 10, 12]:
        return 31
    elif month in [4, 6, 9, 11]:
        return 30
    else:
        return 29 if month == 2 else 0
