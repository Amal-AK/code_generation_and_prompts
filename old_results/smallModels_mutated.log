import math

def strange_sort_lst(lst):
    if not lst:
        return []
    result = [lst[0]]
    for i in range(1, len(lst)):
        if lst[i] > result[-1]:
            result.append(lst[i])
    for i in range(len(lst) - 1, -1, -1):
        if lst[i] < result[0]:
            result.insert(0, lst[i])
    return result
