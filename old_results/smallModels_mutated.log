def apply_shift(data):
    """
    produces a changed sequence by rotating small groups of three items.
    """
    # break input into pieces. Typically size three.
    pieces = [data[(3 * i):min((3 * i + 3), len(data))] for i in range((len(data) + 2) // 3)]
    # rotate items in each piece, except shorter ones.
    pieces = [(piece[1:] + piece[0]) if len(piece) == 3 else piece for piece in pieces]
