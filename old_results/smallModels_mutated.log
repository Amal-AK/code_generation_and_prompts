def valid_date(date):
    """
    Validates a given date string and returns True if the date is valid otherwise False.
    The date is valid if all of the following rules are satisfied:
    1. The date string is not empty.
    2. The months should not be less than 1 or higher than 12.
    3. The date should be in the format: mm-dd-yyyy

    for example: 
    valid_date('03-11-2000') => True

    valid_date('15-01-2012') => False

    valid_date('04-0-2040') => False

    valid_date('06-04-2020') => True

    valid_date('06/04/2020') => False
    """
    from datetime import datetime

    # Check if the date string is not empty
    if not date:
        return False

    # Try to parse the date string using the specified format
    try:
        parsed_date = datetime.strptime(date, '%m-%d-%Y')
    except ValueError:
        return False

    # Extract month from the parsed date
    month = parsed_date.month

    # Check if the month is within the valid range (1-12)
    if month < 1 or month > 12:
        return False

    return True
