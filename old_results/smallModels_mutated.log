def specialFiltr(nums)
    """Write a function that takes an array of numbrs as input and returns 
    the number of elements in the array that are greater than 10 and both 
    first and last digits of a number are odd (1, 3, 5, 7, 9).
For example: specialFilter([15, -73, 14, -15]) => 1 
    specialFilter([33, -2, -3, 45, 21, 109]) => 2
    """

Code  :
def specialFiltr(nums):
    def is_odd(n):
        return n % 2!= 0

    def first_and_last_odd(n):
        str_n = str(abs(n))
        return is_odd(int(str_n[0])) and is_odd(int(str_n[-1]))

    return sum(1 for num in nums if num > 10 and first_and_last_odd(num))
