    """
Code  :
def is_odd(n):
    """Helper function to check if a digit is odd."""
    return int(n) % 2!= 0

def specialFilter(nums):
    """Function to count numbers with odd first and last digits."""
    count = 0
    for num in nums:
        str_num = str(abs(num))  # Convert number to string and handle negative sign
        if is_odd(str_num[0]) and is_odd(str_num[-1]):
            count += 1
    return count
