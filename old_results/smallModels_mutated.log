def is_valid_triangle(a, b, c):
    return a + b > c and a + c > b and b + c > a

def area_estimate(p, q, r):
    if not is_valid_triangle(p, q, r):
        return -1
    s = (p + q + r) / 2
    area = (s * (s - p) * (s - q) * (s - r)) ** 0.5
    return round(area, 2)
