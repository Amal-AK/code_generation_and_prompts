def digits(n):
    """Given n, return the product of the odd digits.
    Return 0 if all digits are even.
    For example:
    digits(1)  == 1
    digits(4)  == 0
    digits(235) == 15
    """
    product = 1
    has_odd = False

    for digit in str(n):
        int_digit = int(digit)
        if int_digit % 2!= 0:
            product *= int_digit
            has_odd = True

    return product if has_odd else 0
