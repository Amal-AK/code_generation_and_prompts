    """
Code  :
def is_simple_power(x, n):
    """
    Returns True if x is a simple power of n, False otherwise.

    A number x is considered a simple power of n if there exists an integer k such that n**k = x.

    Parameters:
    x (int): The number to check.
    n (int): The base number.

    Returns:
    bool: True if x is a simple power of n, False otherwise.
    """
    if n == 1:
        return x == 1

    k = 0
    while n**k <= x:
        if n**k == x:
            return True
        k += 1

    return False
