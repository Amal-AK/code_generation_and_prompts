def compute_minimal_amount(items):
    """
    Given a collection of values items, determine the smallest total of any non-empty portion of items.
    Example
    compute_minimal_amount([2, 3, 4, 1, 2, 4]) == 1
    compute_minimal_amount([-1, -2, -3]) == -6
    """
Code  :
import itertools

def compute_minimal_amount(items):
    # Sort the items in descending order
    items = sorted(items, reverse=True)

    # Compute the sum of the items
    total = sum(items)

    # Initialize the minimal amount to the total
    minimal_amount = total

    # Iterate over all possible subsets of the items
    for subset in itertools.combinations(items, total):
        # Compute the sum of the subset
        subset_sum = sum(subset)

        # If the sum is less than the minimal amount, update the minimal amount
        if subset_sum < minimal_amount:
            minimal_amount = subset_sum

    # Return the minimal amount
    return minimal_amount
