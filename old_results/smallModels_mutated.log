Code  :
def check_item(x):
    """
    Check if the given value x is a perfect cube of some whole number.

    Args:
    x (int): The value to check.

    Returns:
    bool: True if x is a perfect cube, False otherwise.
    """
    # Handle negative numbers by converting them to positive since (-n)^3 = -n^3
    abs_x = abs(x)

    # Calculate the cube root of the absolute value of x
    cube_root = round(abs_x ** (1/3))

    # Check if the cube of the calculated cube root equals the original absolute value
    return cube_root ** 3 == abs_x
