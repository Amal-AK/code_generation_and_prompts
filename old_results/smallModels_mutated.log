Code  :
def assess_marks(marks):
    """ marks is a sequence composed of "<" and ">".
    Indicate True when each start mark is paired with a corresponding end mark.

    >>> assess_marks("<")
    False
    >>> assess_marks("<>")
    True
    >>> assess_marks("<<><>>")
    True
    >>> assess_marks("><<>")
    False
    """
    stack = []
    for mark in marks:
        if mark == "<":
            stack.append(mark)
        elif mark == ">":
            if not stack or stack[-1]!= "<":
                return False
            stack.pop()
    return not stack
