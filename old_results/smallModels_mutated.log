    """You are given a string. Your task is to identify a nearby vowel that occurs between
    two non-vowel characters when examined from the right end of the string (case is preserved).
    
    Vowels at the beginning and end are not considered. Return an empty string if you don't
    find any vowel that fits the above condition. 

    You can assume that the input contains only letters from the English alphabet.

    Example:
    locate_near_vowel("yogurt") ==> "u"
    locate_near_vowel("FULL") ==> "U"
    locate_near_vowel("quick") ==> ""
    locate_near_vowel("ab") ==> ""
    """
Code  :
import re

def locate_near_vowel(item):
    vowels = ["a", "e", "i", "o", "u"]
    pattern = r"[^{0}]*({0})[^{0}]*".format("".join(vowels))
    match = re.search(pattern, item)
    if match:
        return match.group(1)
    else:
        return ""
