def tally(inp):
    """Given some input text made of space-separated tokens, produce a mapping of the symbol(s)
    that appear most frequently along with their counts. If multiple items share the top
    frequency, include all of them.
    
    Example:
    tally('a b c') == {'a': 1, 'b': 1, 'c': 1}
    tally('a b b a') == {'a': 2, 'b': 2}
    tally('a b c a b') == {'a': 2, 'b': 2}
    tally('b b b b a') == {'b': 4}
    tally('') == {}

    """

Code  :
from collections import Counter

def tally(inp):
    """Given some input text made of space-separated tokens, produce a mapping of the symbol(s)
    that appear most frequently along with their counts. If multiple items share the top
    frequency, include all of them.

    Example:
    tally('a b c') == {'a': 1, 'b': 1, 'c': 1}
    tally('a b b a') == {'a': 2, 'b': 2}
    tally('a b c a b') == {'a': 2, 'b': 2}
    tally('b b b b a') == {'b': 4}
    tally('') == {}
    """
    if not inp:
        return {}

    token_counts = Counter(inp.split())
    max_count = max(token_counts.values(), default=0)
    return {token: count for token, count in token_counts.items() if count == max_count}
