    """Provide a routine that accepts a non-negative quantity and yields a collection of the integers
    that are prime and smaller than that quantity.
    for example:
    tally_up_to(5) => [2,3]
    tally_up_to(11) => [2,3,5,7]
    tally_up_to(0) => []
    tally_up_to(20) => [2,3,5,7,11,13,17,19]
    tally_up_to(1) => []
    tally_up_to(18) => [2,3,5,7,11,13,17]
    """
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def tally_up_to(limit):
    return [i for i in range(2, limit) if is_prime(i)]
