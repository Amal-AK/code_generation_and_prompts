    For example:
    shift([1, 2, 3, 4], [1, 2, 3, 4]) => "YES"
    shift([1, 2, 3, 4], [1, 5, 3, 4]) => "NO"
    It's assumed the inputs won't be empty.
    """
Code  :
def shift(a, b):
    # Count the number of odd elements in the first list
    odd_count_a = sum(1 for x in a if x % 2!= 0)

    # Count the number of even elements in the second list
    even_count_b = sum(1 for x in b if x % 2 == 0)

    # If there are enough even elements in the second list to replace all odd elements in the first list, return "YES"
    if odd_count_a <= even_count_b:
        return "YES"
    else:
        return "NO"
