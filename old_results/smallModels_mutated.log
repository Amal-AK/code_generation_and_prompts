def assess(seq):
    '''
    Write a routine that accepts a sequence made up of bracket characters.
    The routine should indicate True exactly when there exists a subsequence of those brackets
    that forms a properly paired arrangement and where at least one element of that subsequence
    is nested within another.

    assess('[[]]') ➞ True
    assess('[]]]]]]][[[[[]') ➞ False
    assess('[][]') ➞ False
    assess('[]') ➞ False
    assess('[[][]]') ➞ True
    assess('[[]][[') ➞ True
    '''
Code  :
def assess(seq):
    stack = []
    nested = False
    for bracket in seq:
        if bracket == '[':
            stack.append(bracket)
        elif bracket == ']':
            if not stack:
                return False
            stack.pop()
            if stack and stack[-1] == '[':
                nested = True
    return nested and not stack
