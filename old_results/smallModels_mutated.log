def transform(items):
    """
    Given a collection of numbers, loosely order the elements that fall within the 1 to 9 range,
    flip the resulting list, and then swap each value for its corresponding word from
    "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine".

    For example:
      arr = [2, 1, 1, 4, 5, 8, 2, 3]   
            -> sort arr -> [1, 1, 2, 2, 3, 4, 5, 8] 
            -> reverse arr -> [8, 5, 4, 3, 2, 2, 1, 1]
      return ["Eight", "Five", "Four", "Three", "Two", "Two", "One", "One"]
    
      If the array is empty, return an empty array:
      arr = []
      return []
    
      If the array has any strange number ignore it:
      arr = [1, -1 , 55] 
            -> sort arr -> [-1, 1, 55]
            -> reverse arr -> [55, 1, -1]
      return = ['One']
    """
Code  :
def transform(items):
    # Define the mapping from numbers to words
    num_to_word = {
        1: "One",
        2: "Two",
        3: "Three",
        4: "Four",
        5: "Five",
        6: "Six",
        7: "Seven",
        8: "Eight",
        9: "Nine"
    }

    # Filter out numbers not in the 1-9 range
    filtered_items = [item for item in items if 1 <= item <= 9]

    # Sort the filtered items
    sorted_items = sorted(filtered_items)

    # Reverse the sorted list
    reversed_items = sorted_items[::-1]

    # Convert numbers to words
    result = [num_to_word[item] for item in reversed_items]

    return result
