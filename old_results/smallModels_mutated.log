Code  :
def items(val):
    """Given a positive number val, return an overall multiplicative result of the odd parts.
    Produce 0 if none of the figures are odd.
    For example:
    items(1)  == 1
    items(4)  == 0
    items(235) == 15
    """
    result = 1
    has_odd = False

    while val > 0:
        digit = val % 10
        if digit % 2!= 0:
            result *= digit
            has_odd = True
        val //= 10

    return result if has_odd else 0
