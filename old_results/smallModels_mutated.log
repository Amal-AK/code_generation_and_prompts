    looks_like_combination(8) == True
    '''

Code  :
import math

def looks_like_combination(val):
    if val < 0 or val % 2!= 0:
        return False
    root = math.sqrt(val)
    if root!= int(root):
        return False
    num = int(root)
    return num % 2 == 0 and num // 2 >= 2
