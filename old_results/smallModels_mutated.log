def rough_mean(a, b):
    '''You are given two values a and b, and your task is to get the
    average of the numbers from a through b (including a and b). 
    Round off the result to the nearest integer and convert that to binary.
    If the first is larger than the second, return -1.
    Example:
    rough_mean(1, 5) => "0b11"
    rough_mean(7, 5) => -1
    rough_mean(10, 20) => "0b1111"
    rough_mean(20, 33) => "0b11010"
    '''
Code  :
def rough_mean(a, b):
    if a > b:
        return -1
    total = sum(range(a, b + 1))
    count = b - a + 1
    average = round(total / count)
    return bin(average)

