from typing import List

def string_xor(a: str, b: str) -> str:
    # Convert the strings to lists of characters
    a_list = list(a)
    b_list = list(b)

    # Perform XOR operation on the lists
    xor_list = [str(int(a) ^ int(b)) for a, b in zip(a_list, b_list)]

    # Convert the list back to a string
    xor_str = ''.join(xor_list)

    return xor_str
