def Pick_Strong(target_label, candidates):
    """You will be provided with a label for an entity and a collection of add-ons.
    The add-ons are meant to be used to bring in extra components to that entity. The
    'strength' of an add-on is based on the counts of uppercase versus lowercase
    characters in the add-on's label: let CAP be the count of uppercase characters,
    and SM be the count of lowercase characters; the strength is CAP - SM.
    You should pick the strongest add-on and return a string in this
    form: EntityLabel.AddonLabel.
    If two or more add-ons share the same strength, pick the one that appears
    earlier in the collection.
    For example, if you are given "Slices" as the entity and a collection of the
    add-ons: ['SErviNGSliCes', 'Cheese', 'StuFfed'] then you would
    return 'Slices.SErviNGSliCes' since 'SErviNGSliCes' is the strongest add-on
    (its strength is -1).
    Example:
    for Pick_Strong('my_class', ['AA', 'Be', 'CC']) == 'my_class.AA'
    """
Code  :
def Pick_Strong(target_label, candidates):
    def calculate_strength(label):
        cap = sum(1 for char in label if char.isupper())
        sm = sum(1 for char in label if char.islower())
        return cap - sm

    strongest_addon = max(candidates, key=calculate_strength)
    return f"{target_label}.{strongest_addon}"
