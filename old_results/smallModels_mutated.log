Code  :
from math import sqrt

def is_prime(n):
    if n <= 1:
        return False
    for i in range(2, int(sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True

def fibonacci_generator():
    a, b = 0, 1
    while True:
        yield b
        a, b = b, a + b

def notable_item(idx):
    fib_gen = fibonacci_generator()
    count = 0
    while True:
        fib_num = next(fib_gen)
        if is_prime(fib_num):
            count += 1
            if count == idx:
                return fib_num

