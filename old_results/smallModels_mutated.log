def change_base(x: int, base: int)
  """Change numerial base of input number x to base.
  retrun string representation after the conversion.
  base numbers are less than 10.
    >>> change_base(8, 3)
    '22'
    >>> change_base(8, 2)
    '1000'
    >>> change_base(7, 2)
    '111'
  """

Code  :
def change_base(x: int, base: int) -> str:
    if base < 2 or base > 9:
        raise ValueError("Base must be between 2 and 9 (inclusive).")

    if x == 0:
        return "0"

    digits = []
    while x:
        digits.append(int(x % base))
        x //= base

    # The digits are in reverse order, so we need to reverse them before joining
    digits.reverse()
    return ''.join(map(str, digits))

