def looseFilter(vals):
    """Create a routine that accepts a collection of values and yields how many
    entries are above 10 and whose leading and trailing digits are odd (1, 3, 5, 7, 9).
    For example:
    looseFilter([15, -73, 14, -15]) => 1 
    looseFilter([33, -2, -3, 45, 21, 109]) => 2
    """
Code  :
def looseFilter(vals):
    def is_odd(n):
        return n % 2!= 0

    def has_odd_leading_and_trailing_digits(n):
        str_n = str(n)
        return is_odd(int(str_n[0])) and is_odd(int(str_n[-1]))

    count = 0
    for val in vals:
        if val > 10 and has_odd_leading_and_trailing_digits(val):
            count += 1
    return count
