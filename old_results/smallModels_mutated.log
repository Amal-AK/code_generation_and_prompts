    anti_shuffle('Hi') returns 'Hi'
    anti_shuffle('hello') returns 'ehllo'
    anti_shuffle('Hello World!!!') returns 'Hello !!!Wdlor'
    """
Code  :
def anti_shuffle(s):
    words = s.split(' ')
    result = ''
    for word in words:
        if word.isalpha():
            result += ''.join(sorted(word)) +''
        else:
            result += ''.join(sorted(word, key=lambda x: (not x.isalpha(), x))) +''
    return result.strip()
