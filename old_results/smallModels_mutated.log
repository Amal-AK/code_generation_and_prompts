def strange_sort_list(items):
    '''
    Given a collection of values, produce them in a somewhat odd arrangement.
    This kind of ordering is when you begin with the smallest element,
    then the largest among the remaining elements, then the smallest again, and so on.

    Examples:
    strange_sort_list([1, 2, 3, 4]) == [1, 4, 2, 3]
    strange_sort_list([5, 5, 5, 5]) == [5, 5, 5, 5]
    strange_sort_list([]) == []
    '''
Code  :
import itertools

def strange_sort_list(items):
    # Sort the list in descending order
    sorted_items = sorted(items, reverse=True)

    # Group the sorted items into groups of 2
    grouped_items = itertools.zip_longest(*[iter(sorted_items)]*2, fillvalue=None)

    # Flatten the grouped items into a single list
    flattened_items = [item for sublist in grouped_items for item in sublist]

    # Return the flattened list
    return flattened_items
