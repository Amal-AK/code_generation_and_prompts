def alter_positions(seq):
    """This routine accepts a sequence seq and returns a sequence seq' such that
    seq' mostly matches seq at the positions that aren't on every third step, while the entries at positions that are on every third step are the corresponding entries from seq, but arranged in sorted order.
    >>> alter_positions([1, 2, 3])
    [1, 2, 3]
    >>> alter_positions([5, 6, 3, 4, 8, 9, 2])
    [2, 6, 3, 4, 8, 9, 5]
    """
Code  :
def alter_positions(seq):
    # Extract elements at positions that are multiples of three (0-based index)
    third_elements = [seq[i] for i in range(2, len(seq), 3)]

    # Sort these extracted elements
    third_elements.sort()

    # Create a new list to store the result
    result = seq[:]

    # Replace the elements at positions that are multiples of three with the sorted ones
    j = 0
    for i in range(2, len(result), 3):
        result[i] = third_elements[j]
        j += 1

    return result
