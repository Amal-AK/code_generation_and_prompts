def seems_ordered(seq):
    '''
    Given a collection of items, indicate whether they appear
    to be in an ordered arrangement going up. If there are too many
    repeats of the same element, return False. Assume no negative
    values and only whole numbers.

    Examples
    seems_ordered([5]) ➞ True
    seems_ordered([1, 2, 3, 4, 5]) ➞ True
    seems_ordered([1, 3, 2, 4, 5]) ➞ False
    seems_ordered([1, 2, 3, 4, 5, 6]) ➞ True
    seems_ordered([1, 2, 3, 4, 5, 6, 7]) ➞ True
    seems_ordered([1, 3, 2, 4, 5, 6, 7]) ➞ False
    seems_ordered([1, 2, 2, 3, 3, 4]) ➞ True
    seems_ordered([1, 2, 2, 2, 3, 4]) ➞ False
    '''
Code  :
def seems_ordered(seq):
    if not seq:
        return True

    prev = seq[0]
    repeat_count = 1

    for item in seq[1:]:
        if item == prev:
            repeat_count += 1
            if repeat_count > 1:
                return False
        else:
            prev = item
            repeat_count = 1

    return True
