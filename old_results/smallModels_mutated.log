def tweak_gaps(content):
    """
    Given an input sequence content, turn spacing characters into underscores, 
    and if the input contains runs of more than 2 consecutive spacing, 
    then fold those runs into a single dash 
    
    tweak_gaps("Example") == "Example"
    tweak_gaps("Example 1") == "Example_1"
    tweak_gaps(" Example 2") == "_Example_2"
    tweak_gaps(" Example   3") == "_Example-3"
    """
Code  :
import re

def tweak_gaps(content):
    # Replace multiple spaces with a single dash
    content = re.sub(r' {2,}', '-', content)
    # Replace single spaces with underscores
    content = content.replace(' ', '_')
    # Replace multiple underscores with a single underscore
    content = re.sub(r'_+', '_', content)
    # If the first character is a dash, remove it
    if content[0] == '-':
        content = content[1:]
    # If the last character is a dash, remove it
    if content[-1] == '-':
        content = content[:-1]
    return content
