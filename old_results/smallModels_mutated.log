def get_amount(source, piece):
    """ Figure out roughly how often a certain piece can be found in a larger body of content. Include overlapping instances.
    >>> get_amount('', 'a')
    0
    >>> get_amount('aaa', 'a')
    3
    >>> get_amount('aaaa', 'aa')
    3
    """
Code  :
def get_amount(source, piece):
    count = start = 0
    while start < len(source):
        start = source.find(piece, start) + 1
        if start > 0:
            count += 1
    return count
