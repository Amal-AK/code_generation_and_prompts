    Examples:
    >>> process('test')
    'TGST'
    >>> process('This is a message')
    'tHKS KS C MGSSCGG'
    """
Code  :
import string

def process(content):
    result = ''
    for char in content:
        if char in string.ascii_letters:
            if char.islower():
                result += string.ascii_letters[string.ascii_letters.index(char) + 2]
            else:
                result += string.ascii_letters[string.ascii_letters.index(char) - 2]
        else:
            result += char
    return result
