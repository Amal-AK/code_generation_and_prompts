def how_many_times(strng: str, substring: str) -> int:
    """
    Return the number of times the substring can be found in the original string.
    Count overlapping cases.
    """
    count = 0
    for i in range(len(strng) - len(substring) + 1):
        if strng[i:i+len(substring)] == substring:
            count += 1
    return count
