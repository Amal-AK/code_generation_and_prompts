def factorial(num):
    """Helper function to calculate the factorial of a number."""
    if num == 0 or num == 1:
        return 1
    else:
        result = 1
        for i in range(2, num + 1):
            result *= i
        return result

def special_factorial(n):
    """Calculate the Brazilian factorial of a given number."""
    result = 1
    for i in range(1, n + 1):
        result *= factorial(i)
    return result

