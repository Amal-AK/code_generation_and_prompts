def examine_fragments(parts):
    '''
    You are given a pair of strings, each made up only of opening '(' or closing ')' symbols.
    Your task is to check whether it's possible to join the two pieces in some order so the resulting text will be considered good.
    A string is considered good when its parentheses are properly paired. For example: '(())()' is good, while '())' is not.
    Return 'Yes' if there's a way to arrange them into a good string, and return 'No' otherwise.

    Examples:
    examine_fragments(['()(', ')']) == 'Yes'
    examine_fragments([')', ')']) == 'No'
    '''
Code  :
def examine_fragments(parts):
    # Initialize a stack to keep track of the parentheses
    stack = []

    # Iterate over each part
    for part in parts:
        # Iterate over each character in the part
        for char in part:
            # If the character is an opening parenthesis, push it to the stack
            if char == '(':
                stack.append(char)
            # If the character is a closing parenthesis
            elif char == ')':
                # If the stack is empty, return 'No' because there is no matching opening parenthesis
                if not stack:
                    return 'No'
                # Otherwise, pop the last element from the stack
                stack.pop()

    # If the stack is empty, return 'Yes' because all parentheses are properly paired
    if not stack:
        return 'Yes'
    # If the stack is not empty, return 'No' because there are unpaired opening parentheses
    else:
        return 'No'
