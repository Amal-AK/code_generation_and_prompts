    """
Code  :
import math

def decompose(value):
    factors = []
    for i in range(1, int(math.sqrt(value)) + 1):
        if value % i == 0:
            factors.append(i)
            if value // i!= i:
                factors.append(value // i)
    return sorted(factors, reverse=True)
