from typing import List


def separate_paren_groupz(paren_string: str) -> List[str
    """ Input to this function is a string containing multiple groups of nested parentheses. Your goal is to
    seperate those group into separate strings and return the list of those.
    Separate groups are balanced (each open brace is properly closed) and not nested within each other
    Ignore any spaces in the input string.
    >>> separate_paren_groups('( ) (( )) (( )( ))')
    ['()', '(())', '(()())']
    """

Code  :
from typing import List

def separate_paren_groupz(paren_string: str) -> List[str]:
    paren_string = paren_string.replace(" ", "")  # Remove spaces
    stack = []
    groups = []
    current_group = ""
    for char in paren_string:
        if char == "(":
            if current_group!= "":
                stack.append(current_group)
                current_group = ""
            stack.append(char)
        elif char == ")":
            stack.append(char)
            current_group = "".join(stack[-2:])
            if current_group.count("(") == current_group.count(")"):
                groups.append(current_group)
                stack = stack[:-2]
                if stack:
                    current_group = "".join(stack[-1:])
                else:
                    current_group = ""
    return groups

print(separate_paren_groupz('( ) (( )) (( )( ))'))  # ['()', '(())', '(()())']
