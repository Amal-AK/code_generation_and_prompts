    exchange([1, 2, 3, 4], [1, 2, 3, 4]) => "YES"
    exchange([1, 2, 3, 4], [1, 5, 3, 4]) => "NO"
    It is assumed that the input lists will be non-empty.
    """
Code  :
def exchange(lst1, lst2):
    # Check if all elements in lst1 are even
    if all(num % 2 == 0 for num in lst1):
        return "YES"

    # Check if all elements in lst2 are odd
    if all(num % 2!= 0 for num in lst2):
        return "YES"

    # Check if there is at least one element in common between lst1 and lst2
    if any(num in lst2 for num in lst1):
        return "YES"

    return "NO"
