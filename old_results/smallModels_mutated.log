import math

def handle(inp):
    # Convert the input to binary
    binary = bin(inp)[2:]

    # Calculate the sum of the digits
    sum_of_digits = 0
    for digit in binary:
        sum_of_digits += int(digit)

    # Return the binary representation of the sum
    return bin(sum_of_digits)[2:]
