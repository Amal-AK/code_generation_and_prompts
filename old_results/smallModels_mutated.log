def starts_one_ends(n):
    """
    Given an integer n, return the count of the numbers of positive integers that start or end with 1.
    """
    if n == 0:
        return 0

    # There are 9 possible digits for each position except the first and last
    # The first and last positions can be either 1 or any other digit (0-9)
    # However, we need to subtract the cases where both the first and last positions are 1 to avoid double-counting
    count = 2 * (10 ** (n - 1)) - (10 ** (n - 2))

    return count
