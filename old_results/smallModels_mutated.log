    """Take a numeric input and provide a two-item result that indicates how many digits of each parity appear.

     Example:
        parity_tally(-12) ==> (1, 1)
        parity_tally(123) ==> (1, 2)
    """

Code  :
import math

def parity_tally(item):
    if not isinstance(item, (int, float)):
        raise ValueError("Input must be a number")

    str_item = str(abs(item))
    odd_count = 0
    even_count = 0

    for digit in str_item:
        if int(digit) % 2 == 0:
            even_count += 1
        else:
            odd_count += 1

    return (odd_count, even_count)
