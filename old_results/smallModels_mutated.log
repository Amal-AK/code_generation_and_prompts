def near_whole(item):
    """
    Create a routine that accepts an input (text) indicating a quantity
    and yields the nearest whole number to it. If the value is equally
    close to two whole numbers, bias the result away from zero.

    Examples
    >>> near_whole("10")
    10
    >>> near_whole("15.3")
    15

    Note:
    Rounding away from zero means that if the given quantity is equally
    close to two whole numbers, the one to return is the one farther
    from zero. For example near_whole("14.5") should return 15 and
    near_whole("-14.5") should return -15.
    """
    # Convert the input string to a float
    num = float(item)

    # Check if the number is halfway between two integers
    if abs(num - round(num)) == 0.5:
        if num > 0:
            return int(num) + 1
        else:
            return int(num) - 1
    else:
        return round(num)

