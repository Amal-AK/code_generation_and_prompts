Code  :
def correct_bracketing(brackets: str):
    stack = []
    for bracket in brackets:
        if bracket in '<[':
            stack.append(bracket)
        elif bracket in '>]':
            if not stack:
                return False
            if bracket == '>' and stack[-1] == '<':
                stack.pop()
            elif bracket == ']' and stack[-1] == '[':
                stack.pop()
            else:
                return False
    return not stack
