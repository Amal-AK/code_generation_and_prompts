import fractions

def assess(a, b):
    # Convert the string fractions to fractions
    a = fractions.Fraction(a)
    b = fractions.Fraction(b)

    # Multiply the fractions
    product = a * b

    # Check if the product is a whole number
    if product.denominator == 1:
        return True
    else:
        return False
