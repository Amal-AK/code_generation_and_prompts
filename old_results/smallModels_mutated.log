def handle(inp):
    # Convert the number to its binary representation and remove the '0b' prefix
    binary_representation = bin(inp)[2:]

    # Calculate the sum of the digits in the binary representation
    digit_sum = sum(int(digit) for digit in binary_representation)

    # Convert the sum back to binary and return it as a string
    return bin(digit_sum)[2:]
