    The routine should yield an empty tuple if thing1 or thing2 are not recognized names.
    Examples
    locate_between("Jupiter", "Neptune") ==> ("Saturn", "Uranus")
    locate_between("Earth", "Mercury") ==> ("Venus")
    locate_between("Mercury", "Uranus") ==> ("Venus", "Earth", "Mars", "Jupiter", "Saturn")
    '''
Code  :
import re

def locate_between(thing1, thing2):
    planets = ("Mercury", "Venus", "Earth", "Mars", "Jupiter", "Saturn", "Uranus", "Neptune")
    if thing1 not in planets or thing2 not in planets:
        return ()
    idx1 = planets.index(thing1)
    idx2 = planets.index(thing2)
    if idx1 > idx2:
        return ()
    return tuple(planets[idx1+1:idx2+1])
