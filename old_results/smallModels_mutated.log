def process_items(items):
    """This routine accepts a collection items and returns an output of similar shape such that
    the output keeps entries at the other positions unchanged, while the entries at a certain set
    of positions are reordered.
    >>> process_items([1, 2, 3])
    [1, 2, 3]
    >>> process_items([5, 6, 3, 4])
    [3, 6, 5, 4]
