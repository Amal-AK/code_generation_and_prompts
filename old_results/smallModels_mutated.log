Code  :
def cycpattern_check(a, b):
    """
    Check if the second word or any of its rotations is a substring in the first word.

    :param a: The first word (str)
    :param b: The second word (str)
    :return: True if any rotation of 'b' is a substring of 'a', otherwise False (bool)
    """
    # Concatenate 'b' with itself to handle rotations
    double_b = b + b

    # Check if 'a' contains any rotation of 'b'
    for i in range(len(b)):
        rotated_b = double_b[i:i+len(b)]
        if rotated_b in a:
            return True

    return False

