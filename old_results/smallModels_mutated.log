import math

def largest_prime_factor(n):
    """Return the largest prime factor of n. Assume n > 1 and is not a prime."""
    # Start from the smallest possible prime number 2
    i = 2
    while i * i <= n:
        if n % i:
            i += 1
        else:
            n //= i
    return n
