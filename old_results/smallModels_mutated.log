      If the array is empty, return an empty array:
      arr = []
      return []
    
      If the array has any strange number ignore it:
      arr = [1, -1 , 55] 
            -> sort arr -> [-1, 1, 55]
            -> reverse arr -> [55, 1, -1]
      return = ['One']
    ""
Code  :
import re

def by_lenght(arr):
    if not arr:
        return []

    sorted_arr = sorted(arr)
    reversed_arr = sorted_arr[::-1]

    names = []
    for num in reversed_arr:
        if 1 <= num <= 9:
            names.append(str(num))
        else:
            names.append(str(num)[0])

    return names
