PromptUsed:
def arrange_items(items):
    """ Input is a space-separated string of item words that stand for digits.
    These correspond broadly to the words for the digits zero through nine.
    Typical choices include 'zero', 'one', 'two', 'three', 'four', 'five', 'six', 'seven', 'eight' and 'nine'.
    Return the string with the pieces ordered from smaller to larger
    >>> arrange_items('three one five')
    'one three five'
    """
Code  :
def arrange_items(items):
    # Define a dictionary to map digit words to their numeric values
    digit_map = {
        'zero': 0,
        'one': 1,
        'two': 2,
        'three': 3,
        'four': 4,
        'five': 5,
       'six': 6,
       'seven': 7,
        'eight': 8,
        'nine': 9
    }

    # Split the input string into individual items
    item_list = items.split()

    # Convert each item word to its corresponding numeric value
    numeric_values = [digit_map[item] for item in item_list]

    # Sort the numeric values
    sorted_numeric_values = sorted(numeric_values)

    # Convert the sorted numeric values back to item words
    sorted_item_words = [list(digit_map.keys())[list(digit_map.values()).index(value)] for value in sorted_numeric_values]

    # Join the sorted item words into a single string
    result =''.join(sorted_item_words)

    return result
