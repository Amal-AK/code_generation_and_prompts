def file_name_chek(file_name):
    import re

    # Regular expression pattern for validating the file name
    pattern = r'^[a-zA-Z][a-zA-Z0-9]{0,}(\d{0,3})\.(txt|exe|dll)$'

    # Check if the file name matches the pattern
    if re.match(pattern, file_name):
        return 'Yes'
    else:
        return 'No'

