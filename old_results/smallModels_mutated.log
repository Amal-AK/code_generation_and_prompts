    Exponentiation ( ** ) 

    Example:
    operator['+', '*', '-']
    array = [2, 3, 4, 5]
    result = 2 + 3 * 4 - 5
    => result = 9

    Note:
        Operand is a list of of non-negative integers.
        Operator list has at least one operator, and operand list has at least two operands.

    """

Code  :
import operator

def do_algebra(operators, operands):
    # Define the operators as per the operator module
    op_dict = {
        '+': operator.add,
        '-': operator.sub,
        '*': operator.mul,
        '//': operator.floordiv,
        '**': operator.pow
    }

    # Initialize the result with the first operand
    result = operands[0]

    # Iterate over the operators and operands
    for op, num in zip(operators, operands[1:]):
        # Apply the operator to the result and the next operand
        result = op_dict[op](result, num)

    return result
