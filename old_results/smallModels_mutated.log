Code  :
def compute_minimal_amount(items):
    """
    Given a collection of values items, determine the smallest total of any non-empty portion of items.
    Example
    compute_minimal_amount([2, 3, 4, 1, 2, 4]) == 1
    compute_minimal_amount([-1, -2, -3]) == -6
    """
    if not items:
        return 0

    min_sum = float('inf')
    current_sum = 0

    for item in items:
        current_sum += item
        if current_sum < min_sum:
            min_sum = current_sum
        if current_sum > 0:
            current_sum = 0

    return min_sum
