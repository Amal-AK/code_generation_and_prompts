Code  :
import math

def is_prime(n: int) -> bool:
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def fibonacci(n: int) -> int:
    if n <= 1:
        return n
    a, b = 0, 1
    for _ in range(n - 1):
        a, b = b, a + b
    return b

def prime_fib(n: int) -> int:
    i = 1
    while True:
        fib_num = fibonacci(i)
        if is_prime(fib_num):
            n -= 1
            if n == 0:
                return fib_num
        i += 1
