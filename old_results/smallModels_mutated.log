Code  :
import math

def poly(xs: list, x: float) -> float:
    """
    Evaluates polynomial with coefficients xs at point x.
    return xs[0] + xs[1] * x + xs[1] * x^2 +.... xs[n] * x^n
    """
    return sum([coeff * math.pow(x, i) for i, coeff in enumerate(xs)])


def find_zero(xs: list) -> float:
    """
    Finds the zero point of a polynomial with coefficients xs.
    The function only takes list xs having even number of coefficients
    and largest non zero coefficient as it guarantees
    a solution.
    """
    if len(xs) % 2!= 0:
        raise ValueError("xs must have even number of coefficients")
    if max(xs) == 0:
        raise ValueError("xs must have non-zero coefficients")
    x0 = -1
    while True:
        x1 = x0 - poly(xs, x0) / poly(xs, x0)
        if abs(x1 - x0) < 1e-6:
            return x1
        x0 = x1
