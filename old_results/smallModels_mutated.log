Code  :
import sys

def minSubArraySum(nums):
    if not nums:
        return 0
    min_sum = sys.maxsize
    for i in range(len(nums)):
        curr_sum = 0
        for j in range(i, len(nums)):
            curr_sum += nums[j]
            if curr_sum < min_sum:
                min_sum = curr_sum
    return min_sum
