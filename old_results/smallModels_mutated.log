    next_smallest([5, 1, 4, 3, 2]) == 2
    next_smallest([]) == None
    next_smallest([1, 1]) == None
    """
Code  :
def next_smallest(lst):
    if len(lst) < 2:
        return None
    sorted_lst = sorted(lst)
    for i in range(len(lst)):
        if sorted_lst[i]!= lst[i]:
            return sorted_lst[i]
    return None
