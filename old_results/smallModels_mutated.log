def smallest_change(arr):
    """
    Given an array arr of integers, find the minimum number of elements that
    need to be changed to make the array palindromic. A palindromic array is an array that
    is read the same backwards and forwards.

    For example:
    smallest_change([1,2,3,5,4,7,9,6]) == 4
    smallest_change([1, 2, 3, 4, 3, 2, 2]) == 1
    smallest_change([1, 2, 3, 2, 1]) == 0
    """
    # Initialize the count of changes to 0
    changes = 0

    # Initialize two pointers, one at the start of the array and one at the end
    start = 0
    end = len(arr) - 1

    # While the start pointer is less than or equal to the end pointer
    while start <= end:
        # If the elements at the start and end pointers are the same, move the pointers inward
        if arr[start] == arr[end]:
            start += 1
            end -= 1
        # If the elements are different, increment the count of changes and replace the element at the end pointer with the element at the start pointer
        else:
            changes += 1
            arr[end] = arr[start]
            start += 1
            end -= 1

    # Return the count of changes
    return changes
