    is_nested('[[][]]') ➞ True
    is_nested('[[]][[') ➞ True
    '''
Code  :
def is_nested(string):
    stack = []
    for char in string:
        if char == '[':
            stack.append(char)
        elif char == ']':
            if not stack:
                return False
            stack.pop()
    return not stack
