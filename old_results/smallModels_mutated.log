def examine_fragments(parts):
    '''
    You are given a pair of strings, each made up only of opening '(' or closing ')' symbols.
    Your task is to check whether it's possible to join the two pieces in some order so the resulting text will be considered good.
    A string is considered good when its parentheses are properly paired. For example: '(())()' is good, while '())' is not.
    Return 'Yes' if there's a way to arrange them into a good string, and return 'No' otherwise.

    Examples:
    examine_fragments(['()(', ')']) == 'Yes'
    examine_fragments([')', ')']) == 'No'
    '''
Code  :
def examine_fragments(parts):
    """
    Check if it's possible to concatenate two strings containing only '(' and ')' in some order
    to form a balanced parentheses string.

    :param parts: List of two strings consisting of '(' and ')'.
    :return: 'Yes' if a balanced string can be formed, 'No' otherwise.
    """

    # Helper function to check if a string has balanced parentheses
    def is_balanced(s):
        balance = 0
        for char in s:
            if char == '(':
                balance += 1
            else:
                balance -= 1
            if balance < 0:
                return False
        return balance == 0

    # Try both possible concatenations
    concat1 = parts[0] + parts[1]
    concat2 = parts[1] + parts[0]

    # Check if either concatenated string is balanced
    if is_balanced(concat1) or is_balanced(concat2):
        return 'Yes'
    else:
        return 'No'

# Example usage:
