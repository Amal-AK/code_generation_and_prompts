    0
    >>> how_many_times('aaa', 'a')
    3
    >>> how_many_times('aaaa', 'aa')
    3
"""

Code  :
def how_many_times(strng: str, substring: str) -> int:
    count = start = 0
    while start < len(strng):
        pos = strng.find(substring, start)
        if pos!= -1:
            start = pos + 1
            count += 1
        else:
            break
    return count
