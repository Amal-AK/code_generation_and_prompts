    """ The input to this routine is a piece of data composed of several groups of parentheses separated by whitespace.
    For each group, return an indication of the deepest nesting level present.
    E.g. (()()) has two levels while ((())) has three.

    >>> process_paren_groups('(()()) ((())) () ((())()())')
    [2, 3, 1, 3]
    """
Code  :
import re

def process_paren_groups(text):
    """
    The input to this routine is a piece of data composed of several groups of parentheses separated by whitespace.
    For each group, return an indication of the deepest nesting level present.
    E.g. (()()) has two levels while ((())) has three.
    """
    # Split the input text into individual groups of parentheses
    groups = re.split(r'\s+', text)

    # Initialize a list to store the results
    results = []

    # Iterate over each group and calculate the nesting level
    for group in groups:
        # Count the number of opening and closing parentheses
        opening = group.count('(')
        closing = group.count(')')

        # Calculate the nesting level
        level = opening - closing

        # Add the result to the list
        results.append(level)

    return results
