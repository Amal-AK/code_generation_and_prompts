def encode_cyclic(s: str) -> str:
    """
    Encodes the given string by cycling groups of characters.

    Args:
    s (str): The input string to be encoded.

    Returns:
    str: The encoded string.
    """
    # Split the string into groups of up to 3 characters
    groups = [s[i:i+3] for i in range(0, len(s), 3)]
    # Cycle the elements in each group
    cycled_groups = [(group[1:] + group[0]) if len(group) == 3 else group for group in groups]
    # Join the cycled groups back into a single string
    return ''.join(cycled_groups)
