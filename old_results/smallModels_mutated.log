    def total_chars(lst):
        return sum(len(s) for s in lst)

    # Calculate the total number of characters for both lists
    total_chars_lst1 = total_chars(lst1)
    total_chars_lst2 = total_chars(lst2)

    # Compare the totals and return the appropriate list
    if total_chars_lst1 <= total_chars_lst2:
        return lst1
    else:
        return lst2
