PromptUsed:
def extract_groups(paren_text):
    """ Input to this function is a string containing multiple clusters of nested parentheses. Your aim is to
    pull those clusters out into individual strings and return a list of them.
    Groups are well-formed (each opener is properly closed) and not embedded within one another.
    Treat whitespace as insignificant in the input.
    >>> extract_groups('( ) (( )) (( )( ))')
    ['()', '(())', '(()())']
    """
Code  :
def extract_groups(paren_text):
    paren_text = paren_text.replace(" ", "")  # Remove whitespace
    result = []
    stack = []
    current_group = []

    for char in paren_text:
        if char == '(':
            stack.append(char)
            current_group.append(char)
        elif char == ')':
            stack.pop()
            current_group.append(char)
            if not stack:  # If stack is empty, we've completed a group
                result.append(''.join(current_group))
                current_group = []  # Reset current_group for the next group

    return result
