             Constraints: 0 ≤ N ≤ 10000.
    Output
         a string of binary number
    \"\"\"
Code  :
def solve(N):
    if N < 0 or N > 10000:
        raise ValueError("N must be a positive integer between 0 and 10000")

    binary_string = bin(N)[2:]
    sum_of_digits = sum([int(digit) for digit in binary_string])

    return str(sum_of_digits)
