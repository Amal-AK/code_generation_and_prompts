from math import factorial

def sum_of_numbers(n):
    return sum(range(1, n + 1))

def f(n):
    result = []
    for i in range(n):
        if i % 2 == 0:
            result.append(factorial(i))
        else:
            result.append(sum_of_numbers(i))
    return result
