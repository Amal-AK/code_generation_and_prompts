    * 0 <= want <= 1000
    * 0 <= left <= 1000

    Have fun :)
    """
Code  :
import math

def munch(count, want, left):
    total_consumed = count + math.min(want, left)
    remaining = left - math.min(want, left)
    return [total_consumed, remaining]
