import string

def encrypt(s):
    alphabet = string.ascii_lowercase
    rotated_alphabet = alphabet[1:] + alphabet[:1]
    encrypted_string = ''.join(rotated_alphabet[ord(c) - ord('a')] for c in s)
    return encrypted_string
