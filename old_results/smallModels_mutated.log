def find_groups(m):
    """
    You're given a positive whole number m. You're asked to assemble a list-like collection a of length m.
        For each i (1 ≤ i ≤ m), the element a[i] = i * i - i + 1.
        Produce how many three-element tuples (a[i], a[j], a[k]) from a with i < j < k,
    have a[i] + a[j] + a[k] that is divisible by 3.

    Example :
        Input: m = 5
        Output: 1
        Explanation: 
        a = [1, 3, 7, 13, 21]
        The only valid triple is (1, 7, 13).
    """
Code  :
import math

def find_groups(m):
    a = [i * i - i + 1 for i in range(1, m + 1)]
    count = 0
    for i in range(m - 2):
        for j in range(i + 1, m - 1):
            for k in range(j + 1, m):
                if a[i] + a[j] + a[k] % 3 == 0:
                    count += 1
    return count
