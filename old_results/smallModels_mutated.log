def collect_items(x, y):
    """
    Given two numbers x and y, provide the even numbers between them, in ascending order.

    For example:
    collect_items(2, 8) => [2, 4, 6, 8]
    collect_items(8, 2) => [2, 4, 6, 8]
    collect_items(10, 14) => []
    """
    # Ensure x is less than y for the range function
    start, end = sorted([x, y])

    # Generate the list of even numbers between x and y (inclusive)
    return [num for num in range(start, end + 1) if num % 2 == 0]

