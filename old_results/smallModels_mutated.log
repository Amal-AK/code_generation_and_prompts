def parity_tally(item):
    """Take a numeric input and provide a two-item result that indicates how many digits of each parity appear.

     Example:
        parity_tally(-12) ==> (1, 1)
        parity_tally(123) ==> (1, 2)
    """

Code  :
def parity_tally(item):
    # Convert the number to a string
    item_str = str(abs(item))

    # Initialize counters for even and odd digits
    even_count = 0
    odd_count = 0

    # Iterate over each character in the string
    for char in item_str:
        # If the character is an even number, increment the even counter
        if int(char) % 2 == 0:
            even_count += 1
        # Otherwise, increment the odd counter
        else:
            odd_count += 1

    # Return the counts as a tuple
    return (even_count, odd_count)
