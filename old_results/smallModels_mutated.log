Code  :
def probe_final_symbol(inp):
    # Check if the input string is empty or ends with a whitespace
    if not inp or inp.endswith(' '):
        return False

    # Split the input string into words
    words = inp.split()

    # Get the last word from the list
    last_word = words[-1]

    # Check if the last character of the last word is a letter
    if last_word.isalpha():
        return True

    return False
