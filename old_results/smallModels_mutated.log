Code  :
def circular_shift(x, shift):
    """Circular shift the digits of the integer x, shift the digits right by shift
    and return the result as a string.
    If shift > number of digits, return digits number."""
    str_x = str(x)
    length = len(str_x)

    # If shift is greater than or equal to the number of digits, return the original number as a string
    if shift >= length:
        return str_x

    # Perform the circular shift
    shift = shift % length  # In case shift is larger than the length
    shifted_str = str_x[-shift:] + str_x[:-shift]

    return shifted_str

# Test cases
