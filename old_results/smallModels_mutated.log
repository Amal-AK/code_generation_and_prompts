    >>> trend([1, 20, 4, 10])
    False
    >>> trend([4, 1, 0, -10])
    True
    """

Code  :
def trend(seq):
    """Return True if sequence items broadly move in one direction."""
    if not seq or len(seq) == 1:
        return False

    # Determine the initial direction (increasing or decreasing)
    increasing = seq[1] > seq[0]

    for i in range(1, len(seq)):
        if increasing and seq[i] < seq[i - 1]:
            return False
        elif not increasing and seq[i] > seq[i - 1]:
            return False

    return True
