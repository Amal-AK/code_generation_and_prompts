import heapq

def maximum(arr, k):
    """
    Given an array arr of integers and a positive integer k, return a list of length k with the maximum k numbers in arr.
    """
    if k > len(arr):
        raise ValueError("k cannot be greater than the length of the array")

    max_heap = []
    for i in range(k):
        heapq.heappush(max_heap, arr[i])

    for i in range(k, len(arr)):
        if arr[i] > max_heap[0]:
            heapq.heappop(max_heap)
            heapq.heappush(max_heap, arr[i])

    return list(reversed(max_heap))
