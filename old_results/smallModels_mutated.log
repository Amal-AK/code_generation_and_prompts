def find_max(words):
    """
    Find the word with the maximum number of unique characters.
    If there are multiple words with the same number of unique characters,
    return the one that comes first in lexicographical order.

    :param words: List of strings to be evaluated
    :return: The word with the maximum number of unique characters
    """
    # Helper function to count unique characters in a word
    def count_unique(word):
        return len(set(word))

    # Sort the words first by the number of unique characters (descending) and then lexicographically
    sorted_words = sorted(words, key=lambda x: (-count_unique(x), x))

    # Return the first word from the sorted list
    return sorted_words[0] if sorted_words else ""

