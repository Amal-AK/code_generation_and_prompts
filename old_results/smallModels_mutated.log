    items(1)  == 1
    items(4)  == 0
    items(235) == 15
    """

Code  :
def items(val):
    # Convert the number to a string to iterate over its digits
    val_str = str(val)
    # Initialize the result to 1
    result = 1
    # Iterate over the digits
    for digit in val_str:
        # Convert the digit back to an integer
        digit = int(digit)
        # If the digit is odd, multiply it to the result
        if digit % 2!= 0:
            result *= digit
    # Return the result
    return result
