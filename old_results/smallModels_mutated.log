def is_prime(num):
    """Helper function to determine if a number is prime."""
    if num <= 1:
        return False
    if num <= 3:
        return True
    if num % 2 == 0 or num % 3 == 0:
        return False
    i = 5
    while i * i <= num:
        if num % i == 0 or num % (i + 2) == 0:
            return False
        i += 6
    return True

def check_item(value):
    """Indicate whether a given value exhibits a basic numeric property often called 'prime'."""
    return is_prime(value)

