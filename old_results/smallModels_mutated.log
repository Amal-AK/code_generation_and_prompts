PromptUsed:
def get_max_triples(n):
    """
    You are given a positive integer n. You have to create an integer array a of length n.
        Return the number of triples (a[i], a[j], a[k]) of a where i < j < k, 
    and a[i] + a[j] + a[k] is a multiple of 3.

    Example :
        Input: n = 5
        Output: 1
        Explanation: 
        a = [1, 3, 7, 13, 21]
        The only valid triple is (1, 7, 13).
    """
Code  :
import math

def get_max_triples(n):
    # Initialize a list to store the multiples of 3
    multiples = []

    # Loop through the range of numbers from 1 to n
    for i in range(1, n + 1):
        # Check if the number is a multiple of 3
        if i % 3 == 0:
            # If it is, add it to the list of multiples
            multiples.append(i)

    # Initialize a variable to store the maximum number of triples
    max_triples = 0

    # Loop through the list of multiples
    for i in range(len(multiples)):
        # Get the current multiple
        current_multiple = multiples[i]

        # Loop through the remaining multiples
        for j in range(i + 1, len(multiples)):
            # Get the next multiple
            next_multiple = multiples[j]

            # Check if the sum of the two multiples is a multiple of 3
            if (current_multiple + next_multiple) % 3 == 0:
                # If it is, increment the maximum number of triples
                max_triples += 1

    # Return the maximum number of triples
    return max_triples
