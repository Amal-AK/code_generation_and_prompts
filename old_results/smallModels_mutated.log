    """
    Provide a routine that orders the supplied collection of numbers
    in a less rigid way based on the cumulative value of their digits.
    If multiple entries share a similar digit total,
    keep them in the order they appeared originally.

    For example:
    >>> arrange_by_score([1, 11, -1, -11, -12]) == [-1, -11, 1, -12, 11]
    >>> arrange_by_score([]) == []
    """
Code  :
import itertools

def arrange_by_score(items):
    # Calculate the cumulative digit sum for each item
    digit_sums = [sum(int(digit) for digit in str(item)) for item in items]

    # Sort the items based on their digit sums
    sorted_items = sorted(items, key=lambda item: digit_sums.index(item))

    # If there are any ties, keep the items in the original order
    return sorted_items if len(set(digit_sums)) == len(digit_sums) else items
