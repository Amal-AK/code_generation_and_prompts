def strange_sort_list(items):
    '''
    Given a collection of values, produce them in a somewhat odd arrangement.
    This kind of ordering is when you begin with the smallest element,
    then the largest among the remaining elements, then the smallest again, and so on.

    Examples:
    strange_sort_list([1, 2, 3, 4]) == [1, 4, 2, 3]
    strange_sort_list([5, 5, 5, 5]) == [5, 5, 5, 5]
    strange_sort_list([]) == []
    '''
Code  :
def strange_sort_list(items):
    sorted_items = sorted(items)
    result = []
    left = 0
    right = len(sorted_items) - 1
    while left <= right:
        if left == right:
            result.append(sorted_items[left])
        else:
            result.extend([sorted_items[left], sorted_items[right]])
        left += 1
        right -= 1
    return result
