    You'll be given a piece of text, and your task is to tally occurrences of boredom-like segments. A boredom is a sentence that begins with the word "I".
    Sentences are typically separated by punctuation such as '.', '?' or '!'.
   
    For example:
    >>> feel_uninterested("Hello world")
    0
    >>> feel_uninterested("The sky is blue. The sun is shining. I love this weather")
    1
    """
Code  :
def feel_uninterested(txt):
    import re

    # Split the text into sentences using regex to match '.', '?', or '!'
    sentences = re.split(r'[.?!]\s*', txt)

    # Count sentences that start with the word "I"
    boredom_count = sum(sentence.startswith('I') for sentence in sentences if sentence)

    return boredom_count
