Code  :
import re

def correct_bracketing(brackets: str) -> bool:
    """
    Check if the given string of "<" and ">" brackets is correctly bracketed.

    Args:
        brackets (str): A string of "<" and ">" characters.

    Returns:
        bool: True if the brackets are correctly bracketed, False otherwise.
    """
    # Check if the string contains an odd number of "<" characters
    if len(re.findall(r"<", brackets)) % 2 == 1:
        return False

    # Check if the string contains an odd number of ">" characters
    if len(re.findall(r">", brackets)) % 2 == 1:
        return False

    # Check if the string is balanced
    stack = []
    for char in brackets:
        if char == "<":
            stack.append(char)
        elif char == ">":
            if not stack or stack.pop()!= "<":
                return False

    return True
