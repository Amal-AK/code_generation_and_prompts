    item_allocation("0 apples and 1 oranges",3) -> 3 - 0 - 1 = 2
    item_allocation("2 apples and 3 oranges", 100) -> 100 - 2 - 3 = 95
    item_allocation("100 apples and 1 oranges",120) -> 120 - 100 - 1 = 19
