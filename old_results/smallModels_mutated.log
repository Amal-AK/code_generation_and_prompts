Code  :
def monotonic(l: list) -> bool:
    if len(l) < 2:
        return True
    else:
        diff = [l[i + 1] - l[i] for i in range(len(l) - 1)]
        return all(x >= 0 for x in diff) or all(x <= 0 for x in diff)
