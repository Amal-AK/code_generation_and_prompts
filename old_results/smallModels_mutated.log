def is_sorted(lst):
    if len(lst) <= 1:
        return True

    for i in range(len(lst) - 1):
        if lst[i] > lst[i + 1]:
            return False

    # Check for more than one duplicate of the same number
    for num in set(lst):
        if lst.count(num) > 2:
            return False

    return True
