import math

def arrange_items(vals):
    # Sort the values by the number of ones in their binary representation
    # in increasing order, and then by their usual numeric value if there are
    # multiple values with the same number of ones
    return sorted(vals, key=lambda x: (bin(x).count('1'), x))
