from math import sqrt

def is_prime(n):
    if n <= 1:
        return False
    if n <= 3:
        return True
    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def skjkasdkd(lst):
    largest_prime = 0
    for num in lst:
        if num > largest_prime and is_prime(num):
            largest_prime = num
    return sum(int(digit) for digit in str(largest_prime))

