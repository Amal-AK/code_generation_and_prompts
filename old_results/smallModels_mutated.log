def alter_positions(seq):
    """This routine accepts a sequence seq and returns a sequence seq' such that
    seq' mostly matches seq at the positions that aren't on every third step, while the entries at positions that are on every third step are the corresponding entries from seq, but arranged in sorted order.
    >>> alter_positions([1, 2, 3])
    [1, 2, 3]
    >>> alter_positions([5, 6, 3, 4, 8, 9, 2])
    [2, 6, 3, 4, 8, 9, 5]
    """
Code  :
import itertools

def alter_positions(seq):
    # zip() the sequence with an infinite iterator of range(len(seq))
    # to get the indices of every third step
    indices = zip(seq, itertools.count(1))
    # filter() out the indices that are not on every third step
    indices = filter(lambda x: x[1] % 3!= 0, indices)
    # sort() the remaining indices by their value
    indices = sorted(indices)
    # unzip() the sorted indices and use them to create a new sequence
    return [seq[i] for i, _ in indices]
