def compare_one(a, b):
    # Helper function to convert string to float with ',' as decimal separator
    def str_to_float(s):
        return float(s.replace(',', '.'))

    # Convert inputs to floats for comparison if they are not already
    try:
        a_float = float(a)
    except ValueError:
        a_float = str_to_float(a)

    try:
        b_float = float(b)
    except ValueError:
        b_float = str_to_float(b)

    # Compare the float values
    if a_float > b_float:
        return a
    elif b_float > a_float:
        return b
    else:
        return None
