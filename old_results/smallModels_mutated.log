    # 3 is less than the maximum possible weight, and it's balanced.
    '''

Code  :
def will_it_fly(q, w):
    if not is_palindromic(q):
        return False
    if sum(q) > w:
        return False
    return True

def is_palindromic(q):
    return q == q[::-1]
