Code  :
def by_length(arr):
    # Helper function to convert digit to its corresponding name
    def digit_to_name(digit):
        names = ["One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine"]
        return names[digit - 1]

    # Filter out numbers not between 1 and 9
    filtered_arr = [num for num in arr if 1 <= num <= 9]

    # Sort the filtered array
    sorted_arr = sorted(filtered_arr)

    # Reverse the sorted array
    reversed_arr = sorted_arr[::-1]

    # Convert digits to their corresponding names
    result = [digit_to_name(num) for num in reversed_arr]

    return result
