    Examples
    pick([], []) ➞ []
    pick(['hi', 'admin'], ['hI', 'Hi']) ➞ ['hI', 'Hi']
    pick(['hi', 'admin'], ['hi', 'hi', 'admin', 'project']) ➞ ['hi', 'admin']
    pick(['hi', 'admin'], ['hI', 'hi', 'hi']) ➞ ['hI', 'hi', 'hi']
    pick(['4'], ['1', '2', '3', '4', '5']) ➞ ['4']
    '''
Code  :
def pick(items1, items2):
    # Calculate the total number of characters in each collection
    total_chars_items1 = sum(len(item) for item in items1)
    total_chars_items2 = sum(len(item) for item in items2)

    # Compare the totals and return the appropriate collection
    if total_chars_items1 <= total_chars_items2:
        return items1
    else:
        return items2
