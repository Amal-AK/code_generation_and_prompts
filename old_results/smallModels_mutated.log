def split_words(txt):
    # Check for whitespace
    if'' in txt:
        return txt.split()
    # Check for comma
    elif ',' in txt:
        return txt.split(',')
    else:
        # Count lowercase letters with odd positions in the alphabet
        count = sum(1 for char in txt if char.islower() and (ord(char) - ord('a')) % 2 == 0)
        return count
