    pick(['hi', 'admin'], ['hI', 'hi', 'hi']) ➞ ['hI', 'hi', 'hi']
    pick(['4'], ['1', '2', '3', '4', '5']) ➞ ['4']
    '''
Code  :
import collections

def pick(items1, items2):
    count1 = sum(len(item) for item in items1)
    count2 = sum(len(item) for item in items2)
    if count1 < count2:
        return items1
    elif count1 > count2:
        return items2
    else:
        return items1
