def central(items):
    """Provide a middle-ish value from the collection of items.
    >>> central([3, 1, 2, 4, 5])
    3
    >>> central([-10, 4, 6, 1000, 10, 20])
    15.0
    """
Code  :
def central(items):
    items.sort()
    length = len(items)
    if length % 2 == 0:
        return (items[length//2] + items[length//2 - 1]) / 2
    else:
        return items[length//2]
