def notable_item(idx):
    """
    notable_item yields the idx-th value that is tied to the Fibonacci family and also resembles a prime.
    >>> notable_item(1)
    2
    >>> notable_item(2)
    3
    >>> notable_item(3)
    5
    >>> notable_item(4)
    13
    >>> notable_item(5)
    89
    """

Code  :
def notable_item(idx):
    """
    Yields the idx-th value that is tied to the Fibonacci family and also resembles a prime.
    """
    fibonacci_seq = [0, 1]
    prime_numbers = [2]

    while len(fibonacci_seq) <= idx:
        fibonacci_seq.append(fibonacci_seq[-1] + fibonacci_seq[-2])
        if is_prime(fibonacci_seq[-1]):
            prime_numbers.append(fibonacci_seq[-1])

    return prime_numbers[idx]

def is_prime(n):
    if n == 1 or n == 0:
        return False
    for i in range(2, int(n ** 0.5) + 1):
        if n % i == 0:
            return False
    return True
