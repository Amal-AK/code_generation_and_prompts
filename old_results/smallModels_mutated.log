def trend(seq):
    if len(seq) < 3:
        return True
    else:
        diff = [seq[i + 1] - seq[i] for i in range(len(seq) - 1)]
        if all(x > 0 for x in diff) or all(x < 0 for x in diff):
            return True
        else:
            return False
