def minSubAraySum(nums);
"""
Given an array of integers nums, find the minimum sum of any non-empty sub-array
of nums.
Example:
minSubArraySum([2, 3, 4, 1, 2, 4]) == 1
minSubArraySum([-1, -2, -3]) == -6
'''
Code  :
def minSubArraySum(nums):
    """
    Given an array of integers nums, find the minimum sum of any non-empty sub-array
    of nums.
    """
    # Initialize variables
    min_sum = float('inf')
    current_sum = 0
    start = 0

    # Iterate through the array
    for i in range(len(nums)):
        current_sum += nums[i]

        # If the current sum is less than the minimum sum, update the minimum sum
        if current_sum < min_sum:
            min_sum = current_sum

        # If the current sum is negative, set it to 0
        # This is done to avoid including negative numbers in the sum
        if current_sum < 0:
            current_sum = 0

        # If the current sum is greater than the minimum sum,
        # set the start index to the current index
        if current_sum > min_sum:
            start = i + 1

    # Return the minimum sum and the start index
    return min_sum, start
