import re

def examine_fragments(parts):
    opening_brackets = 0
    closing_brackets = 0
    for char in parts[0]:
        if char == '(':
            opening_brackets += 1
        elif char == ')':
            closing_brackets += 1
    for char in parts[1]:
        if char == '(':
            opening_brackets += 1
        elif char == ')':
            closing_brackets += 1
    if opening_brackets == closing_brackets:
        return 'Yes'
    else:
        return 'No'
