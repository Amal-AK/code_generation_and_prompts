Code  :
def pick_val(a, b):
    """This routine takes two numeric inputs a and b and yields the
    largest even integer that lies within the span from a to b, inclusive. If
    none can be found, it should return -1.

    For example:
    pick_val(12, 15) = 14
    pick_val(13, 12) = -1
    """
    if a > b:
        return -1

    # Start from the end of the range and move backwards until we find an even number or reach the start
    for num in range(b, a - 1, -1):
        if num % 2 == 0:
            return num

    return -1
