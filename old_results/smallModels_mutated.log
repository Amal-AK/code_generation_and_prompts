    For items = [0,8,1,2,1,7] the output should be 7
    """
Code  :
import math

def process_numbers(items):
    # Find the biggest prime number in the group
    prime_numbers = []
    for item in items:
        if is_prime(item):
            prime_numbers.append(item)
    if not prime_numbers:
        return 0
    biggest_prime = max(prime_numbers)

    # Sum the digits of the biggest prime number
    return sum(map(int, str(biggest_prime)))

def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True
