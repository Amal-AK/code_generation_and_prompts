def munch(count, want, left):
    """
    You're an eater that has already consumed some items,
    but now intends to take in more to reach today's target.
    you should return a list of [ total consumed after this intake,
                                    the amount remaining afterwards ]
    if there aren't enough items available, you will take all that remain, but will still be short.
    
    Example:
    * munch(5, 6, 10) -> [11, 4]
    * munch(4, 8, 9) -> [12, 1]
    * munch(1, 10, 10) -> [11, 0]
    * munch(2, 11, 5) -> [7, 0]
    
    Variables:
    @count :
        the amount already consumed.
    @want :
        the amount you aim to consume.
    @left :
        how much is available in stock
    
    Bounds:
    * 0 <= count <= 1000
    * 0 <= want <= 1000
    * 0 <= left <= 1000

    Have fun :)
    """
Code  :
def munch(count, want, left):
    # Calculate the total amount of items to consume
    total_want = count + want

    # If there are enough items available, consume the desired amount
    if total_want <= left:
        return [total_want, left - total_want]
    # If there aren't enough items available, consume all that remain
    else:
        return [count + left, 0]
