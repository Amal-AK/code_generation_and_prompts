def tweak_count(items):
    """
    Given a sequence items of values, determine how many entries might need to be altered
    to make the sequence read the same both ways. A palindromic sequence is one that
    is read the same backwards and forwards. A single modification can replace one entry with any other.

    For example:
    tweak_count([1,2,3,5,4,7,9,6]) == 4
    tweak_count([1, 2, 3, 4, 3, 2, 2]) == 1
    tweak_count([1, 2, 3, 2, 1]) == 0
    """
Code  :
import collections

def tweak_count(items):
    # Convert the input sequence to a list if it's not already one
    items = list(items)

    # Create a dictionary to keep track of the number of occurrences of each item
    item_counts = collections.Counter(items)

    # Initialize the number of tweaks to 0
    num_tweaks = 0

    # Iterate over the items in the sequence
    for item in items:
        # If the item has an odd number of occurrences, it needs to be tweaked
        if item_counts[item] % 2 == 1:
            # Increment the number of tweaks
            num_tweaks += 1

    # Return the number of tweaks needed to make the sequence palindromic
    return num_tweaks
