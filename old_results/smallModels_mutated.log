def spread_measure(items):
    """ For an input collection of values, work out a kind of average absolute spread
    around a central point for the data. This is a loose measure of how far
    entries tend to be from a center (like the mean):
    MAD = average | x - center |
    >>> spread_measure([1.0, 2.0, 3.0, 4.0])
    1.0
    """
Code  :
def spread_measure(items):
    """ Calculate the Median Absolute Deviation (MAD) of a list of numbers.

    MAD is a robust measure of statistical dispersion, being less sensitive to outliers than the standard deviation.
    It is defined as the median of the absolute deviations from the dataset's median.

    Args:
    items (list of float): The input list of numerical values.

    Returns:
    float: The Median Absolute Deviation of the input list.
    """
    if not items:
        return 0.0

    # Calculate the median of the items
    sorted_items = sorted(items)
    n = len(sorted_items)
    mid = n // 2
    if n % 2 == 0:
        median = (sorted_items[mid - 1] + sorted_items[mid]) / 2.0
    else:
        median = sorted_items[mid]

    # Calculate the absolute deviations from the median
    abs_deviations = [abs(x - median) for x in items]

    # Calculate the median of these absolute deviations
    abs_deviations_sorted = sorted(abs_deviations)
    mad = abs_deviations_sorted[mid]

    return mad

# Example usage:
print(spread_measure([1.0, 2.0, 3.0, 4.0]))  # Output: 1.0
