def by_length(arr):
    # Helper function to convert numbers to their corresponding names
    def convert_to_name(num):
        names = ["", "One", "Two", "Three", "Four", "Five", "Six", "Seven", "Eight", "Nine"]
        return names[num]

    # Filter out numbers not in the range 1-9
    arr = [num for num in arr if 1 <= num <= 9]

    # Sort the array in ascending order
    arr.sort()

    # Reverse the array
    arr.reverse()

    # Convert each number in the array to its corresponding name
    arr = [convert_to_name(num) for num in arr]

    return arr
