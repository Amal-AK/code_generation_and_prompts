def process_items(items):
    """ From a given collection of values, produce a sequence of running high values seen up to each point
    in the series.
    >>> process_items([1, 2, 3, 2, 3, 4, 2])
    [1, 2, 3, 3, 3, 4, 4]
    """
    if not items:  # Check if the list is empty
        return []

    running_highs = []
    current_max = float('-inf')  # Initialize with the smallest possible number

    for item in items:
        current_max = max(current_max, item)
        running_highs.append(current_max)

    return running_highs
