def is_multiply_prime(a)
    """Write a function that returns true if the given number is the mutliplication of 3 prime numbers
and false otherwise.
Knowing that (a) is less then 100. 
    Example:
    is_multiply_prime(30) == True
    30 = 2 * 3 * 5
    ""
Code  :
import math

def is_prime(n):
    if n <= 1:
        return False
    if n == 2:
        return True
    if n % 2 == 0:
        return False
    sqrt_n = math.isqrt(n)
    for i in range(3, sqrt_n + 1, 2):
        if n % i == 0:
            return False
    return True

def is_multiply_prime(a):
    factors = []
    for i in range(2, a + 1):
        if a % i == 0 and is_prime(i):
            factors.append(i)
            a //= i
            if len(factors) > 3 or a == 1:
                break
    if len(factors) == 3 and a == 1:
        return True
    else:
        return False
