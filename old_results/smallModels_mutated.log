'''
Givn a list of numbers, return the sum of squares of the numbers
in the list that are odd. Ignore numbers that are negative or not intrgers.
    
    double_the_difference([1, 3, 2, 0]) == 1 + 9 + 0 + 0 = 10
    double_the_difference([-1, -2, 0]) == 0
    double_the_difference([9, -2]) == 81
    double_the_difference([0]) == 0  
   
If the input list is empty, return 0.
''
Code  :
def double_the_difference(lst):
    """
    Given a list of numbers, return the sum of squares of the numbers
    in the list that are odd. Ignore numbers that are negative or not integers.

    :param lst: List of numbers
    :return: Sum of squares of odd, non-negative integers in the list
    """
    # Filter out negative numbers and non-integers
    filtered_numbers = [num for num in lst if isinstance(num, int) and num >= 0]

    # Filter out even numbers
    odd_numbers = [num for num in filtered_numbers if num % 2!= 0]

    # Calculate the sum of squares of the odd numbers
    result = sum(num ** 2 for num in odd_numbers)

    return result
