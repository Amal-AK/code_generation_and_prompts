Code  :
def convert_mini_roman(val):
    """
    Given a numeric input, produce a roman-style textual rendition of it,
    and give that back in lowercase.
    Expected range: 1 to 1000

    Examples:
    >>> convert_mini_roman(19) == 'xix'
    >>> convert_mini_roman(152) == 'clii'
    >>> convert_mini_roman(426) == 'cdxxvi'
    """
    if not (1 <= val <= 1000):
        raise ValueError("Input must be between 1 and 1000")

    roman_numerals = [
        ('m', 1000), ('cm', 900), ('d', 500), ('cd', 400),
        ('c', 100), ('xc', 90), ('l', 50), ('xl', 40),
        ('x', 10), ('ix', 9), ('v', 5), ('iv', 4), ('i', 1)
    ]

    result = []
    for numeral, value in roman_numerals:
        while val >= value:
            result.append(numeral)
            val -= value

    return ''.join(result)

# Test cases
print(convert_mini_roman(19))   # Output: xix
print(convert_mini_roman(152))  # Output: clii
print(convert_mini_roman(426))  # Output: cdxxvi
