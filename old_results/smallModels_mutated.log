Code  :
import math

def pluck(arr):
    # Find the smallest even value in the array
    smallest_even_value = math.inf
    smallest_even_index = -1
    for i, value in enumerate(arr):
        if value % 2 == 0 and value < smallest_even_value:
            smallest_even_value = value
            smallest_even_index = i

    # If there is no even value, return an empty list
    if smallest_even_index == -1:
        return []

    # Return the smallest even value and its index in a list
    return [smallest_even_value, smallest_even_index]
