def anti_shuffle(s)
    """
  Wrtie a function that takes a string and returns a oredred version of it.
    Ordered version of string, is a string where all words(separated by space)
 are replaced by a new word where all the charcaters arragned in
    asecnding order based on ascii value.
    Note: You should keep the order of words and blank spaces in the sentence.

    For example:
    anti_shuffle('Hi') returns 'Hi'
    anti_shuffle('hello') returns 'ehllo'
    anti_shuffle('Hello World!!!') returns 'Hello !!!Wdlor'
    """
Code  :
def anti_shuffle(s):
    # Split the input string into words and non-word characters
    import re
    tokens = re.findall(r'\b\w+\b|[^\w\s]', s)

    # Process each token
    result = []
    for token in tokens:
        if token.isalpha():  # Check if the token is a word
            # Sort the characters in ascending ASCII order
            sorted_token = ''.join(sorted(token))
            result.append(sorted_token)
        else:
            # Keep non-word characters as they are
            result.append(token)

    # Join the processed tokens back into a single string
    return ''.join(result)
