def trend(seq):
    """Return True if sequence items broadly move in one direction.
    >>> trend([1, 2, 4, 20])
    True
    >>> trend([1, 20, 4, 10])
    False
    >>> trend([4, 1, 0, -10])
    True
    """

Code  :
import math

def trend(seq):
    if len(seq) < 2:
        return False

    # Calculate the average of the sequence
    avg = sum(seq) / len(seq)

    # Calculate the standard deviation of the sequence
    stddev = math.sqrt(sum((x - avg) ** 2 for x in seq) / (len(seq) - 1))

    # Check if the standard deviation is within a certain threshold
    if stddev < 1:
        return True

    # Check if the sequence is monotonically increasing or decreasing
    if all(x < y for x, y in zip(seq, seq[1:])):
        return True
    elif all(x > y for x, y in zip(seq, seq[1:])):
        return True

    return False
