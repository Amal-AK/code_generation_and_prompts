def slope_of(vals):
    """ vals stand for quantities describing an expression.
    vals[0] + vals[1] * x + vals[2] * x^2 + ....
     Return a sequence showing its rate-like change in the same layout.
    >>> slope_of([3, 1, 2, 4, 5])
    [1, 4, 12, 20]
    >>> slope_of([1, 2, 3])
    [2, 6]
    """
Code  :
def slope_of(vals):
    # Remove the first element from the list as it's not part of the equation
    vals.pop(0)
    # Initialize an empty list to store the slopes
    slopes = []
    # Iterate over the list from the second element to the end
    for i in range(1, len(vals)):
        # Calculate the slope and append it to the slopes list
        slope = i * vals[i-1]
        slopes.append(slope)
    return slopes
