import re

def total_match(lst1, lst2):
    """
    Return the list that has total number of chars in the all strings of the list less than the other list.
    """
    lst1_total = sum(len(s) for s in lst1)
    lst2_total = sum(len(s) for s in lst2)
    if lst1_total < lst2_total:
        return lst1
    elif lst2_total < lst1_total:
        return lst2
    else:
        return []
