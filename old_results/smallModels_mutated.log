    """
    Given two numbers x and y, provide the even numbers between them, in ascending order.

    For example:
    collect_items(2, 8) => [2, 4, 6, 8]
    collect_items(8, 2) => [2, 4, 6, 8]
    collect_items(10, 14) => []
    """

Code  :
def collect_items(x, y):
    # Swap the numbers if x is greater than y
    if x > y:
        x, y = y, x

    # Initialize an empty list to store the even numbers
    even_numbers = []

    # Iterate over the range from x to y
    for i in range(x, y+1):
        # If the number is even, append it to the list
        if i % 2 == 0:
            even_numbers.append(i)

    # Return the list of even numbers
    return even_numbers
