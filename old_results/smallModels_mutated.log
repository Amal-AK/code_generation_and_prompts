def words_string(s):
    """
    Splits a string of words separated by commas or spaces into an array of words.

    Args:
    s (str): The input string containing words separated by commas or spaces.

    Returns:
    list: A list of words extracted from the input string.
    """
    # Replace commas with spaces to unify the separators
    unified_string = s.replace(',','')
    # Split the string by spaces and filter out any empty strings
    words = [word for word in unified_string.split() if word]
    return words

