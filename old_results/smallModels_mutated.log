def shift_one_ball(seq):
    """We have a sequence 'seq' of N elements seq[1], seq[2], ..., seq[N]. The
    values in the sequence will be in some initial arrangement. Your task is to
    decide whether it is possible to obtain the sequence in a sorted, non-decreasing
    arrangement by using the following kind of move on the given sequence:
        You may apply a rightward cyclic move any number of times.

    One such move shifts every element one position to the right, with the tail
    coming around to the front.

    If it is possible to get a sorted arrangement by applying the above move
    then return True else return False.
    If the given sequence is empty then return True.

    Note: The values in the sequence are distinct.

    For Example:
    
    shift_one_ball([3, 4, 5, 1, 2])==>True
    Explanation: By performing 2 rightward cyclic moves, a non-decreasing order can
                 be achieved for the given sequence.
    shift_one_ball([3, 5, 4, 1, 2])==>False
    Explanation:It is not possible to get a non-decreasing arrangement for the given
                sequence by performing any number of such cyclic moves.
                
    """
Code  :
import math

def shift_one_ball(seq):
    # Check if the sequence is empty
    if not seq:
        return True

    # Check if the sequence is already sorted
    if all(seq[i] <= seq[i+1] for i in range(len(seq)-1)):
        return True

    # Check if the sequence can be sorted by performing a rightward cyclic move
    for i in range(math.ceil(len(seq)/2)):
        if all(seq[i] <= seq[i+1] for i in range(len(seq)-1)):
            return True

    return False
