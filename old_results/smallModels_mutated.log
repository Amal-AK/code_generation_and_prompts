Code  :
def process(content):
    """
    Create a routine that accepts some input and transforms it in a way that letter casing is generally altered and vowels are replaced by the character a couple positions later in the English alphabet. Assume the input consists only of letters. 

    Examples:
    >>> process('test')
    'TGST'
    >>> process('This is a message')
    'tHKS KS C MGSSCGG'
    """
    # Define a mapping for vowel replacement
    vowel_map = {'a': 'c', 'e': 'g', 'i': 'k', 'o': 'q', 'u': 'w',
                 'A': 'C', 'E': 'G', 'I': 'K', 'O': 'Q', 'U': 'W'}

    # Function to alter case and replace vowels
    def transform_char(c):
        if c.isalpha():
            if c.lower() in vowel_map:
                return vowel_map[c]
            else:
                return c.swapcase()
        return c

    # Apply transformation to each character in the content
    transformed_content = ''.join(transform_char(c) for c in content)

    return transformed_content

# Example usage
