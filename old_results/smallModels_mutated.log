    pick_next([1, 2, 3, 4, 5]) == 2
    pick_next([5, 1, 4, 3, 2]) == 2
    pick_next([]) == None
    pick_next([1, 1]) == None
    """
Code  :
def pick_next(items):
    if len(items) < 2:
        return None

    unique_items = list(set(items))
    if len(unique_items) < 2:
        return None

    unique_items.sort()
    return unique_items[1]
