Code  :
def count_items(seq):
    vowels = "aeiou"
    count = sum(1 for char in seq.lower() if char in vowels)

    # Check if 'y' is at the end and consider it as a vowel
    if seq.endswith('y') or seq.endswith('Y'):
        count += 1

    return count
