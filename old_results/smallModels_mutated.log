Code  :
from typing import List

# Helper dictionary to map number words to their numeric values
NUM_MAP = {
    'zero': 0,
    'one': 1,
    'two': 2,
    'three': 3,
    'four': 4,
    'five': 5,
   'six': 6,
   'seven': 7,
    'eight': 8,
    'nine': 9
}

def sort_numbers(numbers: str) -> str:
    """ Sorts a space-delimited string of numberals from 'zero' to 'nine'. """
    # Split the input string into a list of number words
    num_words = numbers.split()

    # Convert number words to their numeric values
    nums = [NUM_MAP[word] for word in num_words]

    # Sort the numeric values
    sorted_nums = sorted(nums)

    # Convert the sorted numeric values back to number words
    sorted_num_words = [list(NUM_MAP.keys())[list(NUM_MAP.values()).index(num)] for num in sorted_nums]

    # Join the sorted number words into a single string
    return''.join(sorted_num_words)

# Example usage
print(sort_numbers('three one five'))  # Output: 'one three five'
