    if n % 2 == 0 or n % 3 == 0:
        return False
    i = 5
    while i * i <= n:
        if n % i == 0 or n % (i + 2) == 0:
            return False
        i += 6
    return True

def check_size(text):
    """Check if the length of the input text is a prime number."""
    return is_prime(len(text))
