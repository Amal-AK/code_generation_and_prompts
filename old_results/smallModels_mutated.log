    """Your task is to put together a routine that will handle the product
    a * b. The routine should indicate True when a * b comes out to a whole number and False
    otherwise. Both inputs are string forms of a fraction, expressed as
    <numerator>/<denominator> where numerator and denominator are positive whole numbers.

    You can assume that a and b are valid fractions and don't use zero as a denominator.

    assess("1/5", "5/1") = True
    assess("1/6", "2/1") = False
    assess("7/10", "10/2") = False
    """
Code  :
def gcd(x, y):
    """Helper function to calculate the greatest common divisor."""
    while y!= 0:
        (x, y) = (y, x % y)
    return x

def simplify_fraction(numerator, denominator):
    """Helper function to simplify a fraction."""
    common_divisor = gcd(numerator, denominator)
    return numerator // common_divisor, denominator // common_divisor

def assess(a, b):
    """Function to check if the product of two fractions results in a whole number."""
    # Splitting the fractions into numerators and denominators
    num_a, denom_a = map(int, a.split('/'))
    num_b, denom_b = map(int, b.split('/'))

    # Simplifying the fractions
    num_a, denom_a = simplify_fraction(num_a, denom_a)
    num_b, denom_b = simplify_fraction(num_b, denom_b)

    # Calculating the product of the fractions
    product_numerator = num_a * num_b
    product_denominator = denom_a * denom_b

    # Simplifying the product
    product_numerator, product_denominator = simplify_fraction(product_numerator, product_denominator)

    # Checking if the product is a whole number
    return product_denominator == 1
