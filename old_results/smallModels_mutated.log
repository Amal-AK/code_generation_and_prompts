Code  :
def blend_chars(first, second):
    """Inputs are two text pieces made up of a limited set of characters.
    Apply an exclusive-like combine on these inputs and return the outcome as text.
    >>> blend_chars('010', '110')
    '100'
    """
    # Convert the input strings to lists for easier manipulation
    first_list = list(first)
    second_list = list(second)

    # Ensure both lists are of the same length
    if len(first_list)!= len(second_list):
        raise ValueError("Input strings must be of the same length")

    # Perform the exclusive OR operation character by character
    result = ''.join('1' if a!= b else '0' for a, b in zip(first_list, second_list))

    return result
