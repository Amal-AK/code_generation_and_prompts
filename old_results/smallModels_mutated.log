Code  :
import re

def is_bored(S):
    """
    This function counts the number of boredoms in a given string of words.
    A boredom is a sentence that starts with the word "I".
    Sentences are delimited by '.', '?' or '!'.

    Args:
    S (str): The string of words to be checked.

    Returns:
    int: The number of boredoms in the string.

    Example:
    >>> is_bored("Hello world")
    0
    >>> is_bored("The sky is blue. The sun is shining. I love this weather")
    1
    """
    # Split the string into sentences using regular expressions
    sentences = re.split('[.!?]', S)

    # Initialize the count of boredoms
    boredom_count = 0

    # Check each sentence
    for sentence in sentences:
        # If the sentence starts with "I", increment the count
        if sentence.strip().startswith("I"):
            boredom_count += 1

    return boredom_count
