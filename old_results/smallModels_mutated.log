import math

def skjkasdkd(lst):
    largest_prime = 0
    for i in lst:
        if is_prime(i) and i > largest_prime:
            largest_prime = i
    return sum(str(largest_prime))

def is_prime(n):
    if n < 2:
        return False
    for i in range(2, int(math.sqrt(n)) + 1):
        if n % i == 0:
            return False
    return True
